    {
      "term": "set",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A collection of things that belong together or are used together; also a group or fixed arrangement.",
          "examples": [
            "A set of dishes sits on the table.",
            "He bought a set of tools for the workshop."
          ],
          "collocations": ["tool set", "dinner set", "set of glasses", "complete set"],
          "synonyms": ["group", "collection", "array"],
          "antonyms": ["single", "loss"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "A specific number of items used together; a chess set, a set of stairs.",
          "examples": [
            "She climbed the stairs in three quick sets.",
            "A set of stairs led to the balcony."
          ],
          "collocations": ["exercise set", "three-set routine"],
          "synonyms": ["series", "batch"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "sport", "architecture"]
        },
        {
          "pos": "verb",
          "definition": "To put or arrange something in a particular place or position; to set a table or sun.",
          "examples": [
            "She set the vase in the center of the table.",
            "The sun sets in the west."
          ],
          "collocations": ["set the table", "set a price", "set the scene"],
          "synonyms": ["place", "put", "position"],
          "antonyms": ["remove", "unset"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "To cause to become; to fix or decide a value, time, or condition.",
          "examples": [
            "The committee set a deadline for Friday.",
            "They set the price high."
          ],
          "collocations": ["set a deadline", "set a price", "set the date"],
          "synonyms": ["determine", "establish"],
          "antonyms": ["unset", "reverse"],
          "register": "neutral",
          "domain": ["general", "business"]
        }
      ]
    },
