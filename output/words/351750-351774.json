    {
      "term": "senseless",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Lacking sense or meaning; pointless or foolish.",
          "examples": [
            "It was a senseless act of vandalism.",
            "The movie was long and senseless, with no clear plot."
          ],
          "collocations": [
            "senseless violence",
            "senseless act",
            "completely senseless"
          ],
          "synonyms": ["pointless", "foolish", "irrational"],
          "antonyms": ["sensible", "meaningful", "rational"],
          "register": "formal",
          "domain": ["general", "societal"]
        }
      ]
    },
