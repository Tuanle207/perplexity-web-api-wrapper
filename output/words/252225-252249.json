      "term": "nonjudgmental",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "not judging people harshly or negatively, and not making quick or critical judgments about others",
          "examples": [
            "She was praised for being nonjudgmental about people's choices.",
            "A nonjudgmental attitude helps friends feel safe sharing their problems."
          ],
          "collocations": [
            "nonjudgmental approach",
            "nonjudgmental attitude",
            "nonjudgmental listening"
          ],
          "synonyms": ["open-minded", "tolerant", "unprejudiced"],
          "antonyms": ["judgmental", "condemning", "prejudiced"],
          "register": "informal",
          "domain": ["general", "everyday", "psychology"]
        }
      ]
    },
