      "term": "brahmapootra",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a term often used in Hindu culture to refer to a descendant or son of Brahma, sometimes spelled 'Brahmaputra' when referring to the river or lineage context; historical or mythical usage varies and may be rare in modern English.",
          "examples": ["In some texts, a brahmapootra is described as a divine or legendary descendant of Brahma."],
          "collocations": ["brahmapootra myth", "brahmapootra lineage"],
          "synonyms": ["brahmin descendant (approximate)"],
          "antonyms": [],
          "register": "literary",
          "domain": ["mythology", "religion", "general"]
        }
