      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "relating to the earliest ages of the world or to the very ancient, original state.",
          "examples": [
            "The fossil records reveal primeval forests.",
            "They described the landscape as primeval and wild."
          ],
          "collocations": ["primeval forest", "primeval era", "primeval landscape"],
