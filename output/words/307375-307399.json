    {
      "term": "primeur",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a French term used in English to describe an early or first release of a product, especially in wine or other luxury goods.",
          "examples": [
            "The wine shop offered a primeur sale for next season's vintage.",
            "They lined up for the primeur release of the limited edition champagne."
          ],
          "collocations": ["primeur wine", "primeur release", "primeur sale"],
          "synonyms": ["early release", "pre-release"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "commerce"]
        }
      ]
    },
    {
      "term": "primeurs",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
