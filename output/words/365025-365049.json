      "term": "solonetz",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "a type of saline soil with high sodium content that is poorly drained and forms a hard pan; in soil science, a saline soil with a sodium saturation ratio that causes dispersion of clays.",
          "examples": [
            "The farm was troubled by a solonetz, making tilling difficult.",
            "Researchers studied solonetz soils to improve crop yields."
          ],
          "collocations": ["solonetz soil", "solonetz soil profile", "desert solonetz"],
          "synonyms": ["alkali soil", "sodic soil"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "environment", "agriculture"]
        }
      ]
