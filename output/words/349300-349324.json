          "collocations": ["seep through", "seep away", "slowly seep"],
          "synonyms": ["ooze", "drip", "trickle"],
          "antonyms": ["pour", "flow freely"],
          "register": "neutral",
          "domain": ["general", " Everyday"]
        },
        {
