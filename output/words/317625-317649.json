      "term": "queazy",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Feeling that you might vomit, or slightly sick, especially in your stomach.",
          "examples": [
            "The boat moved so much that I started to feel queazy.",
            "He always gets queazy on long car journeys."
          ],
          "collocations": [
            "feel queazy",
            "get queazy",
            "make someone queazy",
            "a queazy stomach",
            "feel a bit queazy"
          ],
          "synonyms": [
            "nauseous",
            "sick",
            "ill"
          ],
          "antonyms": [
            "well"
          ],
          "register": "null",
          "domain": [
            "everyday",
            "general"
          ]
        },
        {
