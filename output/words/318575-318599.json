    {
      "term": "quitclaim",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A legal claim that relinquishes any future rights to property.",
          "examples": [
            "He signed a quitclaim deed to transfer his interest.",
            "The quitclaim settles any potential claims on the land."
          ],
          "collocations": ["quitclaim deed", "quitclaim deed", "quitclaim on property"],
          "synonyms": ["relinquishment", "waiver"],
          "antonyms": [],
          "register": "formal",
          "domain": ["law", "general"]
        },
        {
          "pos": "verb",
          "definition": "To relinquish all rights or claims to something, especially property, via a quitclaim deed.",
          "examples": [
            "They quitclaimed their interest to the buyer.",
            "The seller quitclaims any future rights to the property."
          ],
          "collocations": ["quitclaim the interest", "quitclaim deed the property"],
          "synonyms": ["relinquish", "waive"],
          "antonyms": [],
          "register": "formal",
