    {
      "term": "quisquilious",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Characterized by being full of trivial, useless, or unpleasant things; of little value.",
          "examples": [
            "The drawer was filled with quisquilious junk that no one ever used.",
            "She dismissed the report as quisquilious detail and ignored it."
          ],
          "collocations": ["quisquilious items", "quisquilious details", "quisquilious junk"],
          "synonyms": ["trivial", "paltry", "valueless"],
          "antonyms": ["valuable", "essential"],
          "register": "formal",
          "domain": ["general", "everyday"]
        }
      ]
    },
    {
      "term": "quisquous",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Disposed to trivialities or concerned with petty, unimportant matters.",
          "examples": [
            "His remarks were(quotes) quisquous, focusing on tiny flaws rather than the big picture."
          ],
          "collocations": ["quisquous concerns", "quisquous chatter"],
          "synonyms": ["pettish", "frivolous"],
          "antonyms": ["serious", "weighty"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
