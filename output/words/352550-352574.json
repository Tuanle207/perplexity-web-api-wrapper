    {
      "term": "serial",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "happening in a series or one after another; sequential",
          "examples": ["The story unfolds in serial chapters.", "She watched the serial episodes every week."],
          "collocations": ["serial number", "serial killer", "serial communication", "serial publication"],
          "synonyms": ["sequential", "successive"],
          "antonyms": ["random", "sporadic"],
          "register": "neutral",
          "domain": ["general", "literature", "media"]
        },
        {
          "pos": "noun",
          "definition": "a story or program that is published or broadcast in parts, usually daily or weekly",
          "examples": ["The soap opera is a long-running serial.", "This crime serial has ten episodes."],
          "collocations": ["television serial", "radio serial", "serial publication"],
