      "term": "carry",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to support and move something from one place to another using hands or a device",
          "examples": [
            "She can carry a heavy box by herself.",
            "The bags are too heavy to carry up the stairs."
          ],
          "collocations": [
            "carry a bag",
            "carry a suitcase",
            "carry a load",
            "carry someone",
            "carry out",
            "carry on"
          ],
          "synonyms": ["transport", "tote", "lift"],
          "antonyms": ["unload", "drop", "remove"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
