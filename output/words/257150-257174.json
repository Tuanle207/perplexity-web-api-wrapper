  "items": [
    {
      "term": "nuclearize",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to bring under control or influence by nuclear power, often by including nuclear weapons in a policy or strategy",
          "examples": [
            "The alliance plans to nuclearize its defense policy.",
            "The country decided to nuclearize its regional security strategy."
          ],
          "collocations": ["nuclearize policy", "nuclearize defense", "nuclearize capabilities"],
          "synonyms": ["weaponize", "arm", "nucleate (in a metaphorical sense)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "politics", "military"]
        }
      ]
    },
    {
