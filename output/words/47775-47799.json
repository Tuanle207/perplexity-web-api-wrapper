    {
      "term": "brainwashed",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "made to accept new beliefs or ideas without question through deliberate manipulation",
          "examples": [
            "The propaganda campaign left many citizens brainwashed into supporting the policy.",
            "She felt brainwashed by constant exposure to persuasive advertising."
          ],
          "collocations": ["completely brainwashed", "politically brainwashed", "brainwashed into"],
          "synonyms": ["indoctrinated", "manipulated"],
          "antonyms": ["independent", "unbiased"],
          "register": "formal",
          "domain": ["general", "psychology", "politics"]
        }
      ]
    },
