      "term": "potch",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "to mix or stir a substance roughly; to cull or collect roughly; to patch together in a rough or clumsy way",
          "examples": [
            "She potched together a meal from leftovers.",
            "The committee potched a proposal from several scattered ideas."
