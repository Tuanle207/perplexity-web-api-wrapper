      "term": "capacitor",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A passive electronic component that stores electrical energy temporarily in an electric field.",
          "examples": [
            "The capacitor helps smooth surges in the power supply.",
            "A ceramic capacitor is often used for high-frequency filtering."
          ],
          "collocations": [
            "electrolytic capacitor",
            "ceramic capacitor",
            "storage capacitor",
            "capacitor array",
            "capacitor bank",
            "electrical capacitor",
            "time constant capacitor"
          ],
          "synonyms": ["condenser"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "science", "general"]
        },
        {
          "pos": "verb",
          "definition": "To store electrical energy in a capacitor; to charge a capacitor.",
          "examples": [
            "The battery charges the capacitor to stabilize the circuit.",
            "Capacitors are charged and discharged in timing circuits."
          ],
          "collocations": [
            "charge capacitor",
            "discharge capacitor",
            "capacitor charge",
            "capacitor discharge"
          ],
          "synonyms": [],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "engineering", "general"]
        }
      ]
    },
