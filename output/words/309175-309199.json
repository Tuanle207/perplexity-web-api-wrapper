    {
      "term": "prolactin",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a hormone produced by the pituitary gland that stimulates milk production after childbirth",
          "examples": [
            "Her doctor checked her prolactin level to assess lactation readiness.",
            "High prolactin can interfere with ovulation in some women."
          ],
          "collocations": [
            "prolactin level",
            "increase/decrease prolactin",
            "prolactin secretion",
            "prolactin in pregnancy",
            "prolactin therapy"
          ],
          "synonyms": [
            "PRL (abbreviation, informal)"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": ["medicine", "biology", "healthcare", "general"]
        }
      ]
    },
