    {
      "term": "sannyasi",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A Hindu renouncer or ascetic who has adopted sannyāsa, often living a life of spiritual discipline.",
          "examples": [
            "The sannyasi withdrew from worldly life to seek spiritual insight.",
            "Some sannyasis wander as beggars to practice detachment."
          ],
          "collocations": [
            "Hindu sannyasi",
            "wandering sannyasi",
            "renouncer sannyasi"
          ],
          "synonyms": ["renouncer", "ascetic", "sadhu"],
          "antonyms": ["householder", "renounced life (antonym)"],
          "register": "formal",
          "domain": ["culture", "religion", "general"]
        }
      ]
    },
    {
