      "term": "asystolic",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Relating to or having asystole, when the heart shows no electrical activity and does not beat.",
          "examples": [
            "The patient arrived in an asystolic state and CPR was started immediately.",
            "Asystolic cardiac arrest has a very low chance of survival.",
            "The monitor showed an asystolic rhythm with a flat line on the screen."
          ],
          "collocations": [
            "asystolic arrest",
            "asystolic rhythm",
            "asystolic patient",
            "asystolic cardiac arrest",
            "asystolic state",
            "asystolic episode",
            "asystolic event"
          ],
          "synonyms": [
            "flatline",
            "cardiac-arrested"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine"
          ]
        }
      ]
    },
