      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A condition in which the heart shows complete asystole, with no effective contractions or electrical activity.",
          "examples": [
            "Prolonged asystolism usually leads to irreversible brain damage.",
            "The team discussed possible causes of the sudden asystolism.",
            "Asystolism is a life‑threatening emergency that requires immediate treatment."
