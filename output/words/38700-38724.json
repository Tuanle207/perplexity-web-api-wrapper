{
  "items": [
    {
      "term": "bespeckles",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to cover something with small spots or specks, especially of a different color",
          "examples": [
            "The artist bespeckled the canvas with tiny specks of paint.",
            "The white shirt was bespeckled with rain droplets."
          ],
          "collocations": ["bespeckle with", "bespeckled by", "tiny specks"],
          "synonyms": ["speckle", "spatter"],
          "antonyms": ["unspotted", "clean"],
          "register": "neutral",
          "domain": ["general", "arts"]
        }
      ]
    },
    {
      "term": "bespeckling",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of adding small specks or spots to something",
          "examples": [
            "The portrait shows bespeckling across the surface.",
            "Bespeckling can create a starry effect."
          ],
          "collocations": ["bespeckling on", "with bespeckling"],
          "synonyms": ["speckling", "spattering"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["art", "design"]
        }
      ]
    },
    {
