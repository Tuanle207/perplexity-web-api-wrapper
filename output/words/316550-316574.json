      "term": "pythonoid",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Resembling or relating to a python or the form of a snake-like creature.",
          "examples": [
            "A pythonoid fossil suggests a long, snake-like body.",
            "The pythonoid outline in the diagram hints at a serpentine shape."
          ],
          "collocations": [
            "pythonoid form",
            "pythonoid structure",
            "pythonoid body"
          ],
          "synonyms": ["serpentine", "snake-like", "dragoniform (rare)"],
          "antonyms": ["linear", "straight", "snakelike (redundant)"],
          "register": "neutral",
          "domain": ["science", "academic", "general"]
        }
      ]
    },
    {
      "term": "pythonomorph",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "A member of the Pythonomorpha, a historical grouping used in paleontology to describe serpentine or lizard-like reptiles linking snakes and mosasaurs.",
          "examples": [
            "The fossil was classified as a pythonomorph.",
            "Pythonomorphs are often cited in discussions of early snake evolution."
          ],
          "collocations": [
            "pythonomorph fossil",
            "pythonomorph classification",
            "pythonomorph reptile"
          ],
          "synonyms": ["serpentine reptile", "pseudofamily (historical context)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "biology", "paleontology"]
        }
      ]
    },
    {
