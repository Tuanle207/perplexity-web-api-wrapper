        {
          "pos": "verb",
          "definition": "To snore; to make a ronco sound while sleeping.",
          "examples": ["He tends to ronco when he naps."],
          "collocations": ["ronco loudly", "ronco during sleep"],
          "synonyms": ["snore"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "medicine"]
