      "term": "scintiscan",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a medical imaging test that uses a scintillating detector to produce images from radioactive emissions in the body",
          "examples": ["The patient underwent a scintiscan to check for abnormalities in the thyroid."],
          "collocations": ["bone scintiscan", "myocardial scintiscan", "nuclear medicine scintiscan"],
          "synonyms": ["nuclear scan", "radionuclide scan"],
          "antonyms": [],
          "register": "formal",
          "domain": ["medical", "technology"]
        }
      ]
    },
