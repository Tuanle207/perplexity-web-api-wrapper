    {
      "term": "benight",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "To cause someone to be asleep, ignorant, or unaware; to cover with darkness; to cause to be in a state of ignorance or oblivion.",
          "examples": [
            "A heavy fog benighted the valley.",
            "The decision to cancel the embassy was benighted by secrecy.",
            "He was benighted to the consequences of his actions."
          ],
          "collocations": [
            "benight someone",
            "benight the region",
            "benighted by ignorance"
          ],
          "synonyms": ["blind", "darken", "obscure"],
          "antonyms": ["enlighten", "illuminate", "expose"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
    {
