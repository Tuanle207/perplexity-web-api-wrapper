            "He skimmed the scum from the top of the simmering soup."
          ],
          "collocations": ["scum layer", "fish scum", "boiling scum"],
          "synonyms": ["foam", "froth", "filth"],
          "antonyms": ["clarity", "cleanliness"],
          "register": "informal",
          "domain": ["general", "kitchen"]
        },
        {
          "pos": "noun",
