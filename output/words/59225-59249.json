    "term": "cassegrain",
    "kind": "word",
    "cefrLevel": "null",
    "senses": [
      {
        "pos": "noun",
        "definition": "A type of reflecting telescope design with a curved primary mirror and a hyperboloidal secondary mirror that reflects light back through a central hole in the primary mirror.",
        "examples": [
          "The observatory mainly uses a Cassegrain telescope for deep-sky imaging.",
          "Cassegrain designs are common in modern amateur and professional telescopes."
        ],
        "collocations": [
          "Cassegrain telescope",
          "Cassegrain design",
          "long focal length Cassegrain"
        ],
        "synonyms": ["Gregorian telescope variant", "mirror-based telescope design"],
        "antonyms": ["Refracting telescope", "Newtonian telescope"],
        "register": "neutral",
        "domain": ["science", "technology", "astronomy"]
      }
    ]
  },
