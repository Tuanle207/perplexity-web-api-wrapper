          "collocations": ["sinecurists", "pay", "pensions", "office", "position"],
          "synonyms": ["deadweight", "malinger", "privileged officeholder"],
          "antonyms": ["hard worker", "productive employee"],
          "register": "formal",
          "domain": ["general", "business", "politics"]
        }
      ]
    },
