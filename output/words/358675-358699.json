      "term": "sinecurists",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "people who hold sinecures, i.e., jobs that require little work but provide pay or prestige",
          "examples": [
            "The board awarded pensions to several sinecurists with long but inactive service.",
            "Historically, sinecurists could collect salaries without real duties."
