      "term": "nonutilitarians",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "people who reject utilitarian principles, often opposing actions that maximize overall happiness if they violate other moral considerations",
          "examples": [
            "Nonutilitarians argued that individual rights should not be sacrificed for greater social utility.",
            "The debate featured both utilitarians and nonutilitarians explaining their moral foundations."
          ],
          "collocations": [
            "nonutilitarian stance",
            "nonutilitarian ethics",
            "nonutilitarian critique"
          ],
          "synonyms": ["deontologists", "moralists", "anti-utilitarians"],
          "antonyms": ["utilitarians"],
          "register": "formal",
          "domain": ["general", "philosophy", "ethics"]
        }
      ]
    },
