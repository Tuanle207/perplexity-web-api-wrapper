      "term": "snit",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a sudden fit of petty irritation or bad mood",
          "examples": [
            "He kicked off in a snit when his plan was rejected.",
            "Don’t get into a snit over a small mistake."
          ],
          "collocations": [
            "in a snit",
            "get into a snit",
            "leave someone in a snit"
          ],
          "synonyms": ["huff", "fit", "pique"],
          "antonyms": ["calm", "composure"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
