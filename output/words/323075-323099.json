          "collocations": [
            "former recanters",
            "public recant",
            "recanting behavior",
            "retraction by recanters"
          ],
          "synonyms": ["renegers (informal)", "withdrawers", "retractors"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "history"]
        }
