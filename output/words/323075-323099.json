      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "people who recant or withdraw their previous statements or beliefs",
          "examples": [
            "The recanters publicly renounced their former confessions.",
            "Historically, many recanters faced social backlash."
