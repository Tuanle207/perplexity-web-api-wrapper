      "term": "nonsymmetrical",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "not symmetrical; lacking symmetry or balanced proportions",
          "examples": [
            "The painting has a nonsymmetrical layout with uneven shapes on either side.",
            "The garden design felt nonsymmetrical, which gave it a unique character."
