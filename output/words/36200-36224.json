    {
      "term": "beetleheaded",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having a head that resembles a beetle or is blocked/hidden like a beetle’s head; used humorously to describe someone with a stubborn or unmoving head",
          "examples": [
            "The beetleheaded statue seemed to stare blankly into the distance.",
            "He stood beetleheaded, refusing to change his mind despite the new evidence."
          ],
          "collocations": ["beetleheaded look", "beetleheaded stubbornness", "beetleheaded expression"],
          "synonyms": ["stubborn", "blockheaded", "inflexible"],
          "antonyms": ["flexible", "open-minded"],
          "register": "informal",
          "domain": ["general", "literary"]
        }
      ]
    },
