    {
      "term": "scab",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a rough protective layer that forms on a wound as it heals",
          "examples": ["The cut formed a crusty scab over the wound.", "Avoid pulling off the scab too early to prevent scarring."],
          "collocations": ["blood scab", "dry scab", "scab formation", "heal a scab"],
          "synonyms": ["crust", "scurf"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "medical"]
        },
        {
          "pos": "noun",
          "definition": "a worker who stays loyal to their employer after a strike or those who cross a picket line; a person who reopens a wound or lets it fester by not treating it",
          "examples": ["During the strike, the scab workers crossed the picket line.", "Calling someone a scab can be insulting in labor contexts."],
          "collocations": ["strikebreaker", "scab worker", "call someone a scab"],
          "synonyms": ["strikebreaker", "traitor (informal)"],
          "antonyms": ["union member", "striker"],
          "register": "informal",
          "domain": ["society", "labor", "general"]
        }
      ]
    },
