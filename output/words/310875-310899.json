    {
      "term": "protended",
      "kind": "verb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "past tense of protend: to tilt or bend forward, as if pointing or projecting.",
          "examples": ["The archer protended his body toward the target.", "The forearm protended as the crane lowered the load."],
          "collocations": ["protended slightly", "protended forward", "protended toward"],
          "synonyms": ["tilted", "bent forward", "projected"],
          "antonyms": ["retracted", "straightened", "diverted"],
          "register": "formal",
          "domain": ["general", "physical action"]
        }
      ]
    },
