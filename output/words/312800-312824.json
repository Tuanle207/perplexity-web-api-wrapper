    {
      "term": "pseudorheumatic",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "adjective",
          "definition": "appearing to be rheumatic (relating to joints or muscles) but not truly so; resembling rheumatic symptoms in a superficial way",
          "examples": ["The patient had pseudorheumatic symptoms that disappeared after rest."],
          "collocations": ["pseudorheumatic symptoms", "pseudorheumatic fever", "pseudorheumatic pain"],
          "synonyms": ["pseudo-rheumatic", "veneer rheumatic"],
          "antonyms": ["genuine rheumatic", "true rheumatic"],
          "register": "neutral",
          "domain": ["medical", "general"]
        }
      ]
    },
