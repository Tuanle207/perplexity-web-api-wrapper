      "term": "premillenarianism",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a belief in Christian eschatology that Jesus will return before (premillennial) a literal thousand-year reign on earth.",
          "examples": [
            "Premillenarianism holds that Christ's second coming will inaugurate a literal millennium on earth.",
            "Some theologians argue for premillenarianism as part of end-times interpretation."
          ],
          "collocations": [
            "premillenarianism doctrine",
            "adherents of premillenarianism",
            "premillenarianism view"
          ],
          "synonyms": [
            "premillennialism (alt spelling)"
          ],
          "antonyms": [
            "amillennialism"
          ],
          "register": "formal",
          "domain": ["religion", "theology", "academic"]
        }
      ]
    },
