      "term": "skirts",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "The part of a garment that hangs below the waist and covers the hips and legs, or the outer edge of a surrounding area.",
          "examples": [
            "She bought a new pink skirt for the party.",
            "The skirt of the hill was covered in wildflowers."
          ],
          "collocations": ["short skirt", "skirt hem", "skirt length", "skirt suit", "miniskirt"],
          "synonyms": ["hemline", "garment bottom"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "fashion"]
        },
        {
          "pos": "noun",
          "definition": "The outer edge or margin of something, especially a border or minimizing area.",
          "examples": [
            "The trees lined the skirts of the field.",
            "At the skirts of the forest, the path narrowed."
          ],
          "collocations": ["skirts of the city", "skirts of the hill"],
          "synonyms": ["edge", "border"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["geography", "general"]
        },
        {
          "pos": "verb",
          "definition": "To move or exist around the outer edge, or to go around the outside of something.",
          "examples": [
            "People skirted the lake to avoid the festival crowd.",
            "The debate skirts around the main issue."
