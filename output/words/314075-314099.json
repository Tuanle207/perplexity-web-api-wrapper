      "term": "puggy",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Smelling or tasting of strong tobacco; resembling a pig in a playful way; or used to describe something as cute or silly in a childish way.",
          "examples": [
            "The dog had a puggy face with a wrinkled nose.",
            "That coat is a bit puggy, but I like the color.",
            "He wore a puggy grin after the joke."
          ],
          "collocations": ["puggy grin", "puggy face", "puggy nose"],
          "synonyms": ["cute", "snug", "dumpy" ],
