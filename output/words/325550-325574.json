  "items": [
    {
      "term": "reelects",
      "kind": "verb",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to elect someone again to a political position after they have already been in that position",
          "examples": [
            "The party plans to reelect the incumbent mayor in the upcoming election.",
            "Voters may choose to reelect the current president for another term."
          ],
          "collocations": ["reelect someone", "reelect a mayor", "reelect to office", "reelect for a term"],
          "synonyms": ["reappoint (in some contexts)", "elect again"],
          "antonyms": ["unseat", "oppose", "replace"],
          "register": "formal",
          "domain": ["government", "politics", "general"]
        }
      ]
    },
    {
      "term": "reeled",
      "kind": "verb",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "past tense of reel; to behave in a dizzy or unsteady way as if shocked or stunned; or to wind a reel in fishing or machinery",
          "examples": [
            "The sudden news left him reeling with disbelief.",
            "She reeled the fish in after a long fight."
          ],
          "collocations": ["reeled back", "reeled from the shock", "reeled in the net"],
          "synonyms": ["staggered", "tottered", "unreeled"],
          "antonyms": ["steadied", "balanced"],
          "register": "neutral",
          "domain": ["general", "emotions", "fishing"]
        }
      ]
    },
