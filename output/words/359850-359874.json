    {
      "term": "skeptic",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A person who questions or doubts widely accepted beliefs or claims.",
          "examples": [
            "The scientist remained a skeptic until there was solid evidence.",
            "She is a healthy skeptic about quick-fix solutions."
          ],
          "collocations": ["resident skeptic", "part-time skeptic", "professional skeptic", "skeptical attitude", "skeptic about"],
          "synonyms": ["doubter", "cynic", "detractor"],
          "antonyms": ["believer", "optimist", "advocate"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "adjective",
          "definition": "Having or showing skepticism; inclined to doubt widely accepted claims.",
          "examples": [
            "He gave a skeptical smile at the extraordinary claims.",
            "Her skeptical view prevented hasty conclusions."
          ],
          "collocations": ["skeptical about", "highly skeptical", "skeptical stance"],
          "synonyms": ["doubtful", "suspicious"],
          "antonyms": ["certain", "confident"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
        ]
