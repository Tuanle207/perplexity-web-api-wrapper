      "term": "bribe",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A request or offer to do something dishonest in exchange for something else; an illegal payment.",
          "examples": [
            "The official asked for a bribe to speed up the process.",
            "Bribes are illegal in most countries."
          ],
          "collocations": ["pay a bribe", "bribe money", "bribe amount"],
          "synonyms": ["payoff", "corruption", "kickback"],
          "antonyms": ["honesty", "integrity"],
          "register": "formal",
          "domain": ["law", "general", "ethics"]
        },
        {
          "pos": "verb",
          "definition": "To offer or give something (usually money) to persuade someone to do something dishonest or illegal.",
          "examples": [
            "They bribed the official to get the contract.",
            "No one should bribe a referee."
          ],
          "collocations": ["bribe someone", "bribe a official", "bribe money"],
          "synonyms": ["pay off", "corrupt"],
          "antonyms": ["refuse", "deny"],
          "register": "formal",
          "domain": ["law", "ethics", "business"]
        }
      ]
