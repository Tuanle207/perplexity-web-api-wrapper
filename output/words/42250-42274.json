      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Busy; actively engaged in tasks or activities.",
          "examples": ["I'm feeling a bit bizzy today with back-to-back meetings.", "The shop is bizzy during lunch hours."],
          "collocations": ["bizzy day", "bizzy schedule", "be bizzy doing something", "keep bizzy"],
          "synonyms": ["busy", "occupied", "slammed"],
          "antonyms": ["free", "idle", "unbusy"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
