    {
      "term": "blab",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "To talk too much; to reveal secrets or information that should be kept private.",
          "examples": ["Don't blab about the surprise party."],
          "collocations": ["blab on", "blab to someone", "blab about"],
          "synonyms": ["gab", "chat", "talk"],
          "antonyms": ["keep quiet", "stifle", "keep secret"],
          "register": "informal",
          "domain": ["everyday", "social"]
        },
        {
          "pos": "noun",
          "definition": "A person who talks too much; a loud or annoying talker.",
          "examples": ["He's a real blab at parties."],
          "collocations": ["little blab", "local blab"],
          "synonyms": ["yapper", "blabbermouth"],
          "antonyms": [],
          "register": "informal",
          "domain": ["everyday"]
        }
      ]
    },
    {
