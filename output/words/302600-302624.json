      "term": "preconsciousness",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state of being just before conscious awareness, not yet within conscious thought",
          "examples": [
            "The idea lingered in his preconsciousness, barely touching his awareness.",
            "Therapists often explore what lies in the preconsciousness to understand hidden feelings."
          ],
          "collocations": ["state of preconsciousness", "preconsciousness level", "emerge from preconsciousness"],
          "synonyms": ["subconscious awareness", "preconscious mind"],
          "antonyms": ["consciousness", "awareness"],
          "register": "formal",
          "domain": ["psychology", "general"]
        }
      ]
    },
