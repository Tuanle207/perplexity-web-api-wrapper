      "term": "nonunanimously",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "not in a manner agreed by all; without unanimous agreement",
          "examples": [
            "The committee voted nonunanimously on the budget, with several members dissenting.",
            "The board approved the plan nonunanimously, highlighting divided opinions."
          ],
          "collocations": [
            "vote nonunanimously",
            "decide nonunanimously",
            "approve nonunanimously",
            "consensus not reached nonunanimously"
          ],
          "synonyms": ["partially supported", "not unanimously"],
          "antonyms": ["unanimously"],
          "register": "formal",
          "domain": ["general", "politics", "governance"]
        }
      ]
    },
