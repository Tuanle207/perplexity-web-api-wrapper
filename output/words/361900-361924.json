          "collocations": ["slubberly appearance", "slubberly clothes", "slubberly manner"],
          "synonyms": ["slovenly", "untidy", "messy"],
          "antonyms": ["neat", "tidy", "impeccable"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
