    {
      "term": "reindoctrinating",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of teaching someone to accept a set of beliefs uncritically, often by repeated instruction or persuasion, again or anew",
          "examples": [
            "The campaign focused on reindoctrinating new recruits with the party's ideology.",
            "Schools should avoid reindoctrinating students and encourage critical thinking."
          ],
          "collocations": ["reindoctrinating someone", "reindoctrinating efforts", "reindoctrinating children"],
          "synonyms": ["brainwash (informal)", "indoctrinate anew"],
          "antonyms": ["expose to critical thinking", "deprogram"],
          "register": "formal",
          "domain": ["general", "education", "politics"]
        }
      ]
    },
