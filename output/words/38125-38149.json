      "term": "bereft",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "sad because you have lost something or someone; lacking something you need",
          "examples": [
            "She felt bereft after the sudden death of her husband.",
            "The town is bereft of central services since the factory closure.",
            "He stood bereft of hope as the project failed."
          ],
          "collocations": ["bereft of", "left bereft", "bereft and lonely"],
          "synonyms": ["deprived", "tarred", "devoid of", "bereaved"],
          "antonyms": ["full", "rich", "provided"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
