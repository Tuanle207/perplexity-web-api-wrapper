{
  "items": [
    {
      "term": "qualify",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to make someone or something eligible for something or to meet necessary standards",
          "examples": ["You must pass the exam to qualify for the course.", "Her experience qualifies her for the job."],
          "collocations": ["qualify for", "qualify as", "qualify with", "qualify criteria"],
          "synonyms": ["be eligible", "meet the requirements", "meet the criteria"],
          "antonyms": ["disqualify", "invalidate"],
          "register": "formal",
          "domain": ["general", "education", "employment"]
        },
        {
          "pos": "verb",
          "definition": "to modify or limit a statement or claim so that it becomes less strong or precise",
          "examples": ["The judge qualified his remarks.", "Her statement was qualified by a note of caution."],
          "collocations": ["qualify a statement", "qualify the claim", "qualify with a caveat"],
          "synonyms": ["restrict", "restrictly specify", "temper"],
          "antonyms": ["unqualify", "unrestrict"],
          "register": "formal",
          "domain": ["general", "law"]
        }
      ]
    },
    {
