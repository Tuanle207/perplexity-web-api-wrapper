    {
      "term": "puzzle",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A problem or game that requires careful thinking to solve; something that is hard to understand.",
          "examples": [
            "Solving a jigsaw puzzle is fun.",
            "The riddle was a puzzle to me."
          ],
          "collocations": ["crossword puzzle", "puzzle book", "puzzle game", "logic puzzle"],
          "synonyms": ["conundrum", "enigma", "braid"],
          "antonyms": ["answer", "solution"],
          "register": "neutral",
          "domain": ["general", "education", "leisure"]
        },
        {
          "pos": "verb",
          "definition": "To confuse or perplex someone; to be a mystery to someone.",
          "examples": [
            "The meaning of the poem puzzles me.",
            "This math problem puzzles many students."
          ],
          "collocations": ["puzzle over", "puzzle out", "puzzle someone"],
          "synonyms": ["confuse", "perplex", "baffle"],
          "antonyms": ["clarify", "explain"],
          "register": "neutral",
          "domain": ["general", "education"]
