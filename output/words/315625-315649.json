    {
      "term": "putz",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A worthless or foolish person; a fool. A slang term used humorously or insultingly.",
          "examples": [
            "Don't be a putz, help me with this.",
            "What a putz move to forget the keys again."
          ],
          "collocations": ["big putz", "total putz", "you silly putz"],
          "synonyms": ["fool", "idiot", "nitwit"],
          "antonyms": ["genius", "professor"],
          "register": "informal",
          "domain": ["everyday", "slang"]
        }
      ]
    },
    {
      "term": "putzed",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "Past tense of putz; to waste time or mess around, especially in a clumsy or aimless way.",
          "examples": [
            "We putzed around the house all morning before finally leaving.",
            "He putzed with the car engine instead of fixing it."
          ],
          "collocations": ["putzed around", "putz around with"],
          "synonyms": ["fiddled", "dawdled", "goofed off"],
          "antonyms": ["acted quickly", "efficiently worked"],
          "register": "informal",
          "domain": ["everyday"]
        }
      ]
    },
    {
      "term": "putzes",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "Plural of putz; foolish people or acts; things that are silly or pointless.",
          "examples": [
            "Their ideas are a bunch of putzes.",
            "All those extra gadgets are just putzes."
          ],
          "collocations": ["a bunch of putzes", "petty putzes"],
          "synonyms": ["fools", "nonsense"],
          "antonyms": [],
          "register": "informal",
          "domain": ["everyday"]
        }
      ]
    },
    {
      "term": "putzing",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "Present participle of putz; to waste time or tinker aimlessly.",
          "examples": [
            "We were putzing around the kitchen trying to decide what to cook.",
            "Stop putzing and finish your homework."
          ],
          "collocations": ["putzing around", "putz around with"],
          "synonyms": ["fiddling", "tinkering", "goofing off"],
          "antonyms": ["working", "productive"],
          "register": "informal",
          "domain": ["everyday"]
        }
