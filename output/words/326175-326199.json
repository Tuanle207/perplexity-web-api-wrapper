    {
      "term": "reflex",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "An automatic response to a stimulus; a thing that mirrors or represents something.",
          "examples": [
            "The knee-jerk reflex happens when the doctor taps below the knee.",
            "Her reflex to smile when praised is natural."
          ],
          "collocations": ["reflex action", "reflex arc", "reflex test", "reflex response"],
          "synonyms": ["automatic response", "instinct", "reaction"],
          "antonyms": ["deliberate action", "volition"],
          "register": "neutral",
          "domain": ["general", "science", "medicine"]
        },
        {
          "pos": "adjective",
          "definition": "Describing something directed back or acted in return; reflecting.",
          "examples": [
            "A reflex camera uses manual focus with quick shutter speed.",
            "Her reflex stance indicated readiness."
          ],
          "collocations": ["reflex angle", "reflex camera", "reflex movement"],
          "synonyms": ["mirror-related", "reflective"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "technology"]
        }
