      "term": "sedate",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to administer a drug to make someone quiet or sleepy; to calm or tranquilize",
          "examples": [
            "The doctor will sedate the patient before the procedure.",
            "The pills sedate him enough to sleep through the night."
          ],
          "collocations": ["sedate the patient", "sedate a child", "gentle sedation"],
          "synonyms": ["calm", "tranquilize", "drug"],
          "antonyms": ["agitate", "excite"],
