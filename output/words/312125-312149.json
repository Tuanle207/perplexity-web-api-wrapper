    {
      "term": "pseudo",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "prefix",
          "definition": "a pretend or false form of something; a misleading or deceptive appearance",
          "examples": ["The report is filled with pseudo-science.", "He used a pseudo name to hide his identity."],
          "collocations": ["pseudo-science", "pseudo-", "pseudo-intellectual", "pseudo-scientific", "pseudo-beauty"],
          "synonyms": ["false", "pretend", "pseudo-"],
          "antonyms": ["real", "genuine", "authentic"],
          "register": "neutral",
          "domain": ["general", "language"]
        },
        {
          "pos": "noun",
          "definition": "a person or thing that is not genuine; a sham",
          "examples": ["The antique looked like a genuine painting, but it was a pseudo."],
          "collocations": ["pseudo", "pseudo-artist", "pseudo-scientist"],
          "synonyms": ["sham", "fake", "imitation"],
          "antonyms": ["authentic item", "genuine article"],
          "register": "informal",
          "domain": ["general"]
        }
      ]
    },
