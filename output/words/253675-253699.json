    {
      "term": "nonproliferation",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of preventing the spread of something, especially weapons or ideas",
          "examples": ["The treaty focuses on the nonproliferation of nuclear weapons.", "Efforts toward nonproliferation require international cooperation."],
          "collocations": ["nuclear nonproliferation", "nonproliferation treaty", "strategic nonproliferation", "policy of nonproliferation"],
          "synonyms": ["containment", "prevention of spread"],
          "antonyms": ["proliferation", "spread"],
          "register": "formal",
          "domain": ["general", "policy", "international relations"]
        }
      ]
    },
