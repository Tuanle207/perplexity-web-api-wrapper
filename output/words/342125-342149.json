    {
      "term": "sanctimoniously",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that shows moral superiority or self-righteousness, often hypocritically.",
          "examples": [
            "She spoke sanctimoniously about helping others, while ignoring her own faults.",
            "He lectured sanctimoniously on honesty."
          ],
          "collocations": ["lecture sanctimoniously", "act sanctimoniously", "talk sanctimoniously"],
          "synonyms": ["self-righteously", "holier-than-thou", "piously"],
          "antonyms": ["humorously", "modestly", "sincerely"],
          "register": "informal",
          "domain": ["general", "everyday"]
        }
      ]
    },
