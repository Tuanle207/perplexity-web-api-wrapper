          "collocations": ["nonprosaically elegant", "speak nonprosaically", "write nonprosaically"],
          "synonyms": ["poetically", "lyrically", "in verse"],
          "antonyms": ["prosaically"],
          "register": "formal",
          "domain": ["literary", "general"]
        }
      ]
    },
