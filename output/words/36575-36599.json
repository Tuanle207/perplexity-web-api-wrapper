      "term": "begrudgers",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "people who resent or envy others' success or good fortune",
          "examples": [
            "The begrudgers around him whispered that his promotion was undeserved.",
            "She ignored the begrudgers and continued pursuing her goals."
          ],
          "collocations": [
            "persistent begrudgers",
            "jealous begrudgers",
            "quiet begrudgers",
            "to neutralize the begrudgers"
          ],
          "synonyms": ["envier", "resentful person", "jealous person"],
          "antonyms": ["supporters", "cheerleaders", "advocates"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
