      "term": "bradycardia",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A heart rhythm where the heart beats slower than normal.",
          "examples": [
            "The doctor said he has bradycardia after checking his heart rate.",
            "Athletes may have bradycardia that causes no symptoms.",
            "Bradycardia can be dangerous if it leads to dizziness or fainting."
          ],
          "collocations": [
            "slow heart rate",
            "resting heart rate",
            "abnormal heart rhythm",
            "heart rate below 60",
            "cardiac monitoring",
            "ECG findings"
          ],
          "synonyms": [
            "slow heart rate",
            "slow pulse"
          ],
          "antonyms": [
            "tachycardia"
          ],
          "register": "formal",
