          ],
          "collocations": ["petulant cantankerousnesses", "deep cantankerousnesses", "daily cantankerousnesses"],
          "synonyms": ["irascibility", "peevishness", "grumpiness"],
          "antonyms": ["good humor", "cheerfulness", "amicability"],
          "register": "formal",
          "domain": ["general", "everyday"]
        }
      ]
