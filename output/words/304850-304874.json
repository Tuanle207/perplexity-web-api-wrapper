  "items": [
    {
      "term": "premises",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun (plural of premise)",
          "definition": "The statements or facts that someone uses to support a conclusion, or the basic ideas or assumptions that underlie a theory or argument.",
          "examples": [
            "The premises of the argument are not clearly stated.",
            "From the premises, we can deduce the conclusion."
          ],
          "collocations": ["assumptions and premises", "logical premises", "basis of the premises", "sound premises"],
          "synonyms": ["assumptions", "foundations", "basis"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "general"]
        },
        {
          "pos": "noun (usually plural)",
          "definition": "The land and buildings at a particular place, especially when used for work or business.",
          "examples": [
            "The company owns several premises in downtown Hanoi.",
            "Visitors are not allowed on the premises after hours."
          ],
          "collocations": ["business premises", "on the premises", "lease the premises"],
          "synonyms": ["property", "grounds", "buildings"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["business", "real estate", "general"]
        }
      ]
    },
    {
      "term": "premising",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb (present participle of premise)",
          "definition": "The act of stating or assuming something as a premise or basis for argument or reasoning.",
          "examples": [
            "She is premising that all customers will agree with the plan.",
            "Premising too much can lead to faulty conclusions."
          ],
          "collocations": ["premising the argument", "premising assumptions", "premising that"],
          "synonyms": ["assuming", "stating as a premise"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "logic"]
        }
      ]
    },
