      "term": "abominations",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "things that are extremely unpleasant or morally wrong",
          "examples": ["The report exposed several social abominations.", "He described the crimes as abominations."],
          "collocations": ["moral abominations", "social abominations", "ancient abominations", "consider something an abomination"],
          "synonyms": ["horrors", "atrocities", "disgusts"],
          "antonyms": ["blessings", "virtues"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
