      "term": "runologist",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who studies runes (characters from ancient alphabets) and their meanings or usage",
          "examples": [
            "The museum employed a runologist to interpret the inscriptions on the ancient stone tablet."
          ],
          "collocations": ["archaic runes", "inscriptions", "rune study", "runic alphabet", "interpret ancient texts"],
          "synonyms": ["rune expert", "rune analyst"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "history", "linguistics"]
        }
      ]
    },
