      "term": "nonelectrolyte",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a substance that does not dissociate into ions when dissolved or fused, so it does not conduct electricity well",
          "examples": [
            "Sucrose is a nonelectrolyte in water.",
            "The solution behaved as a nonelectrolyte, showing no electrical conductivity."
          ],
          "collocations": [
            "nonelectrolyte solution",
            "nonelectrolyte compound",
            "dissolve as a nonelectrolyte"
          ],
          "synonyms": [],
          "antonyms": ["electrolyte"],
          "register": "formal",
          "domain": ["science", "chemistry", "general"]
        }
      ]
    },
