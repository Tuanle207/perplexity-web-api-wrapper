      "term": "scotism",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a philosophical-theological system named after the 13th‑century Scottish thinker Duns Scotus",
          "examples": ["Scotism emphasizes the univocity of being and the formal distinction in scholastic theology."],
          "collocations": ["Scotism emerged", "scotism and scholasticism", "Dominican/Franciscan scotism"],
          "synonyms": ["Scotian doctrine (less common)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "philosophy", "theology"]
        }
      ]
    },
