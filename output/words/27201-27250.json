    {
      "term": "attributively",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that places an adjective or noun directly before another noun to describe it",
          "examples": [
            "In the phrase \"a medical student\", the word \"medical\" is used attributively.",
            "Some adjectives can only be used attributively, before a noun, not after a linking verb.",
            "Here the noun \"chicken\" functions attributively in \"chicken soup\"."
          ],
          "collocations": [
            "used attributively",
            "only used attributively",
            "function attributively",
            "noun used attributively",
            "adjective used attributively",
            "appear attributively",
            "occur attributively"
          ],
          "synonyms": [],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "general",
            "academic",
            "grammar"
          ]
        }
      ]
    },
