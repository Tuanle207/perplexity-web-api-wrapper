    {
      "term": "proportionable",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "capable of being proportioned or measured in relation to something else",
          "examples": ["The canvas is proportionable to the frame, allowing a balanced layout.", "We must determine a proportionable amount of flour for the recipe."],
          "collocations": ["proportionable amount", "proportionable size", "proportionable to"],
          "synonyms": ["measurable", "commensurate", " scalable"],
          "antonyms": ["unproportionable", "unmeasurable"],
          "register": "formal",
          "domain": ["general", "mathematics"]
        }
      ]
    },
