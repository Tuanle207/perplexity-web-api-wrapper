          "collocations": ["numero uno", "numero sign", "numero is used in musical scores"],
          "synonyms": ["number", "ordinal", "figure"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "language", "publishing"]
        }
      ]
    },
