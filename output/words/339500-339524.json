  "items": [
    {
      "term": "rumouring",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of sharing or circulating unverified or sensational information about someone; the act of making or spreading rumors",
          "examples": [
            "There was a lot of rumouring about the celebrity's breakup.",
            "Rumouring can harm reputations if not based on facts."
          ],
          "collocations": ["rumour", "rumouring spread", "persistent rumouring", "wild rumouring", "rumouring mill"],
          "synonyms": ["gossip", "tale-telling", "scuttlebutt"],
          "antonyms": ["fact", "verifiable information"],
          "register": "informal",
          "domain": ["everyday", "media"]
        }
      ]
    },
    {
