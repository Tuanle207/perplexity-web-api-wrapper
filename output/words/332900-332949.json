      "term": "reticulitis",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "Inflammation of a reticulum, especially in organs such as the stomach or lymphoid tissue.",
          "examples": [
            "The biopsy confirmed reticulitis in the affected tissue.",
            "Chronic reticulitis can interfere with normal organ function."
          ],
          "collocations": [
            "acute reticulitis",
            "chronic reticulitis",
            "diagnose reticulitis",
            "treat reticulitis",
            "intestinal reticulitis"
          ],
          "synonyms": [
            "reticular inflammation"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine"
          ]
        }
      ]
    },
    {
      "term": "reticulocyte",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "An immature red blood cell that has just left the bone marrow and is not fully developed.",
          "examples": [
            "The doctor ordered a reticulocyte count to assess bone marrow function.",[1][2][3]
            "An increase in reticulocyte levels may indicate blood loss or recovery from anemia."[4][5][6]
          ],
          "collocations": [
            "reticulocyte count",
            "immature reticulocyte",
            "circulating reticulocytes",
            "reticulocyte level",
            "reticulocyte production",
            "absolute reticulocyte count",
            "reticulocyte maturation"
          ],
          "synonyms": [
            "immature erythrocyte",
            "immature red blood cell"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine",
            "academic"
          ]
        }
      ]
    },
    {
      "term": "reticulocytes",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "Plural of reticulocyte: immature red blood cells that are in the final stage before becoming fully mature.",
          "examples": [
            "Reticulocytes normally make up about one to two percent of red blood cells in healthy adults.",[2][5][4]
            "Elevated reticulocytes suggest that the bone marrow is responding to anemia or blood loss."[5][6][7][4]
          ],
          "collocations": [
