      "term": "bombproofs",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of bombproof; structures or protections designed to resist bombs or explosions; also figuratively reliable or extremely sturdy in safeguarding against danger",
          "examples": ["The shelter walls are bombproofed to withstand blasts.", "Their alibi is bombproof, leaving little room for doubt."],
          "collocations": ["bombproof shelter", "bombproof structure", "bombproof design"],
          "synonyms": ["blast-proof structures", "blast-resistant protections"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "architecture", "security"]
        }
      ]
    },
