      "term": "preposterous",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "absurd or completely ridiculous; contrary to common sense or reason",
          "examples": [
            "It would be preposterous to drive without a seatbelt.",
            "The idea that the Earth is flat is preposterous."
          ],
          "collocations": ["preposterous idea", "preposterous claim", "completely preposterous", "utterly preposterous"],
          "synonyms": ["ridiculous", "absurd", "ludicrous", "nonsense"],
          "antonyms": ["reasonable", "sensible", "plausible"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
