  "items": [
    {
      "term": "pray",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to speak to God or a deity, often to ask for help or give thanks",
          "examples": [
            "She goes to the church to pray every Sunday.",
            "We prayed for good weather before the ceremony.",
            "They prayed quietly in the moment of crisis."
          ],
          "collocations": ["pray (to) God", "pray for", "pray aloud", "pray silently", "pray together"],
          "synonyms": ["deem", "supplicate" ],
          "antonyms": ["ignore", "curse"],
          "register": "formal",
          "domain": ["religion", "general"]
        },
        {
          "pos": "verb",
          "definition": "to express hope or wish earnestly about something in a quiet, respectful way",
          "examples": [
            "Please pray for his speedy recovery.",
            "We pray that this decision will bring peace.",
            "People prayed that the storm would pass."
          ],
          "collocations": ["pray that", "pray for", "pray earnestly"],
          "synonyms": ["hope", "wish"],
          "antonyms": ["despair"],
          "register": "formal",
          "domain": ["general", "culture"]
        }
      ]
    },
