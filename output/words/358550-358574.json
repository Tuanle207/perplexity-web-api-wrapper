  "items": [
    {
      "term": "simulacrum",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "an image or representation of someone or something; a copy or imitation that resembles the original closely, often with the sense of being a shallow or superficial likeness",
          "examples": [
            "The statue was a simulacrum of the ancient goddess, crafted with meticulous detail.",
            "Some critics argued that modern reality TV is a simulacrum of real life."
          ],
          "collocations": [
            "perfect simulacrum",
            "fake simulacrum",
            "visual simulacrum",
            "cultural simulacrum"
          ],
          "synonyms": ["image", "likeness", "representation", "apparent copy", "phony copy"],
          "antonyms": ["original", "authenticity"],
          "register": "formal",
          "domain": ["general", "arts", "philosophy"]
        }
      ]
    },
