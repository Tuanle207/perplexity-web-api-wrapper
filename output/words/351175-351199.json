    {
      "term": "semirealistically",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "to do something in a way that resembles but is not fully realistic",
          "examples": ["She described the scene semirealistically, balancing factual detail with imaginative elements."],
          "collocations": ["semirealistically portray", "semirealistically depicted", "semirealistically approach"],
          "synonyms": ["partly realistically", "in a quasi-realistic manner"],
          "antonyms": ["realistically", "unrealistically"],
          "register": "neutral",
          "domain": ["general", "creative-writing"]
        }
        ]
    },
