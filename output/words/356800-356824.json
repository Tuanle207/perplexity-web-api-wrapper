    {
      "term": "shrugs",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "third-person singular simple present form of shrug; to raise both shoulders slightly and momentarily to express indifference, lack of knowledge, or uncertainty",
          "examples": ["She shrugs when asked about the plan, not sure what to do.", "He shrugs his shoulders as if to say he doesn’t know."],
          "collocations": ["shrugged", "shrugging", "shoulders", "indifferently", "slightly"],
          "synonyms": ["grope", "waive", "dismiss with a shrug"],
          "antonyms": ["affirm", "declare", "proclaim"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        }
      ]
    },
