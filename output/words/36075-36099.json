      "term": "beefheaded",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having a head shaped or styled like beef; used figuratively to describe a stubborn, heavy, or thickheaded person in a humorous or derogatory way",
          "examples": [
            "He spoke in a beefheaded manner, refusing to consider new ideas.",
            "That beefheaded decision surprised everyone."
          ],
          "collocations": ["beefheaded attitude", "beefheaded look", "beefheaded stubborn"],
          "synonyms": ["thickheaded", "stubborn", "pigheaded"],
          "antonyms": ["open-minded", "flexible"],
          "register": "informal",
          "domain": ["general", "humor"]
        }
      ]
    },
