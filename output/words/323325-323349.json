      "term": "recessiveness",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being recessive, or less obvious or less dominant in expression or effect",
          "examples": [
            "In genetics, recessiveness refers to a trait that is masked by a dominant allele.",
            "The recessiveness of the symptom means it only appears under certain conditions."
          ],
          "collocations": ["genetic recessiveness", "degree of recessiveness", "trait recessiveness"],
          "synonyms": ["submissiveness", "latent quality"],
          "antonyms": ["dominance", "prominence"],
          "register": "formal",
          "domain": ["science", "biology", "general"]
        }
      ]
    },
