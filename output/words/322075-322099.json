      "term": "realization",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of becoming aware of something or understanding it; the process of making something real or concrete",
          "examples": [
            "Her realization that she was wrong came too late.",
            "The realization of his dream required years of effort."
          ],
          "collocations": ["train of realization", "final realization", "major realization", "personal realization", "face realization"],
          "synonyms": ["awareness", "awaking", "recognition", "comprehension"],
          "antonyms": ["ignorance", "unawareness"],
          "register": "formal",
          "domain": ["general", "education", "psychology"]
        },
        {
