      "term": "serif",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a small stroke or line added to a letter that helps shape its appearance in typography",
          "examples": [
            "The font has rounded serifs.",
            "Choose a serif font for the document title."
          ],
          "collocations": [
            "serif font",
            "serif typeface",
            "serif design",
            "serif style",
            "serif character",
            "serif edge"
          ],
          "synonyms": ["antique stroke", "terminal line"],
          "antonyms": [],
          "register": "formal",
          "domain": ["design", "typography", "graphic_arts", "general"]
        }
      ]
    },
