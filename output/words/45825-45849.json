    {
      "term": "boorishly",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a rude, crude, or ill-mannered way",
          "examples": [
            "He spoke boorishly to the hosts, interrupting every sentence.",
            "She boorishly ignored the courtesy gestures of her colleagues."
          ],
          "collocations": [
            "behave boorishly",
            "talk boorishly",
            "eat boorishly",
            "boorishly dismiss"
          ],
          "synonyms": ["rudely", "coarsely", "uncivilly"],
          "antonyms": ["politely", "courteously", "gently"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
