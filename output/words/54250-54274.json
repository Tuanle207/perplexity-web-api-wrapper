      "term": "calcification",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process by which calcium deposits build up in body tissues or other substances, forming a hard substance",
          "examples": [
            "The X-ray showed calcification of the arteries.",
            "Age-related calcification can occur in the joints.",
            "Calcification of the breast tissue can make screening more challenging."
          ],
          "collocations": ["bone calcification", "arterial calcification", "pathological calcification", "calcium calcification", "extensive calcification"],
          "synonyms": ["hardening by calcium deposits", "ossification (in some contexts)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["medical", "general"]
        }
      ]
    },
