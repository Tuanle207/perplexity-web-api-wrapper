    {
      "term": "canceling",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to decide that something will not happen or that a planned event will not take place",
          "examples": [
            "They decided to cancel the meeting due to bad weather.",
            "The flight was canceled after mechanical issues were found.",
            "She canceled her subscription."
          ],
          "collocations": [
            "cancel a meeting",
            "cancel an order",
            "cancel a subscription",
            "cancel a plan"
          ],
          "synonyms": ["call off", "abort", "withdraw"],
          "antonyms": ["confirm", "proceed", "keep"],
          "register": "neutral",
          "domain": ["general", "business", "travel"]
        }
      ]
    },
