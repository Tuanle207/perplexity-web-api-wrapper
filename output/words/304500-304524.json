  "items": [
    {
      "term": "prejudize",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to form an opinion about someone or something before having enough information, often in a way that causes bias or unfair judgment",
          "examples": [
            "Don't prejudize the candidate before you hear all the facts.",
            "Media coverage can prejudize public perception."
          ],
          "collocations": ["prejudize a judgment", "prejudize public opinion", "prejudize fairness"],
          "synonyms": ["bias", "prejudge", "preconceive"],
          "antonyms": ["evaluate", "assess", "judge fairly"],
          "register": "formal",
          "domain": ["general", "society", "law"]
        }
      ]
    },
    {
      "term": "prejudizes",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "third person singular present of prejudize; forms an opinion unfairly about someone or something",
          "examples": [
            "The article prejudizes readers against the defendant.",
            "Her comments prejudize the outcome of the trial."
          ],
          "collocations": ["prejudizes opinions", "prejudizes jurors"],
          "synonyms": ["biases", "prejudges"],
          "antonyms": ["evaluates", "judges fairly"],
          "register": "formal",
          "domain": ["general", "law", "media"]
        }
      ]
