    {
      "term": "shouldering",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of taking on or assuming a burden, responsibility, or duty",
          "examples": [
            "He is shouldering most of the workload.",
            "They are shouldering the cost of the project."
          ],
          "collocations": ["shouldering responsibility", "shouldering a load", "shouldering burden", "take on shouldering"],
          "synonyms": ["taking on", "bearing", "taking responsibility for"],
          "antonyms": ["avoiding responsibility", "evading duty"],
          "register": "neutral",
          "domain": ["general", "everyday", "business"]
        }
      ]
    },
