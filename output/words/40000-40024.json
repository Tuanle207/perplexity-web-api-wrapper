      "term": "bidonvilles",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a term for overcrowded, informal, makeshift shelters or shantytowns built by refugees or impoverished communities.",
