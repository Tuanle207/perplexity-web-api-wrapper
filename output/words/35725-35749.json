      "term": "bedeafening",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "causing someone to become deaf or to lose the ability to hear, either literally or figuratively",
          "examples": [
            "The constant loud music was almost bedeafening.",
            "Her words were bedeafening to his sense of right and wrong."
          ],
          "collocations": [
            "bedeafening noise",
            "bedeafening silence",
            "bedeafening volume"
          ],
          "synonyms": ["deafening", "deafeningly loud"],
          "antonyms": ["quiet", "soft"],
          "register": "formal",
          "domain": ["everyday", "general"]
        }
      ]
    },
