          "collocations": ["hard-working ruminators", "obsessive ruminators", "persistent ruminators"],
          "synonyms": ["thinkers", "ponderers", "rumblers (less common)"],
          "antonyms": ["deciders", "decisive people"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
