    {
      "term": "recontested",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of having been contested again or challenged anew previous decisions, results, or claims",
          "examples": [
            "The outcome was recontested after new evidence emerged.",
            "The validity of the ruling was recontested by the defense."
          ],
          "collocations": [
            "recontested election",
            "recontested result",
            "recontested claim"
          ],
          "synonyms": ["challenged again", " disputed anew"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "law", "politics"]
        }
      ]
    },
