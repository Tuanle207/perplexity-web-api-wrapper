  "items": [
    {
      "term": "profiteered",
      "kind": "verb",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to have made or taken unfair or excessive gains from a situation, especially in business or during a crisis",
          "examples": [
            "During the shortage, several companies profiteered by raising prices.",
            "Some vendors profiteered off the disaster by selling essential supplies at exorbitant rates."
          ],
          "collocations": ["profiteer", "profiteering", "profiteered prices", "profiteered goods"],
          "synonyms": ["make an ill-gotten gain", "exploit", "gouge"],
          "antonyms": ["sell fairly", "offer at cost"],
          "register": "informal",
          "domain": ["business", "economy", "everyday"]
        }
      ]
    },
    {
