      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "a term used in nautical or Irish-English contexts for a kind of chant or shout used to urge sailors or workers; may also refer to a lively traditional song or call.",
