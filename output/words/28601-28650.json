      "term": "autopsy",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a detailed medical examination of a dead body to find out the cause of death or study disease",
          "examples": [
            "The pathologist performed an autopsy to determine the cause of death.",
            "The autopsy showed that he had died of a heart attack.",
            "Police are still waiting for the autopsy report before closing the case."
          ],
