      "term": "nondurables",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "plural noun",
          "definition": "goods that are not intended to last for a long time or are not durable, often used in trade or economics to describe short-lived consumer products.",
          "examples": [
            "In the study, households spent more on nondurables like food and toiletries.",
            "The company focuses on nondurables rather than long-lasting equipment."
          ],
          "collocations": ["nondurables sector", "nondurables goods", "consumption of nondurables"],
          "synonyms": ["consumables", "short‑life goods"],
          "antonyms": ["durables", "long‑lasting goods"],
          "register": "formal",
          "domain": ["economy", "business", "general"]
        }
      ]
    },
