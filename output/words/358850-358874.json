      "term": "sinistrodextral",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "describing or located on the left side and turning to the right (clockwise) in some contexts, especially in anatomy or morphology",
          "examples": [
            "The sinistrodextral coil of the snail shell follows a left-handed and right-turning pattern.",
            "In some mollusk species, sinistrodextral shells are less common than dextral ones."
          ],
          "collocations": [
            "sinistrodextral orientation",
            "sinistrodextral shell",
            "left-handed sinistrodextral"
          ],
          "synonyms": ["left-handed orientation", "sinistral-right-turning (in specific contexts)"],
          "antonyms": ["dextrozaudal", "dextral"],
          "register": "neutral",
          "domain": ["biology", "anatomy"]
        }
      ]
    },
