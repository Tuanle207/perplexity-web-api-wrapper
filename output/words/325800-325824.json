    {
      "term": "reestimating",
      "kind": "verb",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "to estimate again or again adjust an estimate based on new information",
          "examples": [
            "The analysts are reestimating the market size after receiving the latest data.",
            "We are reestimating the project budget as costs changed."
          ],
          "collocations": ["reestimate", "reestimating the forecast", "reestimate the figures"],
          "synonyms": ["recalculate", "recalculate anew", "reassess"],
          "antonyms": ["estimate", "set", "finalize"],
          "register": "formal",
          "domain": ["business", "economics", "statistics"]
        }
      ]
    },
    {
