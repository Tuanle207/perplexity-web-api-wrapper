      "term": "biodiversities",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of biodiversity: the variety and variability of life in a particular habitat or in the world as a whole",
          "examples": [
            "Conservationists study the biodiversities of rainforests to protect many species.",
            "Different regions have different biodiversities."
          ],
          "collocations": [
            "rich biodiversity",
            "protect biodiversity",
            "biodiversity loss",
            "biodiversity hotspot",
            "genetic biodiversity",
            "ecosystem biodiversity"
          ],
          "synonyms": ["variety of life", "biological diversity"],
          "antonyms": ["monoculture", "homogeneity"],
          "register": "formal",
          "domain": ["general", "environment", "science"]
        }
      ]
    },
