      "term": "nonproductively",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that does not lead to production or results; inefficiently",
          "examples": [
            "The factory operated nonproductively due to faulty machinery.",
            "They spent the morning arguing nonproductively instead of making a decision."
          ],
          "collocations": [
            "work nonproductively",
            "function nonproductively",
            "use resources nonproductively"
          ],
          "synonyms": [
            "inefficiently",
            "unproductively",
            "dawdlingly"
          ],
          "antonyms": [
            "productively",
            "efficiently"
          ],
          "register": "neutral",
          "domain": ["general", "business", "economy"]
        }
