      "term": "beriberi",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a disease caused by a deficiency of vitamin B1 (thiamine), characterized by weakness, nerve damage, and swelling of the limbs",
          "examples": [
            "A diet lacking in thiamine can lead to beriberi.",
            "Historically, beriberi was common among sailors who had limited access to fresh foods."
          ],
          "collocations": ["severe beriberi", "thiamine deficiency", "adult beriberi", "infant beriberi"],
          "synonyms": ["thiamine deficiency disease", "vitamin B1 deficiency disease"],
          "antonyms": [],
          "register": "formal",
          "domain": ["medical", "general"]
        }
      ]
    },
