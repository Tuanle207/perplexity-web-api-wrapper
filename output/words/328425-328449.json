    {
      "term": "reliquidates",
      "kind": "verb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to convert something back into liquid form again, or to restore it to liquidity after being in a liquid state or after a phase where it was not liquid.",
          "examples": [
            "The company reliquidates its assets to cash.",
            "Investors worry that the asset will be reliquidated if market conditions improve."
          ],
          "collocations": [
            "reliquidates assets",
            "reliquidates funds",
            "reliquidates holdings",
            "reliquidates a position"
          ],
          "synonyms": ["liquefies again", "liquefies anew"],
          "antonyms": [],
          "register": "formal",
          "domain": ["business", "finance", "general"]
        }
      ]
    },
    {
      "term": "reliquidating",
      "kind": "verb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of converting something back into liquid form again, or restoring liquidity during ongoing action.",
          "examples": [
            "The fund is reliquidating its portfolio as part of the restructuring.",
            "They are reliquidating previously illiquid assets to raise cash."
          ],
          "collocations": [
            "reliquidating assets",
            "reliquidating funds",
            "reliquidating positions"
          ],
          "synonyms": ["liquefying again", "restoring liquidity"],
