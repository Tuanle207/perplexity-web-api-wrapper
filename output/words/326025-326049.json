  "items": [
    {
      "term": "refertilization",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of making something fertile again, especially soil or land that has become depleted",
          "examples": [
            "The farmer planned a period of refertilization to restore soil nutrients.",
            "Refertilization is often used after crop rotation to improve yield."
          ],
          "collocations": ["soil refertilization", "refertilization process", "fertility restoration", "nutrient replenishment"],
          "synonyms": ["re-fertilization", "fertility restoration"],
          "antonyms": ["defertilization", "soil depletion"],
          "register": "formal",
          "domain": ["agriculture", "environment"]
        }
      ]
    },
    {
      "term": "refertilize",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to restore fertility to soil or land by adding nutrients or fertilizer",
          "examples": [
            "Farmers refertilize the field after a poor harvest.",
            "They plan to refertilize the soil using compost this season."
          ],
          "collocations": ["refertilize the soil", "refertilize crops", "refertilize with fertilizer", "refertilize gradually"],
          "synonyms": ["re-fertilize", "fertilize again"],
          "antonyms": [],
          "register": "formal",
          "domain": ["agriculture", "environment"]
        }
      ]
    },
    {
      "term": "refertilized",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "verb",
          "definition": "past tense of refertilize; having been made fertile again by adding nutrients or fertilizer",
          "examples": [
            "The soil was refertilized after the cover crop was harvested.",
            "They refertilized the field last month and expect better yields."
          ],
          "collocations": ["refertilized soil", "refertilized field", "refertilized using compost"],
          "synonyms": ["re-fertilized", "fertilized again"],
          "antonyms": [],
          "register": "formal",
          "domain": ["agriculture", "environment"]
        }
      ]
    },
    {
