          "collocations": ["effective normanizer", "industry normanizer", "statistical normanizer"],
          "synonyms": ["standardizer", "normalizer"],
          "antonyms": ["deviator", "anomalist"],
          "register": "formal",
          "domain": ["general", "business"]
        }
