      "term": "sonorously",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a loud, deep, and resonant manner; with a full, rich sound",
          "examples": [
            "The musician spoke sonorously, filling the hall with his voice.",
            "She read the passage sonorously, as if addressing a large audience."
          ],
          "collocations": ["speak sonorously", "sound sonorously", "read sonorously", "sonorously booming"],
          "synonyms": ["clearly", "resonantly", "deeply"],
          "antonyms": ["quietly", "mutedly", "softly"],
          "register": "formal",
          "domain": ["general", "performing arts"]
        }
      ]
    },
