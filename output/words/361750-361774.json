      "term": "sloppiness",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of not being careful or tidy; carelessness",
          "examples": [
            "The sloppiness of his notes made it hard to study from them.",
            "Her sloppiness in labeling the jars caused a mix-up in the kitchen."
          ],
