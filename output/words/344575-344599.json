      "term": "scantly",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "To a very small degree; scarcely; barely.",
          "examples": [
            "The town was scantly supplied with fresh water.",
            "He ate scantly, hardly finishing his plate."
          ],
          "collocations": [
            "scantly clad",
            "scantly populated",
            "scantly available"
          ],
          "synonyms": ["barely", "barely enough", "hardly"],
          "antonyms": ["plentifully", "ample", "abundantly"],
          "register": "formal",
          "domain": ["general", "society"]
        }
      ]
    },
