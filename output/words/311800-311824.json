      "term": "prozoning",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "the act or policy of zoning land for developmental or regulatory purposes, often restricting uses to certain types of buildings or activities",
