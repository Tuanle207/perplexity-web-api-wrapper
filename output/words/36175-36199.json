      "term": "beeswax",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a wax produced by honeybees used to build honeycomb and seal honey cells",
          "examples": ["Beeswax is melted and molded into candles.", "The craft project used beeswax to coat the surface."],
          "collocations": ["beeswax candle", "beeswax wrap", "beeswax foundation", "beeswax production"],
          "synonyms": ["cera alba", "wax from bees"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "slang meaning someone’s personal business or secrets (informal, humorous extension from ‘beeswax’ as a play on ‘the bees’wax’ meaning ‘the wax of the bees’ work’, used as a playful injunction to mind one’s own affairs)",
          "examples": ["Mind your own beeswax and stop asking questions.", "That drama is none of my beeswax."],
          "collocations": ["mind your beeswax", "that’s your beeswax"],
          "synonyms": ["private matters", "business", "personal affairs"],
          "antonyms": [],
          "register": "informal",
          "domain": ["everyday", "informal"]
