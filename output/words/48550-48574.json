      "term": "breech",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the part of a firearm where the bullet exits the barrel; the rear part of the gun where the cartridge sits",
          "examples": [
            "He aimed down the breech to load the rifle.",
            "The breechblock rotates to seal the chamber."
          ],
          "collocations": ["breech block", "breech loading", "breech mechanism", "breech velocity"],
          "synonyms": ["chamber end", "rear of barrel"],
          "antonyms": [],
          "register": "null",
          "domain": ["technology", "general"]
        },
        {
          "pos": "noun",
          "definition": "the part of a firearm or cannon behind the muzzle; the hind part of the barrel",
