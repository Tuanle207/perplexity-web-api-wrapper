          "collocations": ["deep numinousness", "a sense of numinousness", "rare numinousness"],
          "synonyms": ["mystical awe", "spiritual grandeur", "sacred aura"],
          "antonyms": ["prosaicness", "mundanity"],
          "register": "formal",
          "domain": ["general", "religion", "aesthetic"]
        }
      ]
    },
