  "items": [
    {
      "term": "smells",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the sense of a person or thing that is detectable by the nose; a smell",
          "examples": [
            "The smells from the bakery made her hungry.",
            "There are many pleasant smells in the garden after rain."
          ],
          "collocations": ["strong smell", "faint smell", "smell of", "smell nice", "smell awful"],
          "synonyms": ["odor", "aroma", "scent"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "verb",
          "definition": "to emit an odor or to perceive an odor with the nose",
          "examples": [
            "The kitchen smells of garlic.",
            "Her clothes smelled after the rain."
          ],
          "collocations": ["smell of", "smell like", "smell good", "smell bad"],
          "synonyms": ["emit an odor", "reek of", "odor"],
          "antonyms": ["smellless (rare)", ""],
          "register": "neutral",
          "domain": ["everyday", "general"]
        }
      ]
    },
