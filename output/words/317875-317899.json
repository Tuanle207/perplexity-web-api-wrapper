      "term": "questioning",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of asking questions to obtain information or to challenge something",
          "examples": ["The police began questioning the suspect.", "There was a lot of questioning of the method used."],
          "collocations": ["intense questioning", "police questioning", "legal questioning"],
          "synonyms": ["interrogation", "inquiry", "interviewing"],
          "antonyms": ["assurance", "silence"],
          "register": "formal",
          "domain": ["general", "law", "investigation"]
        },
        {
          "pos": "adjective",
          "definition": "relating to the act of asking questions or to questions in general",
          "examples": ["There were questioning looks from the audience.", "The data came from questioning responses."],
          "collocations": ["questioning attitude", "questioning gaze", "questioning process"],
          "synonyms": ["inquisitive", "probing"],
          "antonyms": ["definitive", "certain"],
          "register": "neutral",
          "domain": ["general", "education", "psychology"]
