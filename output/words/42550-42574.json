      "term": "blah",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a word used to express tiredness, boredom, or a lack of enthusiasm, often used as a filler sound without specific meaning",
          "examples": ["She yawned and said, 'blah, blah, blah.'", "All that talk about reform sounded like blah to him."],
          "collocations": ["blah blah", "blah blah blah", "utter blah"],
          "synonyms": ["boredom", "drivel", "nonsense"],
          "antonyms": ["meaningful talk", "substance"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
