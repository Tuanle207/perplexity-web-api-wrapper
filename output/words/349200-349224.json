      "term": "seedbox",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a high-bandwidth remote server used to upload and download files, typically for peer-to-peer sharing",
          "examples": [
            "The seedbox lets me seed torrents without exposing my home IP.",
            "Many users rent a seedbox for fast, private file transfers."
          ],
          "collocations": [
            "seedbox provider",
            "seedbox hosting",
            "seedbox account",
            "seedbox server",
            "seedbox service"
          ],
          "synonyms": ["torrent server", "private server"],
          "antonyms": [],
          "register": "informal",
          "domain": ["technology", "internet", "general"]
        }
      ]
    },
