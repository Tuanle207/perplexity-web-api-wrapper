      "term": "shloshim",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a Jewish term for the 30-day mourning period observed after a close relative dies",
          "examples": ["During the shloshim, mourners may recite special prayers.", "The family observed shloshim with daily visits and fasting practices."],
          "collocations": ["shloshim period", "mark the shloshim", "shloshim prayers"],
          "synonyms": ["mourning period", "forty days (in some traditions)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["religion", "culture", "general"]
        }
      ]
    },
    {
