      "term": "sarrusophones",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of sarrusophone, a family of deep, woodwind instruments with a brass body and a screw-in reed mouthpiece, used in orchestras and bands to imitate bassoons and saxophones",
          "examples": [
            "The ensemble added two bass sarrusophones for a richer low C.",
            "Early 20th-century orchestral scores sometimes specify sarrusophones for a jazzy bottom end."
          ],
          "collocations": [
            "bass sarrusophone",
            "sarrusophone family",
            "orchestral score",
            "reed mouthpiece",
            "low register"
          ],
          "synonyms": ["satzhorn (obsolete)","bass oboe (approximate)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["music", "art", "general"]
        }
      ]
    },
