      "term": "blanch",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to whiten or turn pale by removing color; to scald quickly in hot water to loosen skin",
          "examples": ["Blanch the almonds before peeling them.", "Her face blanched at the news."],
          "collocations": ["blanch almonds", "blanch vegetables", "blanching skin"],
          "synonyms": ["whiten", "bleach", "pale"],
          "antonyms": ["tan", "color", "darken"],
          "register": "neutral",
          "domain": ["cookery", "general"]
        },
        {
          "pos": "verb",
          "definition": "to briefly immerse in boiling water and then in cold water as a preparatory cooking step",
          "examples": ["Blanch the spinach for 30 seconds."],
          "collocations": ["blanch vegetables", "brief blanching"],
          "synonyms": ["parboil"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["food", "cooking"]
        }
      ]
    },
