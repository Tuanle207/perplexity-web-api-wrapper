    {
      "term": "sack",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a bag made of cloth, leather, or strong paper used for carrying or storing things",
          "examples": ["She carried a sack of flour from the market.", "The farmer weighed the grain in a burlap sack."],
          "collocations": ["sack of potatoes", "paper sack", "cloth sack", "sack full", "empty sack"],
          "synonyms": ["bag", "tote", "pouch"],
          "antonyms": ["box", "crate"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "verb",
          "definition": "to dismiss someone from employment; to remove from a position",
          "examples": ["The company decided to sack several employees.", "After the scandal, he was sacked from his job."],
          "collocations": ["sack employees", "sack someone", "be sacked"],
          "synonyms": ["fire", "dismiss", "terminate"],
          "antonyms": [],
          "register": "formal",
          "domain": ["business", "employment"]
        },
        {
          "pos": "verb",
          "definition": "to plunder or loot, especially to loot a place during a conflict",
          "examples": ["The invaders sacked the city, taking valuables and destroying buildings."],
          "collocations": ["sack a city", "sack and burn"],
          "synonyms": ["plunder", "loot", "raid"],
          "antonyms": [],
          "register": "literary",
          "domain": ["history", "general"]
        }
