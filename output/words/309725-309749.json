    {
      "term": "proofread",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to read and correct a written text in order to improve its grammar, punctuation, and spelling",
          "examples": [
            "I need to proofread my essay before submitting it.",
            "She proofreads all the reports for accuracy.",
            "Before printing, please proofread the draft for any errors."
          ],
          "collocations": ["proofread the manuscript", "carefully proofread", "proofread for mistakes", "proofread and edit"],
          "synonyms": ["edit", "polish", "revise"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "education", "writing"]
        }
      ]
    },
