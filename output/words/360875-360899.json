    {
      "term": "slash",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a mark or a line used to separate, divide, or indicate alternatives",
          "examples": [
            "Draw a slash between the two options.",
            "There is a slash in the date 12/05.",
            "The word is written with a slash to show division."
          ],
          "collocations": ["a slash", "forward slash", "slash mark", "slash symbol", "slash separator"],
          "synonyms": ["stroke", "virgule"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "typography"]
        },
        {
          "pos": "verb",
          "definition": "to cut with a sharp blade or to remove by cutting; to strike or stab with a blade",
          "examples": [
            "He will slash the price in half.",
            "The fabric was slashed to create a new design.",
            "The brakes slash the speed aggressively."
          ],
          "collocations": ["slash prices", "slash tires", "slash profits", "slash costs"],
          "synonyms": ["cut", "halve", "reduce"],
          "antonyms": ["increase", "raise"],
          "register": "neutral",
          "domain": ["general", "business", "technology"]
        },
        {
          "pos": "verb",
          "definition": "to make a long, deep cut or incision",
          "examples": [
            "The surgeon will slash the skin to reach the tissue.",
            "Wind slashes the flag against the pole."
          ],
          "collocations": ["slash open", "slash through", "slash across"],
          "synonyms": ["cut", "hew"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "medicine"]
        }
      ]
    },
