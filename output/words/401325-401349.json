    {
      "term": "toadies",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of toady; people who behave obsequiously toward someone important in order to gain advantage",
          "examples": ["The royal palace was filled with tired toadies catering to every whim of the king."],
          "collocations": ["court toadies", "sycophantic toadies", "political toadies", "group of toadies"],
          "synonyms": ["sycophants", "yes-men", "bootlickers", "flatterers"],
          "antonyms": ["independents", "dissenters", "critics"],
          "register": "informal",
          "domain": ["general", "society"]
        }
      ]
    },
