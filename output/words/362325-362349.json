      "term": "smectite",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a soft clay mineral that swells when wet and is used as a binder or filler in ceramics and drilling muds",
          "examples": ["The drill mud contained a high percentage of smectite.", "In pottery, smectite contributes to plasticity in the clay."],
          "collocations": ["smectite clay", "smectite mineral", "montmorillonite-smectite", "bentonite-smectite"],
          "synonyms": ["clay mineral", "montmorillonite (a specific type)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "geology", "mineralogy"]
        }
      ]
    },
