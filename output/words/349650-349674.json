  "items": [
    {
      "term": "selectively",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "In a way that shows choosing particular things or people rather than everything.",
          "examples": [
            "The program collects data selectively to protect privacy.",
            "She spoke selectively about the incident, avoiding details.",
            "Markets were selectively opened to smaller firms."
          ],
          "collocations": ["operate selectively", "choose selectively", "selectively applied"],
          "synonyms": ["partially", "discriminately", "biasedly"],
          "antonyms": ["uniformly", "randomly", "blindly"],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
    {
      "term": "selectiveness",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "The quality of being careful about what is chosen and what is ignored.",
          "examples": [
            "Her selectiveness in voting reflected careful consideration.",
            "There is a growing debate about the selectiveness of university admissions."
          ],
          "collocations": ["high selectiveness", "selectiveness in", "demonstrate selectiveness"],
          "synonyms": ["choosiness", "particularity", "discrimination"],
          "antonyms": ["leniency", "negligence", "indifference"],
          "register": "formal",
          "domain": ["general", "education", "society"]
        }
      ]
    },
