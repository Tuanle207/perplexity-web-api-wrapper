    {
      "term": "postromantic",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "relating to a movement or period following romanticism, often describing art, literature, or music that comes after Romanticism and preserves its emotional intensity while adopting new ideas.",
          "examples": [
            "The postromantic style continued the emotional expressiveness of Romanticism with newer formal experiments."
          ],
          "collocations": [
            "postromantic era",
            "postromantic music",
            "postromantic aesthetics"
          ],
          "synonyms": ["after-Romantic", "late Romantic-influenced"],
          "antonyms": [],
          "register": "formal",
          "domain": ["art", "literature", "music"]
        }
      ]
    },
