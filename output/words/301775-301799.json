    {
      "term": "prearranged",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "arranged or planned beforehand",
          "examples": ["The schedule was prearranged to avoid any conflicts.", "They entered into a prearranged agreement."],
          "collocations": ["prearranged plan", "prearranged meeting", "prearranged itinerary"],
          "synonyms": ["preplanned", "predetermined", "arranged in advance"],
          "antonyms": ["unarranged", "unplanned", "spontaneous"],
          "register": "formal",
          "domain": ["general", "planning", "business"]
        }
      ]
    },
    {
