    {
      "term": "sibyllic",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "adjective",
          "definition": "relating to or resembling a prophecy or oracular utterance; oracular in tone",
          "examples": [
            "The sibyllic utterances of the ancient oracle were reserved for the king.",
            "Her sibyllic predictions were cryptic and unsettling."
          ],
          "collocations": [
            "sibyllic voice",
            "sibyllic tone",
            "sibyllic utterance"
          ],
          "synonyms": ["prophetic", "oracular", "apocalyptic"],
          "antonyms": ["prosaic", "concrete", "factual"],
          "register": "formal",
          "domain": ["literary", "general"]
        }
      ]
    },
