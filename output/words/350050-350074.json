            "semiautomated process",
            "semiautomated workflow",
            "semiautomated solution"
          ],
          "synonyms": ["partially automated", "partly automated"],
          "antonyms": ["fully automated", "fully manual"],
          "register": "formal",
          "domain": ["general", "technology", "industry"]
        }
      ]
