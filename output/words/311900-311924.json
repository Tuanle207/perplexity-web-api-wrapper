      "term": "prussian",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person from Prussia, a historic region in central Europe; or historically, a German soldier or official associated with Prussia",
          "examples": [
            "The museum exhibit explains the culture of the Prussians.",
            "He studied the role of the Prussians in 18th-century Europe."
          ],
          "collocations": ["Prussian army", "Prussian king", "Prussian culture", "Prussian history"],
          "synonyms": ["German", "Prussic (archaic, less common)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "history", "education"]
        }
      ]
    },
