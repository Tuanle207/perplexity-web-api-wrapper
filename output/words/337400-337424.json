    {
      "term": "romanization",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process or result of converting text from a different writing system into Roman letters",
          "examples": [
            "The romanization of Chinese characters helps learners read aloud.",
            "Two systems of romanization are used for Japanese: Hepburn and Kunrei-shiki."
          ],
          "collocations": [
            "romanization system",
            "transliteration and romanization",
            "phonetic romanization"
          ],
          "synonyms": ["transliteration to Latin script"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "education", "linguistics"]
        }
      ]
    },
