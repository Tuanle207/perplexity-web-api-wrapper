      "term": "solmizate",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to teach or practice solmization, i.e., to assign syllables to notes of a scale for sight-singing.",
          "examples": [
            "The teacher solmizates the students to help them sing the scale.",
            "Musicians solmizate to improve vocal accuracy in early music training."
          ],
          "collocations": ["solmize a scale", "solmizate pitches", "teach solmization"],
          "synonyms": ["solmize", "tone-solve (nonstandard)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["music", "education", "general"]
        }
      ]
    },
    {
      "term": "solmization",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process or system of assigning syllables to musical notes to aid singing.",
          "examples": [
            "Solmization helps beginners learn melodies by using syllables like do, re, mi.",
            "They studied solmization as part of the music theory course."
