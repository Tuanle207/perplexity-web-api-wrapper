    {
      "term": "prophetisms",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "plural noun",
          "definition": "A collection of words or expressions that resemble or relate to 'prophet' in form or usage, often used jokingly or critically to refer to proclaimed predictions or prophetic language.",
          "examples": [
            "His talk was full of prophetisms about the coming era of peace.",
            "Academic critics dismissed the speech as mere prophetisms rather than solid analysis."
          ],
          "collocations": [
            "prophetisms and predictions",
            "religious prophetisms",
            "prophetisms in discourse"
          ],
          "synonyms": ["prophetic claims", "prophetical language", "prophetic rhetoric"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "linguistics", "literary"]
        }
      ]
    },
    {
