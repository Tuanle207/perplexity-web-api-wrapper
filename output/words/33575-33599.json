      "term": "barrenness",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state of being unable to produce plants or crops",
          "examples": ["The barrenness of the desert made farming impossible.", "Soil barrenness can result from overuse of chemicals.", "The barrenness of the land worried the farmers."],
          "collocations": ["soil barrenness", "desert barrenness", "land barrenness", "infertile barrenness", "permanent barrenness"],
          "synonyms": ["sterility", "infertility", "aridity"],
          "antonyms": ["fertility", "productivity"],
          "register": null,
          "domain": ["general", "agriculture"]
        },
        {
          "pos": "noun",
          "definition": "inability to have children",
