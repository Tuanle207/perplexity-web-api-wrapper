      "term": "psalmodize",
      "kind": "verb",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to set or arrange to music the text of a psalm for singing in a worship service",
          "examples": [
            "The choir decided to psalmodize the ancient verses for the evening service.",
            "They psalmodize psalms in a traditional Anglican chant.",
            "The composer chose to psalmodize several psalms for the concert."
          ],
          "collocations": [
            "psalmodize psalms",
            "psalmodize a hymn",
            "psalmodize choral pieces",
            "psalmodize liturgical texts"
          ],
          "synonyms": ["chant", "intonate", "chantify (archaic)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["music", "religion", "worship", "general"]
        }
      ]
    },
