  "items": [
    {
      "term": "ruthlessly",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a cruel and merciless way, with no pity or remorse",
          "examples": [
            "The rival company competed ruthlessly to win the contract.",
            "She chased success ruthlessly, discarding anything that slowed her down."
          ],
          "collocations": ["ruthlessly efficient", "ruthlessly ambitious", "ruthlessly eliminate"],
          "synonyms": ["mercilessly", "cruelly", "pitilessly"],
          "antonyms": ["kindly", "compassionately"],
          "register": "formal",
          "domain": ["business", "general"]
        }
      ]
    },
    {
      "term": "ruthlessness",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of showing no pity or mercy in pursuing one's goals",
          "examples": [
            "His ruthlessness in negotiations surprised his opponents.",
            "The ruthlessness of the regime drew international condemnation."
          ],
          "collocations": ["extreme ruthlessness", "ruthlessness in pursuit", "display of ruthlessness"],
          "synonyms": ["mercilessness", "cruelty", "sternness"],
          "antonyms": ["compassion", "mercy"],
          "register": "formal",
          "domain": ["business", "politics", "general"]
