      "term": "nonsystematic",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "not following or organized by a system; lacking a planned structure or method",
          "examples": [
            "The results were nonsystematic and hard to compare.",
            "Her approach was nonsystematic, making the process unpredictable."
          ],
          "collocations": ["nonsystematic approach", "nonsystematic method", "nonsystematic data"],
          "synonyms": ["unsystematic", "haphazard", "disorganized"],
          "antonyms": ["systematic", "methodical", "organized"],
          "register": "neutral",
          "domain": ["general", "education"]
        }
