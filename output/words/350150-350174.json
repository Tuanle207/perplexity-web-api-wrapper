          "collocations": ["semichannel output", "semichannel path", "semichannel wiring"],
          "synonyms": ["subchannel", "secondary channel"],
          "antonyms": ["main channel", "primary channel"],
          "register": "neutral",
          "domain": ["technology"]
        }
      ]
    },
