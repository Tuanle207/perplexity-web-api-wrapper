      "term": "shillalas",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural form of shillala, a Scots or Irish term for a young or rustic girl; also used regionally to refer to a girl or woman in a playful or affectionate way",
          "examples": [
            "The old tales mention a shillala helping in the market.",
            "In some dialect poems, a shillala appears as a cheerful village girl."
          ],
          "collocations": [
            "local shillalas",
            "shillalas of the valley",
            "young shillalas"
          ],
          "synonyms": ["lass", "girl", "lassie"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "literary"]
        }
      ]
    },
    {
