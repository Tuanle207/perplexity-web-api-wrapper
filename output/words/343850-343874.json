      "term": "savant",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who is very knowledgeable or skilled in a particular area, often with expertise that seems exceptional.",
          "examples": [
            "He is a chess savant, able to predict several moves ahead.",
            "The music savant could play complex pieces after hearing them once."
          ],
          "collocations": ["child prodigy", "math savant", "language savant", "medical savant", "recall savant"],
          "synonyms": ["expert", "genius", "maestro"],
          "antonyms": ["novice", "amateur"],
          "register": "neutral",
          "domain": ["general", "education", "arts", "science"]
        }
