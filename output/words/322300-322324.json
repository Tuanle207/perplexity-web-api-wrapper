      "term": "rear",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the back part of something, or the part that is opposite to the front",
          "examples": [
            "The luggage went on the rear of the train car.",
            "She sat in the rear seat of the taxi.",
            "The photo shows the car’s rear bumper."
          ],
          "collocations": ["rear of the house", "rear wheel", "rear door", "rear view", "rear end"],
          "synonyms": ["back", "behind", "aft"],
          "antonyms": ["front"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
