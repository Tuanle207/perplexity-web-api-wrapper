      "term": "somnambulistic",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "relating to or characteristic of sleepwalking; occurring while one is sleepwalking or in a dreamlike state",
          "examples": [
            "The somnambulistic habit of wandering the house at night worried the family.",
            "She described his somnambulistic behavior as if he were moving through a dream."
          ],
          "collocations": ["somnambulistic behavior", "somnambulistic state", "somnambulistic movements"],
          "synonyms": ["sleepwalking-related", "hypnagogic (adj)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "medical"]
        }
      ]
    },
