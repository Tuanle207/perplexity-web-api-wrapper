          "synonyms": ["jolt", "stun", "surprise"],
          "antonyms": ["calm", "comfort", "ease"],
          "register": "neutral",
          "domain": ["general", "emotions", "society"]
        },
        {
          "pos": "verb",
          "definition": "to cause someone to feel sudden surprise or distress",
          "examples": [
            "The loud crash shocked her into silence.",
            "The news shocked the family."
          ],
          "collocations": [
            "shock someone",
