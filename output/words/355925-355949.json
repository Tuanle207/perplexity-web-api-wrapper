    {
      "term": "shockproof",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "able to resist or avoid damage from a sudden shock or impact",
          "examples": [
            "The bank card is shockproof, so it won’t crack if dropped.",
            "They tested the shockproof casing to protect the camera in rough conditions."
          ],
          "collocations": [
            "shockproof case",
            "shockproof design",
            "shockproof material",
            "shockproof coating"
          ],
          "synonyms": ["unbreakable", "impact-resistant", "durable"],
          "antonyms": ["fragile", "breakable"],
          "register": "neutral",
          "domain": ["general", "technology", "everyday"]
        }
      ]
    },
    {
      "term": "shocks",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "sudden strong feelings of surprise, fear, or pain",
          "examples": [
            "The news came as a shock to everyone.",
            "She stood in shock after hearing the verdict."
          ],
          "collocations": [
            "a shock to",
            "in shock",
            "electric shocks",
            "moral shock"
