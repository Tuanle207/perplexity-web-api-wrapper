  "items": [
    {
      "term": "somatotyping",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the classification of humans into body-type categories (somatotypes) based on physical build and physique, historically used in anthropology and medicine",
          "examples": [
            "Early researchers attempted somatotyping to link body types with temperament.",
            "Somatotyping has been criticized for its simplistic approach to human diversity."
          ],
          "collocations": [
            "ectomorph somatotyping",
            "body-type somatotyping",
            "historical somatotyping",
            "somatotyping method"
          ],
          "synonyms": ["body typing", "somatype classification"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "science", "general"]
        }
      ]
    },
    {
      "term": "somatotypology",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the study or science of somatotyping; the systematic classification of body types",
          "examples": [
            "Somatotypology attempts to map physical forms to physiological or psychological traits.",
            "In modern research, somatotypology is largely superseded by more nuanced methods."
          ],
          "collocations": [
            "psychology somatotypology",
            "anthropology somatotypology",
            "somatotypology theory"
          ],
          "synonyms": ["somatotype theory", "body-type classification science"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "science", "medicine"]
        }
      ]
    },
    {
      "term": "somatotypy",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the practice or result of somatotyping; the arrangement of body types into categories",
          "examples": [
            "The somatotypy of the population was used in the study to correlate physique with certain functional abilities.",
            "Critics argued that somatotypy oversimplified complex human variation."
          ],
          "collocations": [
            "somatotypy classification",
            "somatotypy approach",
            "biological somatotypy"
          ],
          "synonyms": ["somatotyping", "body-type categorization"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "science", "medicine"]
        }
      ]
    },
