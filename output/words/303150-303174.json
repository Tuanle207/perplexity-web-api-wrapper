      "term": "predictability",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being likely to happen or be true; the ability to be foreseen or anticipated",
          "examples": [
            "The predictability of the weather forecast made planning easy.",
            "Her predictability in responding to emails helped the team manage expectations."
          ],
          "collocations": ["high/low predictability", "increased predictability", "predictability of", "predictability of outcomes"],
          "synonyms": ["stability", "reliability", "consistency"],
          "antonyms": ["unpredictability"],
          "register": "formal",
          "domain": ["general", "daily life", "science"]
        }
      ]
    },
