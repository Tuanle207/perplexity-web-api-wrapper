    {
      "term": "biting",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Causing a sharp, stinging, or painful sensation; can describe cold weather or keen wit.",
          "examples": [
            "The biting wind made my cheeks numb.",
            "Her biting critique cut to the heart of the issue."
          ],
          "collocations": ["biting cold", "biting wind", "biting sarcasm", "biting wit"],
          "synonyms": ["sharp", "piercing", "acrimonious"],
          "antonyms": ["gentle", "mild", "soft"],
          "register": "neutral",
          "domain": ["general", "weather", "literary"]
        },
        {
          "pos": "noun",
          "definition": "A small piece or fragment that has been bitten off, or the act of chewing with the teeth.",
          "examples": [
            "She took a bite of the apple.",
            "The dog gave a quick bite."
          ],
          "collocations": ["first bite", "bite size", "jaw bite", "biting together"],
          "synonyms": ["chew", "nibble", "morsel"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "food"]
        },
        {
          "pos": "verb",
          "definition": "To use the teeth to cut or grip something; to chew.",
          "examples": [
            "The dog began biting at the sleeve.",
            "Be careful not to bite your tongue."
          ],
          "collocations": ["biting at", "bite back", "bite into", "bite down"],
          "synonyms": ["chew", "gnaw", "nibble"],
          "antonyms": ["let go", "release"],
          "register": "neutral",
          "domain": ["general", "animals", "food"]
        }
      ]
    },
    {
