      "term": "reexecuting",
      "kind": "verb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to execute again or perform again after an initial execution",
          "examples": [
            "The court ordered reexecuting the plan to ensure it met new standards.",
            "They considered reexecuting the failed experiment to verify the results."
          ],
          "collocations": ["reexecuting a plan", "reexecuting a task", "reexecuting the procedure"],
          "synonyms": ["redoing", "retrying", "rerunning"],
          "antonyms": ["executing once", "finalizing"],
          "register": "formal",
          "domain": ["general", "business", "law", "technology"]
        }
      ]
    },
