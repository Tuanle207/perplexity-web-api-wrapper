    {
      "term": "redundancy",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "The state of being not needed or useless because something already exists or is more than enough.",
          "examples": [
            "There is redundancy in the system, with several teams doing the same job.",
            "Job redundancy occurred when the company restructured."
          ],
          "collocations": [
            "organizational redundancy",
            "staff redundancy",
            "reduce redundancy",
            "production redundancy",
            "data redundancy",
            "redundancy payment"
          ],
          "synonyms": ["superfluity", "duplication", "overabundance"],
          "antonyms": ["necessity", "essential", "concision"],
          "register": "formal",
          "domain": ["general", "business", "economics"]
        }
      ]
    },
    {
      "term": "redundant",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Not needed because something else already exists or because there is more of something than is necessary.",
          "examples": [
            "The appendix contains some redundant information.",
            "Many sentences in that paragraph are redundant."
          ],
          "collocations": [
            "completely redundant",
            "redundant data",
            "redundant part",
            "redundant features",
            "redundant workforce"
          ],
          "synonyms": ["superfluous", "unnecessary", "excessive"],
          "antonyms": ["necessary", "essential", "needed"],
          "register": "formal",
          "domain": ["general", "business", "education"]
        }
      ]
    },
    {
      "term": "redundantly",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "In a way that is unnecessary or more than is needed.",
          "examples": [
            "The report is redundantly long.",
            "He was redundantly repeating the same point."
          ],
          "collocations": [
            "worded redundantly",
            "redundantly verbose",
            "redundantly added information"
          ],
          "synonyms": [],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "writing"]
        }
      ]
    },
