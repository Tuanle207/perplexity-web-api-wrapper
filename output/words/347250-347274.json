          "synonyms": ["testing", "inspection", "vetting"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "business", "medicine"]
        },
        {
          "pos": "noun",
          "definition": "a film, play, or broadcast shown to an audience before the main event",
          "examples": ["The premiere included a short screening of the trailer."],
          "collocations": ["film screening", "screening room"],
          "synonyms": ["preview", "showing"],
          "antonyms": [],
          "register": "formal",
          "domain": ["entertainment", "media"]
        },
        {
          "pos": "verb",
          "definition": "to examine people or things to decide if they are suitable or safe",
          "examples": ["They screened applicants for the internship.", "The library screens all borrowed items for damage."],
          "collocations": ["screen applicants", "screen for", "screen for safety"],
          "synonyms": ["test", "evaluate", "vet"],
          "antonyms": ["disregard", "ignore"],
          "register": "formal",
          "domain": ["general", "business", "law"]
