      "term": "propatriotism",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "A mistaken or misguided form of patriotism that is directed toward promoting a person, group, or cause rather than genuine national service.",
          "examples": [
            "The campaign framed it as propatriotism, but many argued it was just nationalist rhetoric.",
            "Critics claimed the movement leaned toward propatriotism rather than civic duty."
          ],
          "collocations": ["propapatriotism", "surge of propatriotism", "alleged propatriotism"],
          "synonyms": ["jingoism (related concept)", "nationalistic zeal"],
          "antonyms": ["patriotism", "civic mindedness"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
