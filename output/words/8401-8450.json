      "term": "akinesis",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A medical condition in which a person cannot move certain muscles or body parts by their own will.",
          "examples": [
            "The patient’s facial akinesis made it difficult for him to show emotions clearly.",
            "Akinesis is often seen in people with advanced Parkinson’s disease.",
            "Doctors adjusted her medication after signs of akinesis appeared in her right arm."
          ],
          "collocations": [
            "severe akinesis",
            "focal akinesis",
