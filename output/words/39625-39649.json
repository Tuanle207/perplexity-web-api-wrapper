    {
      "term": "bibimbap",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A Korean dish consisting of a bowl of rice topped with seasoned vegetables, usually meat, and often a raw or fried egg, served with gochujang (red pepper paste).",
          "examples": [
            "We had bibimbap for lunch and added a fried egg on top.",
            "Bibimbap is a popular Korean dish at many restaurants."
          ],
          "collocations": [
            "bowl of bibimbap",
            "vegetables for bibimbap",
            "beef bibimbap",
            "gochujang bibimbap",
            "hot bibimbap"
          ],
          "synonyms": ["mixed rice with vegetables" ],
          "antonyms": [],
          "register": "neutral",
          "domain": ["food", "everyday", "culture"]
        }
      ]
    },
