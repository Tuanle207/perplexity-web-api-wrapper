      "term": "casease",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "an enzyme that breaks down casein (a protein found in milk), used in dairy processing or cheese making",
          "examples": ["Researchers added a casease to the mixture to digest excess casein."],
          "collocations": ["casease activity", "casease enzyme", "milk digestion"],
          "synonyms": ["protease (milk-clotting related)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "biology", "food science"]
        }
      ]
    },
