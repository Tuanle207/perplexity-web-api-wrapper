  "items": [
    {
      "term": "shillyshally",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to be indecisive or to waver between options; to dawdle or stall",
          "examples": [
            "He kept shillyshallying about whether to accept the job offer.",
            "Don't shillyshally—make a decision."
          ],
          "collocations": ["shillyshally about", "shillyshally and delay", "continual shillyshallying"],
          "synonyms": ["hesitate", "vacillate", "dither"],
          "antonyms": ["decide", "commit", "determine"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
    {
