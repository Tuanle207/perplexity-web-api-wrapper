      "term": "briticism",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a word, expression, or linguistic feature characteristic of British English, especially as contrasted with other varieties like American English",
          "examples": [
            "The term 'lorry' is a briticism that differs from the American 'truck'.",
            "Some briticisms survive in regional dialects rather than standard British English."
          ],
          "collocations": ["briticism in", "local briticism", "linguistic briticism"],
          "synonyms": ["Britishism", "Britic phrase"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "language"]
        }
