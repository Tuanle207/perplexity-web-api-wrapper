      "term": "sinusitis",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "Inflammation of the sinuses, often causing nasal congestion, facial pain, and thick mucus.",
          "examples": [
            "She was diagnosed with sinusitis after several days of headaches and a blocked nose.",
            "Chronic sinusitis can last for weeks or months."
          ],
          "collocations": ["acute sinusitis", "chronic sinusitis", "sinusitis symptoms", "sinusitis treatment"],
          "synonyms": ["rhinosinusitis", "sinus infection"],
          "antonyms": ["healthy sinuses"],
          "register": "neutral",
          "domain": ["health", "general"]
        }
      ]
    },
