  "items": [
    {
      "term": "quantisation",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process of converting continuous values or measurements into discrete steps or units",
          "examples": ["The quantisation of the continuous signal introduces small errors.", "In digital audio, quantisation affects resolution."],
          "collocations": ["noise", "bit depth", "sampling", "algorithm", "error"],
          "synonyms": ["discretisation", "discretization", "digitisation"],
          "antonyms": ["continuous spectrum", "analog"],
          "register": "formal",
          "domain": ["technology", "general", "engineering"]
        }
      ]
    },
    {
