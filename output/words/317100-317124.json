    {
      "term": "quake",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a sudden and violent shaking of the ground, such as caused by an earthquake",
          "examples": ["The earthquake caused a strong quake that damaged buildings."],
          "collocations": ["earthquake", "magnitude", "aftershock", "tremor", "seismic"],
          "synonyms": ["earthquake", "tremor"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "geography", "science"]
        },
        {
          "pos": "verb",
          "definition": "to tremble or shake violently; to shake with fear or excitement",
          "examples": ["The old house quaked during the blast.", "Her hands quaked with nerves before the speech."],
          "collocations": ["quaked", "quaking", "quake-prone"],
          "synonyms": ["tremble", "shake", "quake"],
          "antonyms": ["steady", "stabilize"],
          "register": "neutral",
          "domain": ["general", "literary"]
        },
        {
          "pos": "noun",
          "definition": "an instance of something that shakes or vibrates strongly",
          "examples": ["The quakes in the area were frequent aftershocks."],
          "collocations": ["afterquake", "seismic quake"],
          "synonyms": ["shudder", "tremor"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["science", "geology"]
        }
      ]
    },
