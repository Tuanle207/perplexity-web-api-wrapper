      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that is symmetrical around a central axis or point in two directions",
          "examples": ["The design is bisymmetrically arranged, mirroring on both sides.", "The figure is bisymmetrically balanced across the vertical axis."],
