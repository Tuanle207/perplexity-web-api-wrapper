    {
      "term": "seroprevalence",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the proportion of people in a population who have antibodies to a particular infectious agent in their blood serum",
          "examples": [
            "The study measured seroprevalence to estimate how many people had been infected before.",
            "High seroprevalence usually suggests past exposure to the disease.",
            "Researchers compared seroprevalence across age groups."
          ],
          "collocations": [
            "level of seroprevalence",
            "estimate seroprevalence",
            "national seroprevalence",
            "seroprevalence study",
            "seroprevalence survey",
            "antibody seroprevalence",
            "seroprevalence rates"
          ],
          "synonyms": [
            "antibody prevalence"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine",
            "public-health",
            "academic"
          ]
        }
      ]
    },
