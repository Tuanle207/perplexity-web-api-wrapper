{
  "items": [
    {
      "term": "proliferation",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the rapid and often excessive increase or spreading of something, especially cells, ideas, or products",
          "examples": [
            "The proliferation of smartphones changed how people communicate.",
            "There is concern about the proliferation of weapons.",
            "Media literacy helps combat the rapid proliferation of misinformation."
          ],
          "collocations": ["rapid proliferation", "proliferation of", "uncontrolled proliferation", "global proliferation"],
          "synonyms": ["spread", "multiplication", "growth", "expansion"],
          "antonyms": ["reduction", "decrease", "contraction"],
          "register": "neutral",
          "domain": ["general", "technology", "business", "science"]
        }
      ]
    },
    {
      "term": "proliferations",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of proliferation; multiple instances of rapid growth or spread",
