    {
      "term": "sinecure",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A paid job or position that requires little or no work but gives the holder status or benefits.",
          "examples": ["Some historians described the post as a sinecure enjoyed by a favored noble."],
          "collocations": ["political sinecure", "official sinecure", "get a sinecure"],
          "synonyms": ["perk", "comfort job", "easy job"],
          "antonyms": ["laborious job", "demanding position"],
          "register": "formal",
          "domain": ["general", "employment", "history"]
        }
      ]
    },
    {
      "term": "sinecured",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Having a sinecure; enjoying an easy, well-paid position with little or no work.",
          "examples": ["He held a sinecured post in the ministry."],
          "collocations": ["sinecured official", "sinecured post"],
          "synonyms": ["easy-duty", "cushy"],
          "antonyms": ["busy", "demanding"],
          "register": "formal",
          "domain": ["general", "employment", "politics"]
        }
      ]
    },
    {
      "term": "sinecures",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "Jobs that provide pay or status with little work required.",
          "examples": ["Several offices were filled with sinecures after the reform."],
          "collocations": ["political sinecures", "padded sinecures"],
          "synonyms": ["easy jobs", "comfort positions"],
          "antonyms": ["hard jobs", "grunt work"],
          "register": "formal",
          "domain": ["politics", "history", "general"]
        }
      ]
    },
    {
      "term": "sinecureship",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "The state or condition of having a sinecure; a position that requires little work but yields benefits.",
          "examples": ["They resented the sinecureship granted to the new appointee."],
          "collocations": ["institution sinecureship", "royal sinecureship"],
          "synonyms": ["easy post", "cushy position"],
          "antonyms": ["labor-intensive role"],
          "register": "formal",
          "domain": ["politics", "history"]
        }
      ]
    },
    {
      "term": "sinecuring",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "The act or practice of obtaining or maintaining a sinecure; favoring someone for an easy post.",
          "examples": ["The sinecuring of relatives was a source of corruption."],
          "collocations": ["sinecure seeking", "sinecuring practice"],
          "synonyms": ["favoritism", "nepotism"],
          "antonyms": ["merit-based appointment"],
          "register": "formal",
          "domain": ["politics", "ethics"]
        }
      ]
    },
    {
      "term": "sinecurism",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "The belief in or practice of preferring sinecures; the system of rewarding with easy posts.",
          "examples": ["Sinecurism was criticized in the reform debates."],
          "collocations": ["practice of sinecurism", "political sinecurism"],
          "synonyms": ["nepotism", "cronyism"],
          "antonyms": ["meritocracy", "egalitarian appointments"],
          "register": "formal",
          "domain": ["politics", "ethics"]
        }
      ]
    },
    {
      "term": "sinecurists",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "People who advocate or practice sinecurism; those who seek or grant sinecures.",
          "examples": ["Sinecurists argued that easier posts were necessary to attract talent."],
          "collocations": ["sinecurist politicians", "senior sinecurists"],
          "synonyms": ["nepotists", "cronyists"],
          "antonyms": ["meritocrats"],
          "register": "formal",
          "domain": ["politics", "ethics"]
        }
      ]
    },
    {
      "term": "sinecurist",
    "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A person who holds or advocates for a sinecure; someone who benefits from easy work",
          "examples": ["The sinecurist declined a demanding assignment."],
          "collocations": ["sinecurist official", "leading sinecurist"],
          "synonyms": ["nepotist", "crony"],
          "antonyms": ["meritocrat"],
          "register": "formal",
          "domain": ["politics", "ethics"]
        }
      ]
    },
    {
