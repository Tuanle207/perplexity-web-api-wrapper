    {
      "term": "sine",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A simple mathematical ratio of the opposite side to the hypotenuse in a right triangle; a trigonometric function.",
          "examples": ["The sine of the angle is 0.5."],
          "collocations": ["sine wave", "sine function", "sin x"],
          "synonyms": ["sin"],
          "antonyms": [],
          "register": "formal",
          "domain": ["mathematics", "science"]
        },
        {
          "pos": "noun",
          "definition": "A poetic or archaic term for a wave or sine-like curve in certain contexts.",
          "examples": ["The sine of the shore line resembled a gentle curve."],
          "collocations": ["sine curve"],
          "synonyms": [],
          "antonyms": [],
          "register": "archaic",
          "domain": ["literature"]
        }
      ]
