  "items": [
    {
      "term": "reconnoiter",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to inspect or scout a place, often to gain information for military or strategic purposes",
          "examples": [
            "The crew reconnoitered the valley before advancing.",
            "They took scarce time to reconnoiter the enemy position."
          ],
          "collocations": ["reconnoiter a place", "reconnoiter the area", "reconnoiter for intelligence"],
          "synonyms": ["survey", "scout", "inspect"],
          "antonyms": ["ignore", "overlook"],
          "register": "neutral",
          "domain": ["military", "general"]
        }
      ]
    },
