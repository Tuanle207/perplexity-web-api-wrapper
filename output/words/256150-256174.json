  "items": [
    {
      "term": "normalism",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a belief or practice that emphasizes conformity to a standard or norm",
          "examples": [
            "the ideology of normalism in certain social groups.",
            "critics argued that normalism stifles creativity by enforcing sameness."
          ],
          "collocations": [
            "cultural normalism",
            "social normalism",
            "political normalism",
            "norms and normalism"
          ],
          "synonyms": ["conformity", "orthodoxy"],
          "antonyms": ["nonconformity", "abnormality"],
          "register": "neutral",
          "domain": ["general", "sociology", "culture"]
        }
      ]
    },
    {
      "term": "normalist",
