      "term": "bedumbing",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "to cause to become numb or insensible, especially by a blow or shock",
          "examples": [
            "The fall bedumbed him for a moment, and he couldn't feel his legs.",
            "The blow bedumbed her senses, making it hard to respond."
          ],
          "collocations": ["bedumb", "bedumbing effort", "bedumbing sensation"],
          "synonyms": ["numb", "stun", "benumb"],
          "antonyms": ["stimulate", "awake", "enliven"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
