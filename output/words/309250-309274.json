    {
      "term": "proletariatism",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a theoretical or ideological concept related to proletariat, often used to describe what some see as the essence or doctrines associated with the working class in Marxist theory",
          "examples": ["Some scholars dismissed proletariatism as an outdated dogma of class struggle."],
          "collocations": ["proletariatism theory", "critique of proletariatism", "Marxist proletariatism"],
          "synonyms": ["proletarianism (related concept)", "Marxist theory (related)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "political"]
        }
      ]
    },
    {
