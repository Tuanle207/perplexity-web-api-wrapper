    {
      "term": "calamity",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A very serious and often sudden disaster or misfortune.",
          "examples": [
            "The earthquake was a calamity that left thousands homeless.",
            "The flood caused widespread calamity in the region."
          ],
          "collocations": [
            "great calamity",
            "national calamity",
            "natural calamity",
            "calamity strike",
            "face calamity",
            "calamity of war"
          ],
          "synonyms": ["disaster", "catastrophe", "calamity"],
          "antonyms": ["blessing", "prosperity", "fortune"],
          "register": "formal",
          "domain": ["general", "emergency", "disaster"]
        },
        {
          "pos": "noun",
          "definition": "A calamity can also mean a great misfortune or disaster that causes distress or hardship.",
          "examples": [
            "The loss of their home was a calamity for the family.",
            "The project failure was seen as a calamity for the team."
          ],
          "collocations": [
            "personal calamity",
            "financial calamity",
            "political calamity"
          ],
          "synonyms": ["misfortune", "disaster", "catastrophe"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "emotional", "economic"]
        }
      ]
