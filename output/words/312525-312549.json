    {
      "term": "pseudoism",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "the practice or tendency of presenting something as genuine when it is not; a false or deceptive imitation of an activity or belief",
          "examples": [
            "His pseudoism in the classroom made students doubt the teacher's expertise.",
            "The article criticized the pseud oism of certain self-proclaimed experts."
          ],
          "collocations": [
            "pseudoism in culture",
            "academic pseudoism",
            "political pseudoism"
          ],
          "synonyms": ["pretense", "sham", "falsehood"],
          "antonyms": ["genuineness", "authenticity", "sincerity"],
          "register": "formal",
          "domain": ["general", "education", "culture"]
        }
      ]
    },
