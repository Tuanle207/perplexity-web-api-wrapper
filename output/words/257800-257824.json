      "term": "nuts",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the hard-shelled edible fruit that grows on trees such as almonds, walnuts, and hazelnuts",
          "examples": ["She bought a bag of mixed nuts for the trail.", "Walnuts are a common ingredient in baking."],
          "collocations": ["mixed nuts", "roasted nuts", "eat nuts", "nut allergy"],
          "synonyms": ["kernels", "seed arils (in specific contexts)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["food", "general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "a slang term meaning a person who is crazy or acting silly; also used as an exclamation (nuts!)",
          "examples": ["That plan is nuts!", "Don't be nuts — wear a helmet."],
          "collocations": ["totally nuts", "completely nuts", "go nuts"],
          "synonyms": ["crazy person", "lunatic (informal)"],
          "antonyms": ["sane person", "reasonable"],
          "register": "informal",
          "domain": ["slang", "general"]
        }
