      "term": "brokery",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act or business of breaking in or dealing with something; often used to refer to illegal or dishonest practices like fraud or conniving behavior",
          "examples": [
            " rumors of brokery spread through the market.",
            "the politician condemned the grocer's alleged brokery in pricing."
          ],
          "collocations": [
            "financial brokery",
            "criminal brokery",
            "market brokery",
            "alleged brokery"
          ],
          "synonyms": ["fraud", "deception", "graft"],
          "antonyms": ["honesty", "integrity"],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
