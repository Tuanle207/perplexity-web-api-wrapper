    {
      "term": "scallop",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A marine mollusk with a fan-shaped shell; also the edible flesh of this mollusk.",
          "examples": [
            "We bought fresh scallops for the dinner.",
            "The scallop has a distinctive ridged shell."
          ],
          "collocations": [
            "sauté scallops",
            "sea scallops",
            "pan-seared scallops",
            "dried scallops"
          ],
          "synonyms": ["pectinidae mollusk", "seafood"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["food", "nature", "general"]
        },
        {
          "pos": "verb",
          "definition": "To form something into a scallop-like shape or to trim edge in a scalloped pattern.",
          "examples": [
            "The lace was scalloped around the edges.",
