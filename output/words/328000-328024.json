      "term": "rejuvenate",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to make someone look or feel younger or more lively; to restore youth or vitality",
          "examples": [
            "A good night's sleep can rejuvenate you.",
            "The spa treatments rejuvenate the skin."
          ],
          "collocations": ["rejuvenate the skin", "rejuvenate the body", "rejuvenate energy", "rejuvenate appearance"],
          "synonyms": ["refresh", "revitalize", "renew", "invigorate"],
          "antonyms": ["exhaust", "deplete", "age"],
          "register": "neutral",
          "domain": ["general", "health", "wellness", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to restore or revive something to a better condition or more youthful state (abstract or non-literal)",
