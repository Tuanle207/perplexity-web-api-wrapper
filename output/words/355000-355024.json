    {
      "term": "shellshocks",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a state of emotional distress or numbness caused by prolonged exposure to traumatic events, especially in soldiers; also any intense emotional shock.",
          "examples": [
            "Many veterans suffer from shellshock after years of combat.",
            "The news of the disaster left him in a shellshock of disbelief."
          ],
          "collocations": ["battlefield shellshock", "prolonged shellshock", "combat-related shellshock"],
          "synonyms": ["trauma", "PTSD (post-traumatic stress disorder)", "numbness"],
          "antonyms": ["composure", "calm"],
          "register": "formal",
          "domain": ["general", "medicine", "psychology", "everyday"]
        }
      ]
    },
