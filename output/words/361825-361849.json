        {
          "pos": "noun",
          "definition": "plural of slough, a swampy or muddy area; also a layer of dead skin shed by some animals or reptiles",
          "examples": [
            "The marsh contained several shallow sloughs.",
            "The snake shed its slough as it grew.",
            "Farmers warned about muddy sloughs after the rain."
          ],
          "collocations": ["seasonal sloughs", "deep slough", "wet sloughs", "slough of mud", "slough habitat"],
          "synonyms": ["marsh", "bog", "swamp", "mire", "soil layer of shed skin for some animals"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "environment", "ecology"]
        }
      ]
