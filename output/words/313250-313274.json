      "term": "psychohistorian",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who studies or writes about psychohistory, the idea of combining psychology and history to understand large-scale human behavior across time",
          "examples": [
            "The psychohistorian analyzed how collective fear shaped political decisions over centuries."
          ],
          "collocations": [
            "noted psychohistorian",
            "psychohistorian book",
            "psychohistorian analysis"
          ],
          "synonyms": ["historian with a focus on psychology", "psychological historian"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["academic", "general"]
        }
      ]
    },
