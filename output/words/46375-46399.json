    {
      "term": "boswellizing",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to imitate or imitate the style of Samuel Johnson's biographer James Boswell; to write in a Boswellian manner, especially with thorough biographical detail.",
          "examples": ["The essay attempts to boswellize the life of the novelist, including extensive anecdotes."],
          "collocations": ["boswellize a biography", "boswellizing approach", "Boswellized writing"],
          "synonyms": ["biographize (less common)", "emulate Boswell"],
          "antonyms": [],
          "register": "formal",
          "domain": ["literature", "writing", "biography"]
        }
        ,
        {
          "pos": "noun",
          "definition": "the act or result of writing or composing in a Boswellian style.",
          "examples": ["His boswellizing produced a detailed, anecdotal portrait."],
          "collocations": ["boswellizing", "boswellizing style"],
          "synonyms": ["biographizing style"],
          "antonyms": [],
          "register": "formal",
          "domain": ["literature"]
        }
      ]
    },
