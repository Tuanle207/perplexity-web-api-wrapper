      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a crude or unrefined crowd; the common people often seen as lacking taste or refinement",
          "examples": [
            "The protests drew both the canaille and the reformists, though the loudest voices came from the canaille.",
            "He dismissed the noisy crowd as canaille."
          ],
          "collocations": ["the canaille", "rabble", "crowd", "masses", "common people"],
          "synonyms": ["rabble", "mob", "crowd", "plebeians"],
          "antonyms": ["elite", "gentry", "nobility"],
          "register": "archaic",
          "domain": ["general", "society"]
        }
      ]
    },
