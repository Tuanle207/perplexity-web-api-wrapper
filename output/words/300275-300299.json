      "term": "potamologist",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a scientist who studies rivers and their environments",
          "examples": [
            "The potamologist visited the research site to measure river flow and sediment.",
            "As a potamologist, she specializes in the ecology of freshwater systems."
          ],
          "collocations": [
            "river potamologist",
            "potamologist researcher",
            "study of rivers"
          ],
          "synonyms": ["fluvial scientist", "hydrologist (river specialist)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "environment", "academic"]
        }
      ]
