    {
      "term": "blusteriest",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "most prone to loud, aggressive, or noisy talking; characterized by strong or exaggerated expressions without much substance",
          "examples": [
            "The blusteriest politicians shouted promises without details.",
            "He delivered a blusteriest speech, full of bravado but little insight."
          ],
          "collocations": ["blusteriest rhetoric", "blusteriest voice", "blusteriest performance"],
          "synonyms": ["boastful", "braggadocious", "boisterous"],
          "antonyms": ["measured", "calm", "substantive"],
          "register": "informal",
          "domain": ["general", "politics"]
        }
      ]
    },
