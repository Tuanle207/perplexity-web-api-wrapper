          "collocations": ["renegating on a promise", "renegating on an agreement", "suddenly renegating"],
          "synonyms": ["backpedaling", "breaking a promise", "defaulting"],
          "antonyms": ["keeping a promise", "fulfilling an agreement"],
          "register": "formal",
          "domain": ["general", "business"]
        }
