      "term": "renegating",
      "kind": "gerund",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of reneging; failing to keep a promise or commitment",
          "examples": [
            "Renegating on the deal damaged his credibility.",
            "The company faced backlash for renegating after the merger."
