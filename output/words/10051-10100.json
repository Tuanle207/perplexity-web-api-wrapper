      "term": "allegorizes",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "verb",
          "definition": "expresses ideas through symbolic stories or images",
          "examples": ["The novel allegorizes political events.", "He allegorizes human life as a journey."],
