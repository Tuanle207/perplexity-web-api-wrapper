  "items": [
    {
      "term": "semifictionally",
      "kind": "adverb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that resembles or is related to semi-fiction; not fully fictional or fully non-fictional",
          "examples": ["The report was presented semifictionally, blending fact with narrative elements.", "Her memoirs were semifictionally embellished to read more like a novel."],
          "collocations": ["semifictionally accurate", "semifictionally blended", "semifictionally presented"],
          "synonyms": ["partially fictional", "semi-fictional"],
          "antonyms": ["completely factual", "strictly nonfictional"],
          "register": "neutral",
          "domain": ["general", "literary"]
        }
      ]
    },
    {
