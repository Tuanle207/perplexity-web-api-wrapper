      "term": "capsulectomy",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a surgical procedure to remove a scarred capsule of tissue around an implanted medical device",
          "examples": [
            "A capsulectomy may be recommended if a capsule tightens around an implant.",
            "The surgeon removed the capsule and replaced the implant.",
            "After a capsulectomy, healing can take several weeks."
          ],
          "collocations": [
            "capsulectomy procedure",
            "capsulectomy surgery",
            "remove the capsule",
            "scar tissue capsule",
            "implant capsule",
            "capsular contracture",
            "breast implant capsulectomy"
          ],
          "synonyms": [
            "capsule removal surgery"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine",
            "surgery"
          ]
        }
