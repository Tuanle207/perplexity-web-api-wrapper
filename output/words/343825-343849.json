    {
      "term": "savage",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Fierce, violent, or uncontrolled in behavior or appearance.",
          "examples": [
            "The storm caused savage waves along the coast.",
            "He gave a savage critique of the proposal.",
            "The dog growled with savage intensity."
          ],
          "collocations": [
            "savage violence",
            "savage attack",
            "savage critic",
            "savage temperature",
            "savage mood"
          ],
          "synonyms": ["brutal", "ferocious", "cruel"],
          "antonyms": ["gentle", "mild", "civilized"],
          "register": "informal",
          "domain": ["general", "emergency"]
        },
        {
          "pos": "noun",
          "definition": "A brutal or uncivilized person; a person who behaves violently or cruelly.",
          "examples": [
            "The film portrays a group of savages in the jungle.",
            "The battlefield was full of savages and refugees alike."
          ],
          "collocations": [
            "band of savages",
            "savage attack",
            "attack by savages"
          ],
          "synonyms": ["brute", "barbarian", "monster"],
          "antonyms": ["civilian", "civilian person"],
          "register": "informal",
          "domain": ["general", "literary"]
        },
        {
          "pos": "verb",
          "definition": "To attack or treat someone with cruel violence; to crush or destroy severely.",
          "examples": [
            "The hurricane savaged the coastal town.",
            "The company was savaged by critics."
          ],
          "collocations": [
            "savaged by storms",
            "savaged by critics",
            "savaged market"
          ],
          "synonyms": ["ruin", "devastate", "disfigure"],
          "antonyms": ["protect", "nurse", "sustain"],
          "register": "informal",
          "domain": ["general", "media"]
        }
      ]
    },
