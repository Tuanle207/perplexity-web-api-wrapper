      "term": "segregationist",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who supports or advocates segregation by race or other social groups",
          "examples": [
            "The segregationist argued that separate schools were best for each community.",
            "Historical segregationists defended laws that separated people by race."
          ],
          "collocations": [
            "racial segregationist",
            "die-hard segregationist",
            "old-time segregationist",
            "segregationist policy",
            "segregationist stance"
          ],
          "synonyms": ["racialist", "separatist (contextual)"],
          "antonyms": ["integrationist", "egalitarian"],
          "register": "formal",
          "domain": ["history", "society", "politics"]
        }
      ]
    },
