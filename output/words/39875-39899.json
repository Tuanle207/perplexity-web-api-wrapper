  "items": [
    {
      "term": "biconditional",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a logical statement that expresses two conditions which are both true for the statement to hold, typically written as 'If A then B, and if B then A' in formal logic or mathematics",
          "examples": [
            "In mathematics, the biconditional A if and only if B is true when both directions hold.",
            "The sentence 'P if and only if Q' is a biconditional in logic."
          ],
          "collocations": ["biconditional statement", "biconditional proof", "biconditional connective"],
          "synonyms": ["iff condition", "if and only if statement"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "science", "logic", "mathematics"]
        }
      ]
    },
    {
