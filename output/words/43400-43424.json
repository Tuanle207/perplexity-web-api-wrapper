      "term": "blitzkrieg",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a swift, overwhelming military attack intended to defeat an opponent quickly.",
          "examples": [
            "The invasion used a blitzkrieg to surprise the defenders.",
            "Historians describe the early campaigns as a blitzkrieg."
          ],
          "collocations": [
            "blitzkrieg tactic",
            "blitzkrieg attack",
            "blitzkrieg warfare",
            "lightning blitzkrieg"
          ],
          "synonyms": ["lightning war", "sudden attack", "surprise invasion"],
          "antonyms": ["defensive war", "stalemate", "prolonged siege"],
          "register": "formal",
          "domain": ["military", "history", "general"]
        }
      ]
    },
