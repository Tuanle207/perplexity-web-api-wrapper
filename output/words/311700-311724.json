  "items": [
    {
      "term": "provocation",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of provoking or causing a reaction, often deliberately to annoy or incite someone",
          "examples": [
            "The teacher warned that any provocation would lead to disciplinary action.",
            "His provocative remarks were intended to provoke a debate."
          ],
          "collocations": [
            "intentional provocation",
            "provocation to anger",
            "racial provocation",
            "incitement and provocation",
            "emotional provocation",
            "provocation factor"
          ],
          "synonyms": ["incitement", "stimulation", "provoking", "aggravation"],
          "antonyms": ["composure", "restraint", "calmness"],
          "register": "formal",
          "domain": ["general", "society", "psychology"]
        }
      ]
    },
