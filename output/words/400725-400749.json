      "term": "tinter",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a device or person that adds color or dye to something, or that colors a material; more broadly, something that tints or affects color",
          "examples": ["The tinter added a small amount of blue to the mixture.", "A news article can tints the reader's perception with bias."],
          "collocations": ["tint the color", "color tints", "automatic tinter", "ink tinter"],
          "synonyms": ["dyer", "colorer", "dyer-instrument"],
          "antonyms": ["bleacher", "colorer (opposite function)"],
          "register": "neutral",
          "domain": ["general", "technology"]
        }
      ]
