{
  "items": [
    {
      "term": "send",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to cause something to go from one place to another; to cause a message or parcel to go to a recipient",
          "examples": [
            "Please send the email by the end of the day.",
            "She will send the package tomorrow."
          ],
          "collocations": ["send a letter", "send a message", "send money", "send off", "send back"],
          "synonyms": ["dispatch", "transmit", "ship"],
          "antonyms": ["receive", "keep", "retain"],
          "register": "neutral",
          "domain": ["everyday", "general", "business"]
        },
        {
          "pos": "noun",
          "definition": "an act of sending something; the thing that is sent",
          "examples": [
            "The send took longer than expected.",
            "He placed the send with the shipment."
          ],
          "collocations": ["make a send", "send of the parcel"],
          "synonyms": ["dispatch", "shipment"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general"]
        }
      ]
    },
    {
      "term": "sendable",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "able to be sent, typically via mail or electronic communication",
          "examples": [
            "The document is sendable as a PDF attachment.",
            "Make sure the file is in a sendable format."
          ],
          "collocations": ["sendable file", "sendable format"],
          "synonyms": ["transmittable", "dispatchable"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "general"]
        }
      ]
