      "term": "pucker",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to move the lips into a tight, pressed shape, usually as a reaction to sourness or to make a kissy face",
          "examples": [
            "She puckered her lips for a kiss.",
            "The lemon made him pucker up in surprise."
          ],
          "collocations": ["pucker your lips", "pucker up", "pucker slightly"],
          "synonyms": ["compress lips", "pout (mild)", "wrinkle lips"],
          "antonyms": ["relax lips", "unfold lips"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "verb",
          "definition": "to cause a surface to gather into small wrinkles or folds",
          "examples": [
            "The fabric puckered after washing.",
            "The seams puckered along the edge."
          ],
          "collocations": ["pucker the fabric", "pucker up the surface"],
          "synonyms": ["wrinkle", "crease"],
          "antonyms": ["smooth", "flatten"],
          "register": "neutral",
          "domain": ["general", "textile"]
        }
