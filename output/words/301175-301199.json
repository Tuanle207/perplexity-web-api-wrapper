      "term": "praisableness",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being praisable; worthiness of praise",
          "examples": [
            "The praisableness of her efforts was evident in the team’s overall improvement.",
            "Readers noted the praisableness of the author's meticulous research."
          ],
          "collocations": [
            "great praisableness",
            "praisableness of effort",
            "inherent praisableness"
          ],
          "synonyms": ["commendability", "merit", "worthy of praise"],
          "antonyms": ["blameworthiness", "reproach", "praiseworthiness is not applicable here"],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
