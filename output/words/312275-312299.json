    {
      "term": "pseudocentrum",
      "kind": "noun",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a body or central part formed by the fusion of dorsal elements in certain ancient vertebrates",
          "examples": [
            "The fossil description notes a pseudocentrum as the fused central structure of the midline vertebra.",
            "In tailed amphibians, the pseudocentrum refers to the body created by fusion of arcualia."
          ],
          "collocations": [
            "pseudocentrum of the vertebra",
            "fused pseudocentrum",
            "anatomical pseudocentrum"
          ],
          "synonyms": ["centrum fusion", "fused central body"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "biology", "paleontology"]
        }
      ]
    },
