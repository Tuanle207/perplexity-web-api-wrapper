      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the use of long or unusual words; pedantry in vocabulary",
          "examples": [
            "His talk was full of sesquipedalism, making it hard for the audience to follow.",
            "The essay suffered from sesquipedalism and unnecessary jargon."
          ],
          "collocations": ["prominent sesquipedalism", "avoid sesquipedalism", "excessive sesquipedalism"],
          "synonyms": ["verbosity", "grandiloquence", "sesquipedalianism"],
          "antonyms": ["conciseness", "brevity"],
          "register": "formal",
          "domain": ["academic", "general"]
