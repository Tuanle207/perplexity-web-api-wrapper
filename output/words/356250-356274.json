      "term": "shortchanges",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to cheat someone by giving less than what is owed or due",
          "examples": ["The seller shortchanges customers by charging for items they did not receive."],
          "collocations": ["shortchange customers", "shortchange someone", "shortchange pay"],
          "synonyms": ["cheat", "defraud", "rip off"],
          "antonyms": ["compensate", "refund"],
          "register": "formal",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to cause someone to receive less than they deserve or are entitled to",
          "examples": ["The audit revealed how the contractor shortchanges the local community."],
          "collocations": ["shortchange the victims", "shortchange the community"],
          "synonyms": ["undercut", "shortfall"],
          "antonyms": ["enhance", "improve"],
          "register": "formal",
          "domain": ["general", "society"]
        }
      ]
    },
