          ],
          "synonyms": ["marinating (in brine)"],
          "antonyms": ["drying", "rinsing"],
          "register": "neutral",
          "domain": ["food", "cooking"]
        },
        {
          "pos": "verb",
          "definition": "Present participle of 'brine'; to soak in brine.",
          "examples": [
            "The chef is brining the olives overnight.",
            "Brining the fish helps preserve it."
          ],
          "collocations": [
