          "collocations": ["bemusement", "great bemusements", "moments of bemusement"],
          "synonyms": ["confusion", "perplexity", "amusement"],
          "antonyms": ["clarity", "understanding"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
