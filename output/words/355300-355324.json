      "term": "shiftier",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "more inclined to change position or be evasive; more suspicious or dubious",
          "examples": [
            "The shiftier thief avoided cameras by moving quickly from shadow to shadow.",
            "He gave shiftier answers than before, avoiding direct commitments."
          ],
          "collocations": ["more shiftier", "increasing shiftier behavior", "shiftier than"],
          "synonyms": ["more evasive", "more dubious", "surer of deception (less direct)"],
          "antonyms": ["more straightforward", "honest", "trustworthy"],
          "register": "informal",
          "domain": ["general", "everyday"]
        }
      ]
    },
