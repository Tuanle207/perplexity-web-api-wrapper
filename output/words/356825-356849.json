      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "To tremble or shake suddenly, often from fear, cold, or strong emotion.",
          "examples": [
            "The ground shook as the thunder rolled.",
            "She shuddered at the memory.",
            "The old house shook during the earthquake."
          ],
          "collocations": ["shudder violently", "shudder with fear", "shudder in horror"],
          "synonyms": ["tremble", "quiver", "shake"],
          "antonyms": [],
