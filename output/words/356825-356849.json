    {
      "term": "shuck",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "To remove the outer shell or covering of something, often quickly and with effort.",
          "examples": [
            "He shucked the corn and handed the ears to me.",
            "The oyster was shucked at the market by a vendor."
          ],
          "collocations": ["shuck off", "shuck the corn", "shuck the shell"],
          "synonyms": ["peel", "pare", "strip"],
          "antonyms": ["wear", "keep"],
          "register": "neutral",
          "domain": ["general", "food"]
        },
        {
          "pos": "noun",
          "definition": "A husk or shell that has been removed from something, especially shellfish or corn.",
          "examples": [
            "He discarded the shucks after shucking the corn.",
            "The field was littered with corn shucks."
          ],
          "collocations": ["corn shucks", "oyster shucks"],
          "synonyms": ["husk", "shell"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "agriculture"]
        }
      ]
    },
