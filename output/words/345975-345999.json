    {
      "term": "scientizes",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to make something scientific in character or to apply scientific methods or thinking to something",
          "examples": [
            "The researcher scientizes the approach by using controlled experiments.",
            "We should scientize our analysis with quantitative data."
          ],
          "collocations": [
            "scientize data",
            "scientize approach",
            "scientize method",
            "scientize research"
          ],
          "synonyms": ["scientificize", "systematize"],
          "antonyms": ["antique", "artificialize"],
          "register": "neutral",
          "domain": ["general", "academic"]
        }
      ]
    },
