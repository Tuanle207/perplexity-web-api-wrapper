    {
      "term": "reprivatize",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to return a company or service from government control to private ownership",
          "examples": ["The government plans to reprivatize the railway system.", "They voted to reprivatize several state-owned firms."],
          "collocations": ["reprivatize industry", "reprivatize services", "reprivatize assets", "reprivatize a company"],
          "synonyms": ["privatize again", "return to private ownership"],
          "antonyms": ["nationalize", "publicize"],
          "register": "formal",
          "domain": ["business", "economics"]
        }
      ]
    },
