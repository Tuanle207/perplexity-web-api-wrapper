      "term": "scrape",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to remove an outer layer from something by rubbing or scratching it with a tool or with your nails",
          "examples": [
            "He scraped the paint off the wall.",
            "Her knees were scraped after the fall."
          ],
          "collocations": ["scrape off", "scrape the surface", "scrape clean"],
          "synonyms": ["rasp", "scrub", "rub off"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "home"]
        },
        {
          "pos": "verb",
          "definition": "to obtain or collect something with difficulty or by scraping together small amounts",
          "examples": [
            "They managed to scrape together enough money.",
            "She scraped together a meal from leftovers."
          ],
          "collocations": ["scrape together", "scrape up", "scrape by"],
          "synonyms": ["gather", "collect", "scrimp"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "finance"]
        },
        {
          "pos": "noun",
