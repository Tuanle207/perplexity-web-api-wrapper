    {
      "term": "scrapbook",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a book in which you collect and paste photographs, notes, and other keepsakes",
          "examples": [
            "She kept a scrapbook of travel memories.",
            "His scrapbook is full of old tickets and photos."
          ],
          "collocations": ["photo scrapbook", "travel scrapbook", "scrapbook page"],
          "synonyms": ["album", "memory book"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "creative"]
        },
        {
          "pos": "verb",
          "definition": "to create or fill a scrapbook by collecting items and attaching them to pages",
          "examples": [
            "She scrapbooked her trip with tickets and postcards.",
            "They scrapbooked their wedding memories together."
          ],
          "collocations": ["scrapbook a trip", "scrapbook memories", "scrapbook pages"],
          "synonyms": ["compile a scrapbook"],
          "antonyms": [],
          "register": "neutral",
