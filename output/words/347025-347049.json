    {
      "term": "scrap",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "leftover small pieces or bits of something that are not useful for their original purpose",
          "examples": [
            "We gathered scrap metal from the workshop.",
            "She kept a box of scrap paper for notes."
          ],
          "collocations": ["scrap metal", "scrap wood", "scrap of paper", "scrap value"],
          "synonyms": ["remnant", "waste", "residue"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "a small piece or amount of something that is not enough to be useful on its own",
          "examples": [
            "There isn’t a scrap of evidence to support the claim.",
            "He didn't have a scrap of courage left."
          ],
          "collocations": ["a scrap of evidence", "a scrap of hope", "scrap of cloth"],
          "synonyms": ["bit", "fragment", "trace"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to remove (a material) in small pieces or to discard as worthless",
          "examples": [
            "They scrapped the old model and designed a new one.",
            "He scrapped the broken chair for scrap metal."
          ],
          "collocations": ["scrap the plan", "scrap the project", "scrap metal"],
          "synonyms": ["discard", "discard", "dismantle"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "business"]
        }
      ]
    },
