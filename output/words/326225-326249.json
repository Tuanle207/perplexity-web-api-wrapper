      "term": "reflow",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to flow again or in a new way, especially in a different path or arrangement",
          "examples": [
            "The lava began to reflow after the initial eruption.",
            "Heat caused the plastic to reflow into a softer shape."
          ],
          "collocations": [
            "reflow pattern",
            "reflow process",
            "reflow of lava",
            "reflow of information",
            "allow to reflow"
          ],
          "synonyms": ["flow again", "recede and return to flow", "rearrange"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "science", "technology"]
        }
      ]
    },
