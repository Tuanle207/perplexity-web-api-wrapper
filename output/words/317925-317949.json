    {
      "term": "quib",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A short, witty or clever remark; a small quibble or petty objection.",
          "examples": [
            "He fired a quick quib about the budget.",
            "Her quib about the plan showed she wasn’t convinced."
          ],
          "collocations": ["witty quib", "clever quip", "petty quibbling"],
          "synonyms": ["quip", "sarcastic remark"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "communication"]
        }
      ]
    },
    {
      "term": "quibble",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "To argue about small details or to complain for a small reason.",
          "examples": [
            "They quibble over the exact time of arrival.",
            "Stop quibbling and sign the contract."
          ],
          "collocations": ["quibble over", "quibble about", "hardly quibble"],
          "synonyms": ["argue", "nitpick", "complain"],
          "antonyms": ["agree", "accept"],
          "register": "informal",
          "domain": ["general", "law" ]
        },
        {
          "pos": "noun",
          "definition": "A small objection or petty complaint.",
