    {
      "term": "qui",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "pronoun",
          "definition": "A question word used to ask about the reason or identity of something in formal contexts; also used in phrases meaning 'who' or 'what' in some languages; in English, mainly appears in phrases like 'qui vive' (on the alert) or as part of musical terms borrowed from French.",
          "examples": [
            "Qui est là? (French; not standard English but appears in certain expressions).",
            "The phrase 'qui vive' is used in English to mean being on the alert."
          ],
          "collocations": ["qui vive", "qui est là","dead-quiet (via French phrases)"],
          "synonyms": [],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "language"]
        }
      ]
    },
