      "term": "prepledging",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of pledging something beforehand, such as support or commitment, before an official event",
          "examples": ["The candidate announced prepledging of funds before the campaign began.", "They avoid prepledging their position until all facts are reviewed."],
          "collocations": ["prepledging support", "prepledging funds", "prepledging commitment"],
          "synonyms": ["prior pledging", "pre-pledging"],
          "antonyms": [],
          "register": "formal",
          "domain": ["politics", "finance"]
        }
      ]
    },
