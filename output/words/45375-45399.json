      "term": "bonged",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "Past tense of bong, which can mean to hit with a bong in drug use slang or to strike a bell or similar object soundly; however, bong as a verb is not standard in formal writing and bonged is not widely used with a clear, universal meaning.",
          "examples": ["The bell bonged loudly as the door opened."],
          "collocations": ["bonged bell", "bonged drum"],
          "synonyms": [],
          "antonyms": [],
          "register": "informal",
          "domain": ["everyday", "literary"]
        },
        {
          "pos": "adjective",
          "definition": "Describing something that has been connected to a bong or related to bong use; not common as a standalone adjective in standard English.",
