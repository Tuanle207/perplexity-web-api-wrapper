      "term": "segmentize",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to divide something into smaller parts called segments",
          "examples": [
            "We need to segmentize the market to target different customer groups.",
            "The data was segmentized into categories for analysis."
          ],
          "collocations": [
            "segmentize the data",
            "segmentize the market",
            "segmentize the population"
          ],
          "synonyms": ["partition", "divide", "segregate"],
          "antonyms": ["unify", "combine"],
          "register": "formal",
          "domain": ["general", "business", "data"]
        }
      ]
    },
