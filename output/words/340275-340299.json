    {
      "term": "saccharimetries",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "plural noun",
          "definition": "the plural form of saccharimetry, the science or technique of measuring the concentration of sugar solutions using a saccharimeter",
          "examples": [
            "The laboratory records include several saccharimetries of different sugar solutions.",
            "Historical saccharimetries show how sugar concentration was quantified before modern refractometers."
          ],
          "collocations": [
            "absorbance saccharimetries",
            "calibrated saccharimetries",
            "sugar saccharimetries"
          ],
          "synonyms": ["saccharimetry measurements", "sugar-concentration measurements"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "general"]
        }
      ]
    },
    {
      "term": "saccharimetry",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the branch of measurement science that uses a saccharimeter to determine how much sugar is in a solution by measuring optical rotation",
          "examples": [
            "Saccharimetry was once a common method in sugar laboratories.",
            "The method relies on the rotation of polarized light in sugar solutions."
          ],
          "collocations": [
            "determine sugar content",
            "optical rotation",
            "saccharimetry technique"
          ],
          "synonyms": ["saccharimeter measurement", "sugar concentration measurement"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "technology", "general"]
        }
      ]
    },
