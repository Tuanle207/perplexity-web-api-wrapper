    {
      "term": "prancing",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "present participle of prance; to move with lively, high-stepping action, often showing pride or playfulness",
          "examples": [
            "The horse was prancing around the ring.",
            "Children were prancing about in their new costumes."
          ],
          "collocations": ["prancing horse", "prancing gait", "prancing around"],
          "synonyms": ["trotting", "strutting", "galloping"],
          "antonyms": ["stomping", "dragging", "slumping"],
          "register": "neutral",
          "domain": ["everyday", "animal_behavior"]
        }
      ]
    },
