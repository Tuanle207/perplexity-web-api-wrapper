    {
      "term": "blot",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a dark mark or stain on a surface</br>caused by liquid, ink, or other substances",
          "examples": ["There was a blot on the page from spilled ink.", "She wiped the blot from the fabric."],
          "collocations": ["ink blot", "blot of ink", "stain blot", "blotter"],
          "synonyms": ["stain", "spot", "mark"],
          "antonyms": ["clear area", "unmarked surface"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "a large dark irregular patch on the skin or a surface",
          "examples": ["The canvas had a brown blot across the center.", "She noticed a blot on her sleeve."],
          "collocations": ["blood blot", "blotches of paint", "blood blot"],
          "synonyms": ["patch", "stain", "mark"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "arts"]
        },
        {
          "pos": "verb",
          "definition": "to leave a stain on a surface or to make something less clear by staining",
          "examples": ["The coffee blot the napkin.", "Her handwriting was blotted by rain."],
          "collocations": ["blot out", "blot up", "blot with ink"],
          "synonyms": ["stain", "spoil"],
          "antonyms": ["erase", "clear"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
