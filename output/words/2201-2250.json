      "term": "accustoming",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "Present participle of \"accustom\": gradually making yourself or someone else used to something so that it feels normal or natural.",
          "examples": [
            "She is slowly accustoming herself to the cold climate.",
            "The teacher is accustoming the students to speaking English in class.",
            "Moving abroad means accustoming yourself to many new customs."
          ],
          "collocations": [
            "accustoming oneself",
            "accustoming herself",
            "accustoming himself",
            "accustoming the children",
            "accustoming students to",
            "slowly accustoming",
            "gradually accustoming"
          ],
          "synonyms": [
            "adapting",
            "adjusting",
            "habituating",
            "acclimatizing"
          ],
          "antonyms": [
            "disturbing",
            "unsettling"
