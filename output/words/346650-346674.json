      "term": "score",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "An amount of points gained in a game or test.",
          "examples": [
            "The final score was 3–2.",
            "She kept the score on the whiteboard.",
            "The exam score determined his grade."
          ],
          "collocations": ["high score", "low score", "keep score", "score draw", "scoreboard score"],
          "synonyms": ["points", "points tally", "results"],
          "antonyms": ["losses", "defeat"],
          "register": "neutral",
          "domain": ["general", "sports", "education"]
        },
        {
          "pos": "verb",
          "definition": "To gain points in a game or test; to record or be credited with points.",
          "examples": [
            "They scored a goal in the last minute.",
            "She scored well on the test.",
            "The team has scored in every match this season."
