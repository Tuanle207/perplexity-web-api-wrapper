  "items": [
    {
      "term": "predisposition",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a tendency to behave in a particular way or to have a certain characteristic, often seen as a natural inclination or predisposed trait",
          "examples": [
            "Her predisposition toward careful planning helped the project succeed.",
            "The child has a predisposition to allergies.",
            "People with a genetic predisposition to the disease should monitor their health closely."
          ],
          "collocations": ["genetic predisposition", "predisposition toward", "predisposition to"],
          "synonyms": ["inclination", "tendency", "propensity"],
          "antonyms": ["aversion", "disinclination", "indifference"],
          "register": "formal",
          "domain": ["general", "medicine", "genetics"]
        }
      ]
    },
    {
