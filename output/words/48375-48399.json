      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the point at which income equals costs, resulting in no profit or loss",
          "examples": ["We expect to reach breakeven in year two.", "The project will not be profitable until it hits breakeven."],
          "collocations": ["breakeven point", "breakeven analysis", "breakeven sales"],
          "synonyms": ["no-profit point", "zero-profit"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["business", "economics"]
        },
        {
          "pos": "adjective",
          "definition": "at or to the level where costs equal revenue",
          "examples": ["The breakeven price was calculated to be $15 per unit."],
          "collocations": ["breakeven price", "breakeven quantity"],
          "synonyms": ["zero-profit", "nonloss"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["business"]
        }
      ]
    },
