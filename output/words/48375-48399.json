      "term": "breakers",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "people or things that break something or stop something from continuing",
          "examples": ["The breakers hit the coast with huge waves.", "The breakers in the queue are causing delays."],
          "collocations": ["wave breakers", "ice breakers", "alarm breakers", "gladiator breakers"],
          "synonyms": ["obstacles", "hindrances"],
          "antonyms": ["facilitators", "smoothers"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
    {
      "term": "breakeven",
