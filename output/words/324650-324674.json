  "items": [
    {
      "term": "redacting",
      "kind": "verb",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "present participle of redact; to edit a document by removing or obscuring sensitive information prior to publication or release",
          "examples": [
            "They are redacting the names of witnesses before the report is released.",
            "The document was heavily redacting to protect personal data."
          ],
          "collocations": [
            "redacting sensitive information",
            "redacting personal data",
            "redacting names",
            "redacting documents"
          ],
          "synonyms": [
            "censor",
            "edit",
            "blackout"
          ],
          "antonyms": [
            "reveal",
            "expose",
            "uncensor"
          ],
          "register": "formal",
          "domain": [
            "general",
            "law",
            "government",
            "media"
          ]
        }
      ]
    },
    {
      "term": "redaction",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process of editing a document to remove or obscure sensitive information; a version of a text with such removals",
          "examples": [
            "The redaction of the report prevented the release of personal details.",
            "Many government documents require redaction before public access."
