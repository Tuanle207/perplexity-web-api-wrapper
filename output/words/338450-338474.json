      "term": "rouming",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "the act or practice of using a mobile phone while traveling abroad and using another country’s network to avoid high roaming charges",
          "examples": [
            "He turned off data roaming to avoid high costs while abroad.",
            "Roaming can be expensive without an international plan."
          ],
          "collocations": ["roaming charges", "data roaming", "international roaming", "roaming agreement"],
          "synonyms": ["international roaming", "roaming usage"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "general", "business"]
