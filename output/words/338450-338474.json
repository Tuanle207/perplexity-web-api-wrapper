    {
      "term": "round",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having a shape like a circle; not square or angular",
          "examples": [
            "She cut the cookie into a round shape.",
            "The round table seated six people."
          ],
          "collocations": ["round shape", "round table", "round object", "round corner"],
          "synonyms": ["circular", "spherical", "curved"],
          "antonyms": ["square", "angular"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "one complete orbit or sequence; a group or cycle",
          "examples": [
            "We went around the round of meetings.",
            "He won the first round of the competition."
          ],
          "collocations": ["first round", "round of applause", "round table", "quarter round"],
          "synonyms": ["cycle", "sequence", "lap"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "education", "entertainment"]
        },
        {
          "pos": "verb",
          "definition": "to move or cause to move in a circular direction or to make something into a circle",
          "examples": [
            "The car rounded the bend.",
            "She rounded the dough into a ball."
          ],
          "collocations": ["round the corner", "round off", "round up", "round the bend"],
          "synonyms": ["go around", "circulate", "bend around"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "technology"]
        }
      ]
    },
    {
