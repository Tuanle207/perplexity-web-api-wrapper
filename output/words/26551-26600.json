    {
      "term": "athymia",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A medical condition in which a person has no thymus gland, usually causing serious problems with the immune system.",
          "examples": [
            "Congenital athymia is diagnosed soon after birth because the baby has no functioning thymus gland.",
            "Children with athymia often suffer from repeated, severe infections.",
            "Doctors monitor T‑cell counts closely in patients with athymia."
          ],
          "collocations": [
            "congenital athymia",
            "absence of the thymus",
            "athymia diagnosis",
            "severe immunodeficiency in athymia",
            "athymia treatment",
            "athymia patients",
            "athymia syndrome"
          ],
          "synonyms": [
            "congenital athymia",
            "thymus agenesis"
          ],
          "antonyms": [
            "normal thymus",
            "euthymic thymus"
          ],
          "register": "formal",
          "domain": [
            "medicine"
          ]
        },
        {
