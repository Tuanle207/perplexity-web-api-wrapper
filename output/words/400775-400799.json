      "term": "tip",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "a small piece of advice or a hint about something you should do",
          "examples": ["Take a tip from a friend; they know this area well."],
          "collocations": ["a tip", "give a tip", "tip about", "handy tip", "hot tip"],
          "synonyms": ["hint", "suggestion", "advice"],
          "antonyms": ["instruction", "order"],
          "register": "informal",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "a small pointed end or projection, such as on a tool or object",
          "examples": ["The tip of the knife is very sharp.", "He touched the tip of the pen."],
          "collocations": ["tip of the tongue", "tip of the iceberg", "sharp tip", "needle tip"],
          "synonyms": ["point", "end", "apex"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "technology"]
        },
        {
          "pos": "verb",
          "definition": "to tilt or tilt slightly; to tilt or incline in a direction",
          "examples": ["The boat tipped to one side.", "He tipped the glass to pour the liquid."],
          "collocations": ["tip over", "tip up", "tip back"],
          "synonyms": ["tilt", "lean", "incline"],
          "antonyms": ["level", "straighten"],
          "register": "informal",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to give a tip or gratuity to someone who provides a service",
          "examples": ["We tipped the waiter generously.", "She tipped the taxi driver."],
          "collocations": ["tip someone", "tip at the end", "tip well"],
          "synonyms": ["gratuity", "give a tip", "gratuate (informal)"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "service"]
        }
      ]
