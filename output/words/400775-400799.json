      "term": "tipoff",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "a warning or hint given in advance about something that will happen",
          "examples": ["The announcement was a tip-off about the surprise party."],
          "collocations": ["tip-off about", "crime tip-off", "police tip-off"],
          "synonyms": ["warning", "hint", "forewarning"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "news", "law"]
        },
        {
          "pos": "noun",
          "definition": "a notice or brief information given to someone before a game or event to start play",
          "examples": ["The team got a tip-off before the match."],
          "collocations": ["tip-off time", "kick-off (in sports)"],
          "synonyms": ["signal", "intimation"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["sports", "general"]
        },
        {
          "pos": "verb",
          "definition": "to give a tip-off about something",
          "examples": ["The journalist tipped off the police about the plan."],
          "collocations": ["tip off the authorities", "tip off someone"],
          "synonyms": ["warn", "inform"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "law"]
        }
      ]
