      "term": "prosaist",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a writer of prose; a person who composes ordinary written text as opposed to poetry",
          "examples": [
            "The novel's prosaist was praised for its clear, uncluttered style.",
            "As a prosaist, she focuses on character and plot rather than poetic devices."
          ],
          "collocations": [
            "novelist and prosaist",
            "prosaist craft",
            "read like prosaist prose"
          ],
          "synonyms": ["writer", "author", "prose writer"],
          "antonyms": [],
          "register": "formal",
          "domain": ["literature", "general"]
        }
      ]
