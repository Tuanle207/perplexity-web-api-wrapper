      "term": "serologist",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a scientist who studies blood and other body fluids, often using immunology tests.",
          "examples": [
            "A serologist examined the blood samples in the lab.",
            "The serologist looked for antibodies in the patient’s serum."
          ],
          "collocations": [
            "forensic serologist",
            "clinical serologist",
            "blood sample",
            "body fluids",
            "laboratory test",
            "immunological reactions"
          ],
          "synonyms": [
            "immunologist (in some contexts)",
            "lab scientist (general)"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine",
            "academic"
          ]
        }
      ]
