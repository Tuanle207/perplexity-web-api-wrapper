      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "The state of being rabid; extreme, intense, or fanatic behavior or emotions.",
          "examples": [
            "The rabidity of his political debates surprised everyone.",
            "Her rabidity for sports was evident from a young age."
          ],
          "collocations": ["rabidity of passion", "rabidity toward", "rabidity in debates"],
