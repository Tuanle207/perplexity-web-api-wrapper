    {
      "term": "rabi",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A Hindu or Indian religious leader or teacher, or a title used for a respected religious scholar; in some contexts, refers to a rabbi in Jewish tradition, though less common.",
          "examples": [
            "The village invited their local rabi to lead the ceremony.",
            "She studied under a renowned rabi to learn Jewish laws."
          ],
          "collocations": ["rabi", "rabbinic", "rabbi", "religious leader"],
          "synonyms": ["rabbi (Jewish), religious teacher"],
          "antonyms": [],
          "register": "formal",
          "domain": ["religion", "culture"]
        }
      ]
    },
