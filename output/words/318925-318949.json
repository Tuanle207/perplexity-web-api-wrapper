      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Having or proceeding from rabies; extremely fanatical or filled with intense enthusiasm or violence.",
          "examples": [
            "The dog appeared rabid after being attacked.",
            "He became rabid in his opposition to the new policy."
          ],
          "collocations": ["rabid dog", "rabid fan", "rabid anger", "rabid supporter"],
          "synonyms": ["ferocious", "rabies-infected", "fanatical"],
          "antonyms": ["calm", "moderate", "rabies-free"],
