    {
      "term": "recollectedness",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state or quality of having been recollected, or the degree to which something is remembered or recalled clearly",
          "examples": [
            "His recollectedness faded as the old memories resurfaced.",
            "The speaker spoke with a renewed recollectedness about the events."
          ],
          "collocations": [
            "a sense of recollectedness",
            "in recollectedness",
            "with recollectedness"
          ],
          "synonyms": ["remembrance", "recall", "memory"],
          "antonyms": ["forgetfulness", "amnesia"],
          "register": "literary",
          "domain": ["general", "memory"]
        }
      ]
    },
