    {
      "term": "quest",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a long search for something, usually with many difficulties",
          "examples": [
            "The archaeologist began a quest for ancient artifacts.",
            "Her quest for truth led her to many hidden records."
          ],
          "collocations": ["futile quest", "unending quest", "quest for", "holy quest", "quest begins"],
          "synonyms": ["journey", "search", "mission"],
          "antonyms": ["arrival", "settled", "done"],
          "register": "neutral",
          "domain": ["general", "adventure", "literary"]
        },
        {
          "pos": "verb",
          "definition": "to search for or seek after something, especially something difficult to obtain",
          "examples": [
            "They quested for the perfect solution to the problem.",
            "Liberal arts students quest knowledge beyond the classroom."
          ],
          "collocations": ["quest for", "quest after", "quest to find"],
          "synonyms": ["seek", "search", "pursue"],
          "antonyms": ["ignore", "reject", "forget"],
          "register": "neutral",
          "domain": ["general", "education"]
        }
