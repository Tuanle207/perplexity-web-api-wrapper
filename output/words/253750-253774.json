      "term": "nonprotraction",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the absence of or avoidance of prolonging something, especially in relation to time or movement",
          "examples": [
            "The engineer sought nonprotraction of the project timeline to avoid wasted resources.",
            "A policy aimed at nonprotraction of disputes helps reduce conflict."
          ],
          "collocations": [
            "nonprotraction of time",
            "nonprotraction approach",
            "nonprotraction strategy"
          ],
          "synonyms": ["abbreviation of delay", "speeding up", "expedition (in context of time)"],
          "antonyms": ["protraction", "delay", "elongation"],
          "register": "formal",
          "domain": ["general", "business", "academic"]
        }
      ]
    },
