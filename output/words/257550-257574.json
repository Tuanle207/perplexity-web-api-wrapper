      "term": "nunatak",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a mountain peak that sticks up through ice or snow in a glacier or ice sheet",
          "examples": [
            "The expedition climbed the nunatak to get a view above the surrounding ice.",
            "Several nunataks were visible as the helicopter skimmed over the glacier."
          ],
          "collocations": [
            "glacier nunatak",
            "rocky nunatak",
            "exposed nunatak",
            "ice sheet nunatak",
            "summit nunatak"
          ],
          "synonyms": ["rock outcrop in ice", "isolated peak (in ice)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["geography", "science", "education"]
        }
      ]
    },
