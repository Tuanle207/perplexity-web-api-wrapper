  "items": [
    {
      "term": "settlement",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "an official agreement or a decision to end a disagreement, often involving money or a compromise",
          "examples": [
            "The two companies reached a settlement after the lawsuit.",
            "They paid a settlement to avoid going to court."
          ],
          "collocations": ["financial settlement", "settlement agreement", "out-of-court settlement", "settlement amount", "settlement with"],
          "synonyms": ["accord", "agreement", "compromise", "conciliation"],
          "antonyms": ["dispute", "conflict", "litigation"],
          "register": "formal",
          "domain": ["general", "legal"]
        },
        {
          "pos": "noun",
          "definition": "a place where people establish a community to live, often a small community or town",
          "examples": [
            "The frontier settlement grew into a thriving town.",
            "They built a new settlement along the river."
          ],
          "collocations": ["new settlement", "frontier settlement", "settlement site", "colonial settlement"],
          "synonyms": ["colony", "community", "colony"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["geography", "history", "general"]
        },
        {
          "pos": "noun",
          "definition": "the act of paying attention or coming to a decision on a matter",
          "examples": [
            "There was a settlement of the argument after a long discussion.",
            "Her settlement on the budget plan surprised everyone."
          ],
          "collocations": ["settlement of accounts", "settlement on a matter", "achieve settlement"],
          "synonyms": ["resolution", "conclusion", "decision"],
          "antonyms": ["ignoring", "delaying"],
          "register": "formal",
          "domain": ["general", "business"]
        }
