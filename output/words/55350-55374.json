    {
      "term": "campaign",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a planned series of activities or actions intended to achieve a particular goal, especially in politics or advertising",
          "examples": [
            "The presidential campaign lasted six months.",
            "They launched a campaign to promote recycling.",
            "Advertising campaigns aim to increase brand awareness."
          ],
          "collocations": ["election campaign", "marketing campaign", "PR campaign", "fundraising campaign", "campaign strategy"],
          "synonyms": ["drive", "operation", "effort", "initiative"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "politics", "business", "marketing"]
        },
        {
          "pos": "verb",
          "definition": "to organize or participate in a campaign; to urge others to support a cause or candidate",
          "examples": [
            "Activists campaigned for stricter environmental laws.",
            "The party campaigned across the country.",
            "Volunteers campaigned to raise awareness."
