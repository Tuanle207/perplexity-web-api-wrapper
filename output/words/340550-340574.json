      "term": "sacrilegist",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who commits sacrilege; someone who treats sacred things with disrespect",
          "examples": [
            "The sacrilegist vandalized the sacred temple artifacts.",
            "Many considered him a sacrilegist for desecrating the relic."
          ],
          "collocations": [
            "romantic sacrilegist",
            "self-proclaimed sacrilegist",
            "accused sacrilegist"
          ],
          "synonyms": ["blasphemer", "desecrator", "profaner"],
          "antonyms": ["reverent person", "devotee", "sanctifier"],
          "register": "formal",
          "domain": ["general", "law"] 
        }
      ]
    },
