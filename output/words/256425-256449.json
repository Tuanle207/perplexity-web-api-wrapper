      "term": "nosophobia",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "an extreme or irrational fear of disease or illness",
          "examples": [
            "She developed nosophobia after reading about rare infections online.",
            "His nosophobia made him avoid public places during flu season."
          ],
          "collocations": [
            "develop nosophobia",
            "suffer from nosophobia",
            "treat nosophobia",
            "fear of disease"
          ],
          "synonyms": [
            "fear of illness",
            "illness anxiety"
          ],
          "antonyms": [
            "calmness about health",
            "health confidence"
          ],
          "register": "neutral",
          "domain": ["medical", "mental_health", "everyday"]
        }
