      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A small but important detail that differentiates similar things or adds subtle meaning.",
          "examples": [
            "The painting lacks nuance in color.",
            "She explained the nuances of the language."
          ],
          "collocations": ["nuance of", "subtle nuance", "cultural nuance"],
          "synonyms": ["subtlety", "shade", "refinement"],
          "antonyms": ["bluntness", "coarseness"],
          "register": "formal",
          "domain": ["general", "arts"]
        },
        {
          "pos": "verb",
          "definition": "To distinguish or express subtle differences in meaning, tone, or expression.",
          "examples": [
            "The speaker nuanced the argument with careful qualifiers."
