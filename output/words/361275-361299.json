  "items": [
    {
      "term": "slick",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "smooth and glossy in appearance or texture",
          "examples": [
            "The car had a slick, polished finish.",
            "She wore a slick, glossy hairstyle."
          ],
          "collocations": [
            "slick surface",
            "slick hair",
            "slick design",
            "slick finish",
            "slick and professional"
          ],
          "synonyms": ["glossy", "sleek", "shiny"],
          "antonyms": ["matte", "rough", "dull"],
          "register": "formal",
          "domain": ["general", "fashion", "design"]
        },
        {
          "pos": "noun",
          "definition": "a person who is very smooth or stylish in manner; a clever or persuasive person",
          "examples": [
            "He's a real slick, always talking his way out of trouble.",
            "The ad salesman is a smooth slick who knows how to close a deal."
          ],
          "collocations": [
            "slick operator",
            "slick talk",
            "slick salesmanship"
          ],
          "synonyms": ["smooth-talker", "hustler", "conniver"],
          "antonyms": ["boor", "clumsy person"],
          "register": "informal",
          "domain": ["general", "business", "media"]
        },
        {
          "pos": "verb",
          "definition": "to make something smooth and glossy or to make slick by applying oil or polish",
          "examples": [
            "He slicked the bicycle chain to reduce friction.",
            "She slicked back her hair with gel."
          ],
          "collocations": [
            "slick back",
            "slick down",
            "slicked hair",
            "slick finish"
          ],
          "synonyms": ["polish", "buff", "shine"],
          "antonyms": ["roughen", "matte"],
          "register": "neutral",
          "domain": ["general", "fashion", "maintenance"]
        }
      ]
    },
