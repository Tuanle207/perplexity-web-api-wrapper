      "term": "ariboflavinosis",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A disease caused by not having enough vitamin B2 (riboflavin), usually showing sores and cracks around the mouth and other skin and eye problems.",
          "examples": [
            "The doctor diagnosed the patient with ariboflavinosis after seeing cracks at the corners of his mouth and inflamed lips.",
            "Ariboflavinosis can develop in people whose diets are very low in vitamin B2.",
            "Improving nutrition and giving vitamin supplements usually cures ariboflavinosis."
          ],
          "collocations": [
            "vitamin B2 ariboflavinosis",
            "riboflavin deficiency ariboflavinosis",
            "symptoms of ariboflavinosis",
            "diagnose ariboflavinosis",
            "treat ariboflavinosis",
            "clinical ariboflavinosis",
            "severe ariboflavinosis"
          ],
          "synonyms": [
            "riboflavin deficiency"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine",
            "nutrition"
