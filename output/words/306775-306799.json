      "term": "pretranscribe",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to transcribe something before a reference or source is available, or to prepare a transcription in advance",
          "examples": ["The editor asked the researcher to pretranscribe the interview data.", "We will pretranscribe all audio recordings before the analysis stage."],
          "collocations": ["pretranscribe the notes", "pretranscribe data", "pretranscribe interviews"],
          "synonyms": ["prewhile transcription", "preliminary transcription"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
