    {
      "term": "pout",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a projecting part of the mouth of a bird or animal; a pout is a tubular mouthful of air and can also refer to the act of pouting lips.",
          "examples": ["The duck shook its head and its pout opened slightly.", "She stuck out her lip in a pout."],
          "collocations": ["pout lip", "fish pout", "pout of frustration"],
          "synonyms": ["lip", "moue"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "biology"]
        },
        {
          "pos": "verb",
          "definition": "to push out one's lips in displeasure or sulkiness.",
          "examples": ["She pouted when she didn’t get her way.", "The child pouted, but soon smiled."],
          "collocations": ["pout, sulk", "pout lips", "pout in disappointment"],
          "synonyms": ["sulk", "moue"],
          "antonyms": ["smile", "smirk"],
          "register": "informal",
          "domain": ["general"]
        }
      ]
    },
    {
      "term": "pouted",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "expressed displeasure or annoyance by protruding the lips.",
          "examples": ["She pouted when she heard the news.", "The child pouted but eventually agreed."],
          "collocations": ["pouted softly", "pouted in frustration", "pout (past tense)"],
          "synonyms": ["sulked", "moaned"],
          "antonyms": ["smiled", "grinned"],
          "register": "informal",
          "domain": ["general"]
        }
      ]
