      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "at times; now and then, but not always",
          "examples": [
            "Sometimes I skip breakfast and wait until lunch.",
            "She sometimes goes to the gym after work."
          ],
          "collocations": ["sometimes", "often", "occasionally", "every now and then", "these days"],
