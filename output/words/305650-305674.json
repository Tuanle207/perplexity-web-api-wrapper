      "term": "preregistration",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the action of registering in advance, typically for an event, program, or service",
          "examples": [
            "Participants completed preregistration before the conference.",
            "Preregistration helps organizers estimate attendance."
