            "preregistration process",
            "online preregistration",
            "mandatory preregistration"
          ],
          "synonyms": ["advance registration", "pre-registration"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "events", "business"]
        }
      ]
    },
