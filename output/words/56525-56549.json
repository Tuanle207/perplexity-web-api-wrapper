    {
      "term": "cap",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A protective or decorative top for the head or a bottle; also a limit or reach.",
          "examples": [
            "Put on your cap before you go outside.",
            "The price cap is set at 100 euros.",
            "He popped the cap off the bottle."
          ],
          "collocations": ["cap", "cap itself", "baseball cap", "cap size", "reach cap"],
          "synonyms": ["lid (for container)", "hat (for head)", "limit (figurative)"],
          "antonyms": ["base", "floor", "bottom"],
          "register": "informal",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "noun",
          "definition": "A maximum limit or upper bound in a rule or policy.",
          "examples": [
            "The tax rate has a cap at 50%.",
            "There is a cap on how much you can withdraw daily."
          ],
          "collocations": ["salary cap", "cap on", "cap amount"],
          "synonyms": ["limit", "ceiling"],
          "antonyms": ["floor", "minimum"],
          "register": "formal",
          "domain": ["general", "business"]
        },
        {
          "pos": "verb",
          "definition": "To cover or close with a cap; to limit or restrain.",
          "examples": [
            "Cap the nozzle to prevent spills.",
            "The company capped the price to protect consumers."
          ],
          "collocations": ["cap off", "cap at", "cap price"],
          "synonyms": ["restrict", "limit", "top"],
          "antonyms": ["increase", "raise"],
          "register": "neutral",
          "domain": ["general", "business"]
        }
      ]
    },
