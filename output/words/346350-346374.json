      "term": "sclerotized",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "hardened or made firm by the formation of scleroids (scleroprotein) in the plant or animal tissue",
          "examples": ["The insect exoskeleton becomes sclerotized after metamorphosis."],
          "collocations": ["sclerotized exoskeleton", "sclerotized tissue", "sclerotized plate"],
          "synonyms": ["hardened", "rigidified"],
          "antonyms": ["softened", "unhardened"],
          "register": "neutral",
          "domain": ["biology", "anatomy", "general"]
        }
      ]
    },
