      "term": "prefigures",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to give an early or partial indication of something that will happen or be seen later",
          "examples": [
            "The dark clouds prefigure a storm.",
            "Her success prefigures the impact she will have in the industry."
          ],
          "collocations": ["prefigure a trend", "prefigure the outcome", "often prefigure"],
          "synonyms": ["foreshadow", "prefigure", "indicate"],
          "antonyms": ["obscure", "conceal", "deny"],
          "register": "formal",
          "domain": ["general", "literary"]
        }
      ]
    },
