      "term": "proplasm",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a hypothetical or rare biological term likely referring to early or primitive cellular material related to protoplasm, not standard in contemporary English biology terminology",
          "examples": [
            "The researcher discussed proplasm in a speculative context, noting it is not a widely adopted term.",
            "Some texts might confuse proplasm with protoplasm, though proplasm is not commonly used."
          ],
          "collocations": [
            "cell biology",
            "hypothetical proplasm",
            "early proplasm"
          ],
          "synonyms": [],
          "antonyms": [],
          "register": "null",
          "domain": ["science", "academic"]
        }
      ]
    },
