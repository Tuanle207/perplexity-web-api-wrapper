    {
      "term": "pugnaciousness",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being aggressively combative or eager to fight",
          "examples": ["His pugnaciousness made him quick to challenge anyone who disagreed."],
          "collocations": ["display pugnaciousness", "settle by pugnaciousness", "pugnaciousness and intimidation"],
          "synonyms": ["belligerence", "aggressiveness", "combativeness"],
          "antonyms": ["pacifism", "meekness", "placidity"],
          "register": "formal",
          "domain": ["general", "character"]
        }
      ]
    },
