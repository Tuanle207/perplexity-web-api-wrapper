      "term": "appropriator",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who takes something for their own use, often without permission",
          "examples": ["The artist was accused of being an appropriator of others' work."],
          "collocations": ["cultural appropriator", "resource appropriator", "art appropriator"],
          "synonyms": ["taker", "seizer", "borrower"],
          "antonyms": ["giver", "donor"],
          "register": null,
          "domain": ["general", "art"]
        }
      ]
