  "items": [
    {
      "term": "pretension",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of claiming or pretending to have a quality, status, or achievement that is not genuinely possessed",
          "examples": [
            "Her pretension to expertise was obvious to anyone who listened.",
            "The film critiques the pretension of the art world."
          ],
          "collocations": [
            "false pretension",
            "air of pretension",
            "social pretension",
            "pretension to authority",
            "notions of pretension"
          ],
          "synonyms": ["pose", "affectation", "show", "feigning"],
          "antonyms": ["humility", "authenticity", "sincerity"],
          "register": "formal",
          "domain": ["general", "arts_coculture"]
        }
      ]
    },
