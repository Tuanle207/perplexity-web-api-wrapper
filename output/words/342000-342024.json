          "collocations": [
            "Samnite people",
            "Samnite warrior",
            "Samnite tribe",
            "Samnite culture"
          ],
          "synonyms": ["Italic tribe", "ancient Italian people"],
          "antonyms": [],
          "register": "formal",
          "domain": ["history", "general"]
        },
        {
