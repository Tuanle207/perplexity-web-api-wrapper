    {
      "term": "recovery",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process of returning to a normal state after a illness, injury, or difficult situation; the act of getting back something that was lost or stolen",
          "examples": [
            "She made a full recovery after the surgery.",
            "The recovery of the data from the damaged drive was slow but successful.",
            "Economic recovery is expected to take several quarters."
          ],
          "collocations": [
            "full recovery",
            "slow recovery",
            "rapid recovery",
            "physical/mental recovery",
            "economic recovery",
            "recovery period",
            "post-recovery"
          ],
          "synonyms": [
            "improvement",
            "restoration",
            "return"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": ["medicine", "general", "economy"]
        },
        {
          "pos": "noun",
          "definition": "the act of recovering something, such as data, assets, or a person who has been abducted",
          "examples": [
            "The recovery of the stolen paintings was announced today.",
            "They are tracking the recovery of the hostages.",
            "Data recovery from the backup after the crash was essential."
          ],
          "collocations": [
            "data recovery",
            "asset recovery",
            "economic recovery",
            "recovery of funds",
            "police recovery"
          ],
          "synonyms": [
            "repatriation",
            "retrieval",
            "rescue"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": ["law", "business", "general"]
        }
      ]
    },
