    {
      "term": "snafus",
      "kind": "plural_noun",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a situation in which many things go wrong or fail at the same time; a mess or complication",
          "examples": [
            "We faced several snafus during the conference planning.",
            "The project hit multiple snafus, delaying its completion by weeks."
          ],
          "collocations": ["administrative snafus", "logistical snafu", "major snafu", "unavoidable snafus"],
          "synonyms": ["glitch", "snag", "hitch", "problem", "setback"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "business", "everyday"]
        }
      ]
    },
