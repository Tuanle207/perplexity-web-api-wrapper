      "term": "nonprovocatively",
      "kind": "adverb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a manner that does not provoke or arouse strong reactions or controversy",
          "examples": [
            "She spoke nonprovocatively to avoid offending anyone.",
            "The advertisement was written nonprovocatively to appeal to a broad audience."
          ],
          "collocations": [
            "speak nonprovocatively",
            "act nonprovocatively",
            "present nonprovocatively"
          ],
          "synonyms": ["calmly", "inoffensively", "moderately"],
          "antonyms": ["provocatively", "shockingly", "boldly"],
          "register": "neutral",
          "domain": ["general", "communication"]
        }
      ]
    },
