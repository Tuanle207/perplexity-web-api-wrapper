          "collocations": ["scrying", "scrying mirror", "scry into", "scry for"],
          "synonyms": ["divine", "foretell", "predict"],
          "antonyms": ["ignore", "doubt"],
          "register": "informal",
          "domain": ["general", "everyday"]
        }
      ]
