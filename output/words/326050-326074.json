      "term": "refill",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to fill something again or anew, especially by removing an empty container and putting in more of a substance",
          "examples": [
            "Please refill my glass with water.",
            "She refilled the printer with ink."
          ],
          "collocations": ["refill the bottle", "refill a prescription", "refill with water"],
          "synonyms": ["top up", "replenish", "recharge"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "noun",
          "definition": "the act of filling something again; a new supply of something put into a container",
          "examples": [
            "I bought a coffee refill at the cafe.",
            "Keep the refill for later use."
