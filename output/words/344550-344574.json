      "term": "scant",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Barely sufficient in amount or size; not enough.",
          "examples": [
            "We have a scant supply of food for the trip.",
            "Her replies were scant and showed little interest."
          ],
          "collocations": ["scant amount", "scant resources", "scant evidence", "scant respect"],
          "synonyms": ["meager", "sparse", "insufficient"],
          "antonyms": ["plentiful", "ample", "abundant"],
          "register": "neutral",
          "domain": ["general", "everyday", "business"]
        },
        {
          "pos": "verb",
          "definition": "To move or provide in a small or insufficient amount; to estimate narrowly.",
          "examples": [
            "The report scants the data needed for a decision.",
            "They scant the witnesses who could confirm the facts."
          ],
          "collocations": ["scant attention", "scant evidence", "scant resources"],
          "synonyms": ["skimp", "scrimp", "begrudge"],
          "antonyms": ["enrich", "increase", "provision"],
          "register": "neutral",
          "domain": ["general", "business"]
        },
        {
          "pos": "noun",
          "definition": "An insufficient or small amount; a lack.",
          "examples": [
            "There is scant of proof to support the claim.",
            "She spoke with scant of confidence."
          ],
          "collocations": ["scant of", "scant evidence", "scantiness"],
          "synonyms": ["scarcity", "shortage", "deficiency"],
          "antonyms": ["parity", "plenty", "abundance"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
