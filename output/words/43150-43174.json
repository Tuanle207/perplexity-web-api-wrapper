          "antonyms": [
            "curse"
          ],
          "register": "formal",
          "domain": ["religion", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to say “good health” or “good luck” to someone, especially after they sneeze",
          "examples": [
            "“Bless you,” he said when she sneezed.",
            "When I sneezed, my dad always said, “Bless you.”"
          ],
          "collocations": [
            "say bless you",
            "after a sneeze",
            "bless someone",
