      "term": "bless",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to say a prayer or ask for God’s help and protection for someone",
          "examples": [
            "We blessed the food before we ate.",
            "The priest blessed the family."
          ],
          "collocations": [
            "bless someone",
            "bless the food",
            "bless the hands",
            "bless a child",
            "bless you"
          ],
          "synonyms": [
