      "term": "pyrrhic",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a metrical foot with two short or unstressed syllables followed by a long or stressed syllable",
          "examples": ["In poetry, a pyrrhic foot consists of two unstressed syllables followed by a stressed syllable."],
          "collocations": ["pyrrhic meter", "pyrrhic foot", "metrical foot"],
          "synonyms": ["unaccented–unstressed foot (in some analyses)"],
          "antonyms": ["iamb", "trochee"],
          "register": "formal",
          "domain": ["literary", "academic"]
        },
        {
          "pos": "adjective",
          "definition": "relating to or produced by a pyrrhic meter; also describing something that is weak or punishingly costly in a figurative sense (e.g., a pyrrhic victory)",
          "examples": ["The victory was pyrrhic, leaving the army exhausted and ruined."],
          "collocations": ["pyrrhic victory", "pyrrhic cost", "pyrrhic defeat"],
          "synonyms": ["pyrrhic-style"],
          "antonyms": [],
          "register": "formal",
          "domain": ["literary", "general"]
        }
      ]
    },
