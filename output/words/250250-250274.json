      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state or policy of not having or enforcing armaments, especially weapons and military forces",
          "examples": [
            "The treaty called for worldwide nondisarmament.",
            "Debates about nondisarmament often focus on national security."
