      "term": "pull",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to apply force to move something toward yourself or in a particular direction",
          "examples": [
            "She pulled the door open.",
            "The horse pulled the cart.",
            "He pulled the loose thread from the sweater."
          ],
          "collocations": ["pull a door", "pull hard", "pull the plug", "pull up", "pull together"],
          "synonyms": ["tug", "drag", "haul"],
          "antonyms": ["push"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "noun",
          "definition": "a force that causes something to move toward you or in a direction",
          "examples": [
            "The pull of gravity keeps us on the ground.",
            "There is a strong pull toward the positive side of the debate."
          ],
          "collocations": ["pull of gravity", "magnetic pull", "pull factor"],
          "synonyms": ["draw", "attraction"],
          "antonyms": ["push"],
          "register": "neutral",
          "domain": ["science", "general"]
        },
        {
          "pos": "adjective",
