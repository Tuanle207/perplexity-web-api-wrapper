    {
      "term": "prong",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A separate point or sharp part that sticks out from a main object, like teeth on a fork or a branch on a tool.",
          "examples": [
            "She cleaned the food from between the prongs of the fork.",
            "The hedge trimmer has several long prongs."
          ],
          "collocations": ["fork prong", "tine", "prong of a fork", "prong tip", "sharp prong"],
          "synonyms": ["tine", "point", "spike"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "kitchen", "tools"]
        },
        {
          "pos": "noun",
          "definition": "One of the parts of a fork or similar tool; a prong is a pointed projection.",
          "examples": [
            "Remove the meat from the fork's prongs.",
            "The antler has two main prongs."
          ],
          "collocations": ["prong shape", "prong length"],
          "synonyms": ["tine", "point"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "biology"]
        },
        {
          "pos": "verb",
          "definition": "To make or become sharp or pointed like a prong; to fork or split.",
          "examples": [
            "The path pronged into two trails.",
            "The river pronged into several channels."
