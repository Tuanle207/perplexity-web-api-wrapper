      "term": "sensationalisms",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the use of sensational methods or language to provoke public interest or excitement",
          "examples": [
            "The newspaper was accused of sensationalisms to boost sales.",
            "His speech was filled with sensationalisms rather than factual details."
          ],
          "collocations": [
            "political sensationalisms",
            "media sensationalisms",
            "sensationalisms in journalism",
            "avoid sensationalisms"
          ],
          "synonyms": ["exaggeration", "hype", "drama"],
          "antonyms": ["sobriety", "restraint"],
          "register": "formal",
          "domain": ["media", "journalism", "general"]
        }
      ]
    },
