    {
      "term": "proleptics",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of proleptic; things that anticipate or represent the future as already real, often used in philosophy or rhetoric",
          "examples": [
            "Some theories invoke proleptics to describe present experiences imagined as future outcomes.",
            "In their metaphor, the narrator uses proleptics to foreshadow events."
          ],
          "collocations": [
            "proleptic reasoning",
            "proleptic interpretation",
            "proleptic gesture"
          ],
          "synonyms": ["foreshadowing", "anticipation (in a literary sense)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "literary"]
        }
      ]
    },
    {
