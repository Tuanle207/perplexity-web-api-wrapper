      "term": "preeclampsia",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "A serious pregnancy condition marked by high blood pressure and protein in the urine, potentially causing swelling and organ problems.",
          "examples": [
            "Preeclampsia can develop after the 20th week of pregnancy.",
            "Early diagnosis of preeclampsia is important for the safety of both mother and baby."
          ],
          "collocations": [
            "preeclampsia risk",
            "preeclampsia during pregnancy",
            "preeclampsia diagnosis",
            "severe preeclampsia",
            "preeclampsia treatment"
          ],
          "synonyms": ["toxemia (old usage)", "hypertensive disorder of pregnancy"],
          "antonyms": [],
          "register": "formal",
          "domain": ["medicine", "healthcare", "general"]
        }
      ]
    },
