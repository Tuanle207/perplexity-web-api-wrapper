    {
      "term": "pretty",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "pleasing to the senses; attractive or nice in appearance",
          "examples": ["She wore a pretty dress for the party.", "The garden looked pretty in the spring sunshine."],
          "collocations": ["pretty girl", "pretty good", "pretty little", "pretty much", "pretty soon"],
          "synonyms": ["attractive", "lovely", "beautiful"],
          "antonyms": ["ugly", "unattractive"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "adv",
          "definition": "to a moderately high degree; quite",
          "examples": ["The movie was pretty good.", "It's pretty cold outside today."],
          "collocations": ["pretty well", "pretty much", "pretty enough"],
          "synonyms": ["quite", "fairly", "somewhat"],
          "antonyms": ["barely", "hardly"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "noun",
          "definition": "a term of endearment or a term used to refer to an attractive person (informal)",
          "examples": ["Hey, pretty, can you help me with this?"], 
          "collocations": ["pretty friend", "pretty face", "pretty person"],
          "synonyms": ["beauty", "hottie"],
          "antonyms": [],
          "register": "informal",
          "domain": ["everyday"]
