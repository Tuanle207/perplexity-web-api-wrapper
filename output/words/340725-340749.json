      "term": "saeculum",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "A long period of time, often described as the length of a human generation; a term used in historical or theological contexts to denote an era.",
          "examples": [
            "The empire lasted for several saecula before the region changed hands.",
            "In chronicles, these events occurred across multiple saecula."
          ],
          "collocations": ["long saeculum", "saecular time", "historical saeculum"],
          "synonyms": ["generation", "era", "epoch"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "general"]
