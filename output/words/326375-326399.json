      "term": "refractedness",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality or state of being refracted, or the degree to which something is bent or diverted by refraction",
          "examples": ["The refractedness of the light made the beam appear shifted."],
          "collocations": ["degree of refractedness", "level of refractedness", "refractedness of light"],
          "synonyms": ["bentness (figurative)", "diversion (less common)"],
          "antonyms": ["unbentness", "directness"],
          "register": "neutral",
          "domain": ["science", "general"]
        }
      ]
    },
