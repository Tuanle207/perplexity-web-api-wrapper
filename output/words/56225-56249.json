    {
      "term": "canonization",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act or process of declaring someone a saint in a formal religious procedure",
          "examples": [
            "The canonization of the saint took place after many verified miracles were documented.",
            "Historical records describe the rapid canonization process in the early church."
          ],
          "collocations": [
            "sainthood through canonization",
            "process of canonization",
            "official canonization ceremony",
            "miracles required for canonization",
            "decline in canonization ethics"
          ],
          "synonyms": ["deification (in a religious sense)", "encomiation (less common)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["religion", "general"]
        }
      ]
    },
