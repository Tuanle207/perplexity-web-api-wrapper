    {
      "term": "numb",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Having lost the ability to feel pain or to feel sensation; also feeling nothing or little emotionally.",
          "examples": [
            "Her fingers were numb from the cold.",
            "He stood there with numb hands, unable to move."
          ],
          "collocations": [
            "numb with",
            "completely numb",
            "feel numb",
            "numb the pain"
          ],
          "synonyms": ["unfeeling", "insensitive", "senseless"],
          "antonyms": ["sensitive", "feeling", "tactile"],
          "register": "neutral",
          "domain": ["general", "everyday", "medicine"]
        },
        {
          "pos": "verb",
          "definition": "To cause to lose sensation or feeling, or to become insensitive.",
          "examples": [
            "Cold water can numb the fingers.",
            "The anesthetic will numb the area before the procedure."
          ],
          "collocations": [
            "numb the surface",
            "numb the pain",
            "numb with cold"
          ],
          "synonyms": ["benumb", "deadening"],
          "antonyms": ["stimulate", "energize", "revive"],
          "register": "neutral",
          "domain": ["medical", "everyday"]
        }
      ]
    },
