            "numbed with anesthesia"
          ],
          "synonyms": ["benumbed", "insensitive"],
          "antonyms": ["sensitive", "feeling"],
          "register": "neutral",
          "domain": ["general", "medical"]
        },
        {
          "pos": "verb",
          "definition": "Past tense of numb; to cause to lose feeling or sensation.",
          "examples": [
            "The cold air numbed his fingers.",
            "The anesthetic numbed the area quickly."
          ],
          "collocations": [
            "numbed the room",
            "numbed his hands"
          ],
          "synonyms": ["benumbed"],
          "antonyms": ["reawakened", "stimulated"],
          "register": "neutral",
          "domain": ["general", "medical"]
        }
