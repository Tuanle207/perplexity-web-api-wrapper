      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "In a submissive or easily guided way; in a manner showing sequaciousness.",
          "examples": [
            "The student followed the instructor sequaciously.",
            "She nodded sequaciously at every suggestion."
          ],
          "collocations": ["sequaciously follow", "sequaciously accept"],
          "synonyms": ["submissively", "docilely", "obsequiously"],
          "antonyms": ["independently", "critically"],
          "register": "formal",
          "domain": ["education", "psychology"]
        }
