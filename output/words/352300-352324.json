      "term": "sequacious",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Having a ready or excessive readiness to be guided by others; submissive and eager to follow.",
          "examples": [
            "A sequacious pupil tends to imitate the teacher without question.",
            "Her sequacious nature made her accept every plan proposed by the group."
          ],
          "collocations": ["sequacious personality", "sequacious follower", "sequacious to authority"],
          "synonyms": ["submissive", "docile", "obedient"],
          "antonyms": ["independent", "independent-minded", "assertive"],
          "register": "formal",
          "domain": ["general", "education", "psychology"]
        }
      ]
    },
    {
