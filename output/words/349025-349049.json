{
  "items": [
    {
      "term": "secure",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "free from danger or risk; safe",
          "examples": [
            "Keep your valuables in a secure place.",
            "They felt secure after receiving confirmation."
          ],
          "collocations": ["secure position", "secure environment", "secure investment", "secure and stable", "securely fastened"],
          "synonyms": ["safe", "protected", "sound"],
          "antonyms": ["unsafe", "risky", "unsecured"],
          "register": "formal",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to make something safe or certain; to obtain or achieve something with effort",
          "examples": [
            "They secured a loan for the project.",
            "She secured the victory with a final goal.",
            "Please secure the lid before transporting."
          ],
          "collocations": ["secure funding", "secure a contract", "secure a place", "secure the perimeter", "securely fasten"],
          "synonyms": ["protect", "obtain", "acquire", "lock down"],
          "antonyms": ["expose", "endanger"],
          "register": "formal",
          "domain": ["business", "general", "everyday"]
        }
      ]
    },
