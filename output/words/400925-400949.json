      "term": "tirewoman",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "a female worker who helps customers with tires at a tire shop or service station",
          "examples": [
            "The tirewoman checked the pressure and replaced the worn tire.",
            "She worked as a tirewoman, guiding customers through tire choices."
          ],
          "collocations": ["tirewoman duties", "talking to customers", "mounting tires"],
          "synonyms": ["tire shop assistant", "tire technician (female)"],
          "antonyms": ["mechanic", "tire fitter (male)"],
          "register": "neutral",
          "domain": ["general", "business", "everyday"]
        }
      ]
    },
