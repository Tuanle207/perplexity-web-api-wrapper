      "term": "ting",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A sharp, metallic sound or a ringing tone.",
          "examples": [
            "I heard a ting as the bell rang.",
            "The spoon made a light ting on the glass."
          ],
          "collocations": ["ting of a bell", "ting sound", "tiny ting"],
          "synonyms": ["tinkle", "chime"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["everyday", "sound"]
        },
        {
          "pos": "verb",
          "definition": "To produce a light, metallic sound; to ring with a sharp sound.",
          "examples": [
            "Metal struck the plate and tinged.",
            "The coin tinged as it touched the rim."
          ],
          "collocations": ["ting on", "ting off"],
          "synonyms": ["tinkle", "ring"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["everyday", "sound"]
