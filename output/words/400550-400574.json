    {
      "term": "tinge",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A small amount of color or feeling; a slight trace of something.",
          "examples": [
            "A hint of pink gave the scarf a delicate tinge.",
            "Her remarks carried a tinge of sarcasm."
          ],
          "collocations": ["tinge of color", "tinge of bitterness"],
          "synonyms": ["trace", "hint", "tint"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "visual"]
        },
        {
          "pos": "verb",
          "definition": "To impart a small amount of color or quality to something.",
          "examples": [
            "The sunlight tinges the lake with gold.",
            "Her opinion was tinged with jealousy."
          ],
          "collocations": ["tinge with color", "tinge with emotion"],
          "synonyms": ["tint", "color"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general"]
