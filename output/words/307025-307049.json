          "collocations": ["previsit planning", "previsit checklist", "previsit to a site"],
          "synonyms": ["preview visit", "preliminary visit"],
          "antonyms": ["visit", "postvisit"],
          "register": "formal",
          "domain": ["general", "planning", "travel"]
        },
        {
          "pos": "verb",
          "definition": "to visit a place before a planned visit, in order to prepare or assess it.",
          "examples": ["They will previsit the gallery to set up the exhibit."],
