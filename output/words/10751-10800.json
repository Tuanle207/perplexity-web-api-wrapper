    {
      "term": "alodiality",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "The state or quality of land being owned completely, without owing rent or services to any higher lord or government.",
          "examples": [
            "The alodiality of the estate meant the owner did not pay feudal dues.",
            "In some historical systems, alodiality was rare and most land was held from a lord."
          ],
          "collocations": [
            "state of alodiality",
            "quality of alodiality",
            "enjoy alodiality",
            "true alodiality",
            "landed alodiality"
          ],
          "synonyms": [
            "absolute ownership",
            "allodial tenure"
          ],
          "antonyms": [
            "feudal tenure"
          ],
          "register": "formal",
          "domain": [
            "law",
            "history"
          ]
        }
      ]
    },
