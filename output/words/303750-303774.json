    {
      "term": "prefabricated",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "designed or manufactured in sections that can be assembled quickly at the building site",
          "examples": [
            "The house was built from prefabricated panels to speed up construction.",
            "They used prefabricated walls to reduce on-site labor."
          ],
          "collocations": ["prefabricated panels", "prefabricated housing", "prefabricated components", "prefabricated sections"],
          "synonyms": ["factory-made", "modular"],
          "antonyms": ["custom-built", "handmade"],
          "register": "formal",
          "domain": ["construction", "general", "technology"]
        }
      ]
    },
