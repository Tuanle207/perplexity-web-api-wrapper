      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "A rare or dialect word for a slough or underside of a slug; not common in modern English.",
          "examples": [
            "The old dialect speaker used the word sluer to describe a damp, slippery place."
