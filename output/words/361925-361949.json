    {
      "term": "slug",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A slow, lazy person; a dull, inert or sluggardly person.",
          "examples": [
            "Don’t be a slug, get up and finish your work.",
            "That slug of a mouse made no move."
          ],
          "collocations": [
            "lazy slug",
            "sluggard slug"
          ],
          "synonyms": ["slacker", "loafer"],
          "antonyms": ["active person", "go-getter"],
          "register": "informal",
          "domain": ["everyday"]
        },
        {
          "pos": "noun",
          "definition": "A bullet or a small, soft, pliable mass; also a unit of drink in a slug of whiskey.",
          "examples": [
            "Take a slug of water.",
            "He poured a slug of whiskey."
          ],
          "collocations": [
            "drink a slug",
            "slug of",
            "slugs of"
          ],
          "synonyms": ["mouthful", "draught"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general"]
        },
        {
          "pos": "verb",
          "definition": "To hit or strike someone or something, especially with a fist or blunt object; to punch.",
          "examples": [
            "He slugged him in the jaw.",
            "The car slugged through the debris."
          ],
          "collocations": [
            "slug someone",
            "slug a punch"
          ],
          "synonyms": ["punch", "strike"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general"]
        }
      ]
    },
