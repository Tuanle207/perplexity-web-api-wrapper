      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "A loose outer covering or loose material; also a dialect form of 'sluff' meaning loose dead skin or refuse.",
          "examples": [
            "The old cloak shed its sluff as it dried.",
            "He peeled away the sluff from the poster frame."
          ],
          "collocations": [
            "sluff off",
            "dusty sluff"
          ],
          "synonyms": ["sluff-off", "slough"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general"]
        },
        {
          "pos": "verb",
          "definition": "To shed or remove something loose or unwanted; to shed a layer.",
