          "synonyms": ["wake", "awaken", "stimulate"],
          "antonyms": ["put to sleep", "lull"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to excite or provoke a strong feeling or response",
