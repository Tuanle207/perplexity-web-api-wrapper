      "term": "abiosis",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A state or condition where there is no life.",
          "examples": [
            "Scientists studied the abiosis of the deep lunar surface where no life can survive.",
            "The extreme heat created a zone of abiosis in the experiment."
          ],
          "collocations": [
            "state of abiosis",
            "zone of abiosis",
            "area of abiosis",
            "complete abiosis",
            "conditions of abiosis"
          ],
          "synonyms": [
