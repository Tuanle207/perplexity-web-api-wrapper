      "term": "semistate",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a state that is not fully or officially established; a provisional condition or partial state of something",
          "examples": [
            "The project remains in a semistate of readiness, not quite completed.",
            "The agreement was in a semistate, pending final approval."
          ],
          "collocations": ["semi-state", "semistate of", "in a semistate"],
          "synonyms": ["preliminary state", "partial state", "provisional status"],
          "antonyms": ["full state", "final state", "complete status"],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
