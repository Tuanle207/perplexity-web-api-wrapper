    {
      "term": "snigger",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to laugh quietly in a suppressed or sly way, often at someone or something embarrassing or foolish",
          "examples": ["She sniggered at the politician's mistake.", "They sniggered behind their hands when he tripped."],
          "collocations": ["snigger quietly", "snigger at", "snigger to oneself", "snigger and gossip"],
          "synonyms": ["snicker", "titter", "laugh softly"],
          "antonyms": ["laugh openly", "guffaw", "roar with laughter"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
