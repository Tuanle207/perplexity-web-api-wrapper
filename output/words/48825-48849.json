      "term": "brickbats",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "criticism or insults aimed at someone",
          "examples": [
            "The editor dismissed the negative brickbats and praised the winning manuscript.",
            "Fans ignored the brickbats and celebrated the team's comeback."
          ],
          "collocations": [
            "receive brickbats",
            "throw brickbats",
            "harsh brickbats",
            "ruthless brickbats"
          ],
          "synonyms": ["criticism", "flak", "scolding", "abuse"],
          "antonyms": ["praise", "applause", "acclaim"],
          "register": "informal",
          "domain": ["general", "media", "critique"]
        }
      ]
    },
