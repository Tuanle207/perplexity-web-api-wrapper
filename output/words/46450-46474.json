            "persistent botherer"
          ],
          "synonyms": ["nuisance", "annoyance", "pebble in the shoe (idiom)"],
          "antonyms": ["benefactor", "helper", "supporter"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
