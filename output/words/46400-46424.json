    {
      "term": "botanizing",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "the activity of studying or collecting plants, especially by examining their features or collecting specimens",
          "examples": ["She spent the afternoon botanizing in the rainforest."],
          "collocations": ["botanizing in the garden", "botanizing for specimens", "botanizing trips"],
          "synonyms": ["plant hunting", "dendrology (less precise)", "herbarium collecting"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "hobby"]
        }
        ,
        {
          "pos": "noun",
          "definition": "the act of studying plants; the practice of collecting plant specimens for classification",
          "examples": ["Botanizing requires careful note-taking and labeling."],
          "collocations": ["botanizing activity", "methods of botanizing", "field of botanizing"],
          "synonyms": ["plant study", "phytology activity"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
