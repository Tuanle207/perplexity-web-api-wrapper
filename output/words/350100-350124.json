      "term": "semibourgeois",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "describing someone or something as somewhat bourgeois (middle-class and conventional) yet not fully so",
          "examples": [
            "The party attracted a semibourgeois crowd, not quite elite but comfortable with mainstream values."
          ],
          "collocations": [
            "semibourgeois attitude",
            "semibourgeois tastes",
            "semibourgeois values"
          ],
          "synonyms": ["bourgeois-influenced", "middle-class-ish"],
          "antonyms": ["bourgeois", "proletarian", "radical"],
          "register": "neutral",
          "domain": ["general", "society"]
        }
      ]
    },
