      "term": "semibreve",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the longest note value in the musical system used before modern notation, lasting four whole notes",
          "examples": [
            "In early Renaissance music, a semibreve usually lasts four minims.",
            "She wrote the melody with a semibreve held for four counts."
          ],
          "collocations": [
            "hold a semibreve",
            "play a semibreve rest",
