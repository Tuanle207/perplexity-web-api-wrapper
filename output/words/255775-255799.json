  "items": [
    {
      "term": "nonverifiable",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Not capable of being proven true or reliable beyond doubt.",
          "examples": [
            "The claim remains nonverifiable due to a lack of supporting data.",
            "In science, nonverifiable results should be treated with caution."
          ],
          "collocations": [
            "claim is nonverifiable",
            "nonverifiable evidence",
            "nonverifiable data"
          ],
          "synonyms": [
            "unverifiable",
            "unprovable",
            "unconfirmable"
          ],
          "antonyms": [
            "verifiable",
            "provable",
            "demonstrable"
          ],
          "register": "formal",
          "domain": ["general", "science", "academia"]
        }
      ]
    },
    {
