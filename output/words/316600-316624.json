      "term": "qanat",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "An underground channel or tunnel system that transports water from an aquifer to the surface for irrigation or drinking, typically built with shallow shafts along its length.",
          "examples": [
            "Villages relied on the qanat to bring water from the hillside to the fields.",
            "Ancient engineers built a qanat to survive dry seasons."
          ],
          "collocations": [
            "ancient qanat",
            "underground qanat",
            "qanat system",
            "dig a qanat",
            "water from a qanat"
          ],
          "synonyms": ["aqueduct (underground)", "kārīz (regional variant)", "foggara (regional variant)"],
          "antonyms": ["surface irrigation", "modern piped water system"],
          "register": "formal",
          "domain": ["general", "history", "architecture", "engineering"]
        }
      ]
    },
