    {
      "term": "rowiness",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being rowdy or having a rough, coarse appearance or behavior",
          "examples": ["The rowiness of the crowd made it hard to move through the gate."],
          "collocations": ["rowiness of appearance", "rowiness of behavior", "unmistakable rowiness"],
          "synonyms": ["coarseness", "roughness", "ruggedness"],
          "antonyms": ["polish", "neatness", "refinement"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
