      "term": "nonpropagandist",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who opposes or avoids propaganda",
          "examples": [
            "The campaign tried to persuade the public, but the speaker remained a nonpropagandist, sticking to factual information.",
            "As a nonpropagandist, she presented balanced data without persuasive rhetoric."
          ],
          "collocations": [
            "be a nonpropagandist",
            "act as a nonpropagandist",
            "nonpropagandist stance"
          ],
          "synonyms": ["fact-based advocate", "truth-focused critic"],
          "antonyms": ["propagandist", "apologist"],
          "register": "neutral",
          "domain": ["general", "media"]
        }
      ]
    },
