    {
      "term": "prerighteous",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "adjective",
          "definition": "Not truly righteous; self‑righteously pretended or falsely pious.",
          "examples": [
            "His prerighteous attitude annoyed everyone because he claimed moral superiority while failing to act kindly.",
            "The sermon sounded prerighteous rather than humble."
          ],
          "collocations": ["prerighteous attitude", "prerighteous stance", "pretended prerighteousness"],
