      "term": "remodel",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to change the shape or structure of something, especially a building or room, by altering its appearance or layout",
          "examples": [
            "They decided to remodel the kitchen to make it more open-plan.",
            "The company plans to remodel the old factory into a modern office complex."
          ],
          "collocations": ["remodel the kitchen", "remodeling project", "remodeling work", "remodelled (UK) / remodeled (US)"],
          "synonyms": ["renovate", "redesign", "restructure", "revamp"],
          "antonyms": ["maintain", "preserve"],
          "register": "formal",
          "domain": ["general", "home improvement", "construction"]
        }
      ]
    },
