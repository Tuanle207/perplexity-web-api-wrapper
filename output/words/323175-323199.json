      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of recce; a brief military reconnaissance or reconnaissance mission.",
          "examples": [
            "The soldiers conducted several recces before the attack.",
            "We planned a quick recce of the area at dawn."
