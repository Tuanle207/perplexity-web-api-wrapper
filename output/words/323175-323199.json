    {
      "term": "recede",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to move away from a place or person; to go back or withdraw.",
          "examples": [
            "The floodwaters began to recede after the rain stopped.",
            "As the sound faded, she could see the crowd recede into the distance."
          ],
          "collocations": [
            "recede slowly",
            "water recedes",
            "hair recedes",
            "recede into the background"
          ],
          "synonyms": ["withdraw", "go back", "diminish"],
          "antonyms": ["approach", "advance", "increase"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        }
      ]
    },
    {
