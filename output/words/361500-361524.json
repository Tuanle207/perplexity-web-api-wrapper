    {
      "term": "slippery",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having a surface that is smooth and wet or oily, making it easy to slip or slide on",
          "examples": [
            "The floor was slippery after washing it.",
            "Be careful—the path is slippery when it rains."
          ],
          "collocations": ["slippery floor", "slippery surface", "slippery when wet", "slippery slope"],
          "synonyms": ["slick", "slickery (informal)", "glossy (contextual)"],
          "antonyms": ["rough", "grippy", "sticky"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "adjective",
          "definition": "likely to cause trouble or deception; not to be trusted",
          "examples": [
            "The political deal turned out to be slippery and hard to pin down.",
            "Be wary of slippery promises in some advertisements."
          ],
          "collocations": ["slippery customer", "slippery situation", "slippery logic"],
          "synonyms": ["deceptive", "elusive", "tricky"],
          "antonyms": ["straightforward", "clear", "honest"],
          "register": "formal",
          "domain": ["general", "politics"]
        }
      ]
