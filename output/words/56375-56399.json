      "term": "canthorrhaphy",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a surgical procedure to repair or close a wound of the canthus (the corner of the eye).",
          "examples": [
            "The surgeon performed canthorrhaphy after the injury to the eyelid corner.",
            "Historically, canthorrhaphy was used to treat eyelid deformities."
          ],
          "collocations": ["canthorrhaphy procedure", "eyelid canthorrhaphy", "surgical canthorrhaphy"],
          "synonyms": ["canthopexy (rare)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["medical", "medicine"]
        }
      ]
    },
