      "term": "preconceit",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a preconceived opinion or assumption; a biased or prejudiced view formed before having full knowledge",
          "examples": [
            "Her argument was colored by preconceit about the group.",
            "Don't jump to conclusions; avoid preconceits that cloud judgment."
          ],
          "collocations": [
            "a preconceit about",
            "strong preconceit",
            "outdated preconceit"
          ],
          "synonyms": [
            "preconception",
            "prejudice",
            "bias"
          ],
          "antonyms": [
            "open mind",
            "neutral view",
            "objectivity"
          ],
          "register": "formal",
          "domain": ["general", "psychology", "education"]
        }
