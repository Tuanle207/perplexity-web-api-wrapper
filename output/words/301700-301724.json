    {
      "term": "preamble",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "an introductory statement or passage, especially in a document or speech, explaining the purpose or background before the main content.",
          "examples": [
            "The constitution begins with a preamble that outlines its aims.",
            "In the interview, the speaker gave a brief preamble before answering the questions."
          ],
          "collocations": ["preamble to the constitution", "opening preamble", "brief preamble"],
          "synonyms": ["introduction", "preface", "foreword"],
          "antonyms": ["conclusion", "afterword"],
          "register": "formal",
          "domain": ["general", "law", "government", "academic"]
        },
        {
          "pos": "verb",
          "definition": "to introduce or begin with an introductory statement.",
          "examples": [
            "The report preambled with a note on its limitations."
          ],
          "collocations": ["pre-amble (alt. spelling)", "preamble the document"],
          "synonyms": ["introduce", "opening"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "documentation"]
        }
      ]
    },
