      "term": "semicitizen",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who is only partly or not fully a citizen of a country, or who has limited rights of citizenship",
          "examples": [
            "The policy aimed to grant rights to the semicitizens.",
            "As a semicitizen, he could not vote in national elections."
          ],
          "collocations": ["de facto semicitizen", "illegal semicitizen status", "semi-citizen rights", "dual semicitizen"],
          "synonyms": ["non-citizen", "resident with limited rights"],
          "antonyms": ["citizen", "national"],
          "register": "neutral",
          "domain": ["general", "law", "politics"]
        }
      ]
    },
