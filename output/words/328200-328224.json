      "term": "relays",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a device that receives a signal and sends a new signal to another place, often used to control a circuit remotely",
          "examples": ["The relay switches the circuit when the timer finishes.", "They used a radio relay to extend the network coverage."],
          "collocations": ["relay station", "relay signal", "relay race"],
          "synonyms": ["switch", "intermediate relay", "repeater"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "general"]
        },
        {
          "pos": "verb",
          "definition": "to pass on a message or information to another person or place",
          "examples": ["Please relay the message to the supervisor.", "The information was relayed to the team by email."],
          "collocations": ["relay a message", "relay information", "relay details"],
          "synonyms": ["transmit", "convey", "pass on"],
          "antonyms": ["withhold", "conceal"],
          "register": "neutral",
          "domain": ["general", "communication"]
        }
      ]
