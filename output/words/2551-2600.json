      "term": "achalasia",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A rare medical condition in which the muscles of the esophagus and the lower esophageal sphincter do not relax properly, making it hard to swallow food and drink.",
          "examples": [
            "The doctor diagnosed the patient with achalasia after several tests.",
            "People with achalasia often feel that food is stuck in their chest when they swallow.",
            "Surgery or other procedures can help relieve the symptoms of achalasia."
          ],
          "collocations": [
            "diagnosed with achalasia",
            "achalasia symptoms",
            "achalasia treatment",
            "esophageal achalasia",
            "achalasia patients",
            "achalasia diagnosis",
            "achalasia surgery"
          ],
          "synonyms": [
            "swallowing disorder",
            "esophageal motility disorder"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "medicine"
          ]
        }
      ]
    },
