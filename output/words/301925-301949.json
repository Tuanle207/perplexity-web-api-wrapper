      "term": "preboast",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to boast about something before it has happened or before its outcome is known",
          "examples": ["He tended to preboast about his upcoming performance, which jinxed the event."],
          "collocations": ["preboast about", "preboast loudly", "preboast openly"],
          "synonyms": ["boast prematurely", "talk up in advance"],
          "antonyms": ["humble", "understate"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
        ]
    },
