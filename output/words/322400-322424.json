    {
      "term": "reasoned",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "used to describe a person who has thought carefully or logically about something",
          "examples": ["She gave a reasoned argument for her position."],
          "collocations": ["reasoned argument", "reasoned conclusion", "reasoned approach"],
          "synonyms": ["thoughtful", "logical", "rational"],
          "antonyms": ["impulsive", "rash"],
          "register": "formal",
          "domain": ["general", "academic"]
        },
        {
          "pos": "verb",
          "definition": "past tense of reason; to think about something in a logical way and conclude something",
          "examples": ["He reasoned that the plan would fail.", "She reasoned through the problem step by step."],
          "collocations": ["reasoned that", "reasoned approach", "reasoned conclusion"],
          "synonyms": ["deduced", "inferred", "argued"],
          "antonyms": ["doubted", "ignored"],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
