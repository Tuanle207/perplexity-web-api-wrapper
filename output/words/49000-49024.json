    {
      "term": "brieflessness",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state of lacking a duration or brevity; the quality of being without a brief or concise form",
          "examples": [
            "The brieflessness of his talk made it hard to follow his argument.",
            "She criticized the brieflessness of the report, calling for more detail."
          ],
          "collocations": ["acute brieflessness", "brieflessness of speech", "exhibit brieflessness"],
          "synonyms": ["conciseness lacking", "brevity absence"],
          "antonyms": ["brevity", "conciseness"],
          "register": "formal",
          "domain": ["general"]
        }
      ]
    },
