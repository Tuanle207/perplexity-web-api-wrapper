    {
      "term": "blight",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a plant disease that causes wilting and death; a sign of poor health in crops",
          "examples": [
            "The potato crop was destroyed by blight.",
            "Farmers are worried about blight spreading to the tomato plants."
          ],
          "collocations": ["crop blight", "potato blight", "fungal blight", "blight damage"],
          "synonyms": ["disease", "mildew", "plague (figurative)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["agriculture", "biology", "general"]
        },
        {
          "pos": "noun",
          "definition": "a condition of ruin or decay; something that spoils or damages",
          "examples": [
            "Unchecked urban development is a blight on the landscape.",
            "The factory closure was a blight on the town."
          ],
          "collocations": ["economic blight", "blight on", "social blight"],
          "synonyms": ["blemish", "scourge", "curse"],
          "antonyms": [],
          "register": "formal",
          "domain": ["society", "economy", "general"]
        },
        {
          "pos": "verb",
          "definition": "to spoil or ruin; to cause to wither or deteriorate",
          "examples": [
            "The drought blighted the harvest.",
            "His career was blighted by scandal."
          ],
          "collocations": ["blight crops", "blight affect", "blight someone's chances"],
          "synonyms": ["ruin", "damage", "spoil"],
          "antonyms": [],
          "register": "formal",
          "domain": ["agriculture", "economy", "general"]
        }
      ]
    },
