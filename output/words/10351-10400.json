            "plant allomones",
            "insect allomones",
            "defensive allomones",
            "chemical allomones",
            "allomones in ecology"
          ],
          "synonyms": [
            "allelochemicals"
          ],
          "antonyms": [],
          "register": "formal",
          "domain": [
            "biology",
            "ecology"
          ]
        }
