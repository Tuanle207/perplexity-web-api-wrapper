  "items": [
    {
      "term": "provisioner",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person or organization that provides supplies or resources, especially for a specific purpose or project",
          "examples": [
            "The military provisioner delivered food and medical kits to the frontline.",
            "As a provisioner for the expedition, she organized tents, cooking gear, and rations."
          ],
          "collocations": ["military provisioner", "provisioner of supplies", "food provisioner"],
          "synonyms": ["supplier", "vendor", "supplies officer"],
          "antonyms": ["consumer", "detractor"],
          "register": "formal",
          "domain": ["general", "business", "logistics"]
        }
      ]
    },
    {
