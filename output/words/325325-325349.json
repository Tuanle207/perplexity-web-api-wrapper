    {
      "term": "redshift",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the displacement of spectral lines toward longer wavelengths; a shift to the red end of the spectrum, indicating objects are moving away",
          "examples": [
            "The galaxies show a strong redshift, meaning they are receding from us.",
            "Cosmologists use redshift to measure the expansion of the universe."
          ],
          "collocations": ["cosmological redshift", "spectral redshift", "redshift measurement"],
          "synonyms": ["z-shift (informal)", "Doppler shift (related)"],
          "antonyms": ["blueshift"],
          "register": "formal",
          "domain": ["science", "astronomy"]
        },
        {
          "pos": "verb",
          "definition": "to shift toward the red end of the spectrum in scientific observations or to shift away (rare in casual use)",
          "examples": [
            "The spectrum redshifts as the galaxy moves away."
          ],
          "collocations": ["redshifted light", "redshifted spectrum"],
          "synonyms": ["redden (not exact)"],
          "antonyms": ["blueshift"],
          "register": "formal",
          "domain": ["science"]
        }
      ]
    },
    {
