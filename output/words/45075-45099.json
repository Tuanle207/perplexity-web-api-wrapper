      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "fastened with a bolt; secured in place with a bolt",
          "examples": ["The door was bolted from the inside for security."],
          "collocations": ["bolted shut", "bolted door", "bolted down"],
          "synonyms": ["fastened", "locked"],
          "antonyms": ["unbolted", "unfastened"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "verb",
          "definition": "to secure something with a bolt or to move suddenly as if startled (past tense of bolt)",
          "examples": ["He bolted the gate before leaving.", "The horse bolted when the gate opened."],
          "collocations": ["bolt the door", "bolt shut", "bolt away"],
          "synonyms": ["fastened", "secured", "ran away (figurative)"],
          "antonyms": ["unbolted", "unfastened"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
