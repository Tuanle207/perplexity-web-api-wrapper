      "term": "recatalog",
      "kind": "verb",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to catalog again or reorganize a catalog or list",
          "examples": [
            "They decided to recatalog the library to reflect new genres.",
            "The project will recatalog the products by region."
          ],
          "collocations": [
            "recatalog a catalog",
            "recatalog the library",
            "recatalog items",
            "recatalog entries"
          ],
          "synonyms": ["reclassify", "reindex", "resort"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "library", "information management"]
        }
      ]
    },
