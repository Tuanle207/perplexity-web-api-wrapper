            "The blockbusted thriller drew huge crowds on its opening weekend.",
            "Blockbusted films often break sales records."
          ],
          "collocations": ["blockbusted film", "blockbusted success", "blockbusted at the box office"],
          "synonyms": ["box office hit", "blockbuster"],
          "antonyms": ["flop", "bomb"],
          "register": "neutral",
          "domain": ["general", "business", "entertainment"]
        }
