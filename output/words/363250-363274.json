    {
      "term": "sneezing",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "gerund",
          "definition": "the act of producing a sudden blast of air through the nose and mouth, often as a reflex in response to irritation",
          "examples": [
            "She couldn't stop sneezing from the dust.",
            "Sneezing can be a sign of allergies.",
            "He had to leave the room because of a sneezing fit."
          ],
          "collocations": ["sneezing powder", "sneezing fit", "sneezing attack", "constant sneezing", "allergic sneezing"],
          "synonyms": ["achooing (informal)", "sneeze reflex"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["everyday", "medical"]
        }
      ]
    },
