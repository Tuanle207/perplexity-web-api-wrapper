      "term": "samen",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "The quality of being the same; the state of being indistinguishable or alike.",
          "examples": [
            "The sameness of their faces made it hard to tell them apart.",
            "They valued sameness over individuality in that environment."
          ],
          "collocations": ["a sense of sameness", "remarkable sameness", "identity and sameness"],
          "synonyms": ["similarity", "uniformity", "conformity"],
          "antonyms": ["difference", "variety", "diversity"],
          "register": "formal",
          "domain": ["general", "psychology"]
        }
      ]
    },
