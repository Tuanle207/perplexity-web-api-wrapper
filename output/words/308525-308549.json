      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of poking or nudging someone or something to urge action or provoke a response",
          "examples": ["He kept prodding her to finish the assignment.", "A gentle prodding from the coach pushed the team to try harder."],
          "collocations": ["prodding someone", "prodding action", "prodding into", "with a prodding stick"],
          "synonyms": ["nudging", "urging", "cajoling"],
          "antonyms": ["leaving alone", "ignoring"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
