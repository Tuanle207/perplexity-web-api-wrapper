      "term": "brava",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "interjection",
          "definition": "Used to applaud or praise a performance by a female performer.",
          "examples": [
            "The dancer finished, and the audience shouted, 'Brava!'",
            "Brava to the soloist for that flawless rendition."
          ],
          "collocations": ["brava!", "brava to", "brava for"],
          "synonyms": ["bravissimo (masculine)"],
          "antonyms": [],
          "register": "informal",
          "domain": ["performing arts", "general"]
        }
      ]
    },
    {
      "term": "bravade",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A bold or flashy demonstration intended to impress others; a swaggering display of courage or vanity.",
          "examples": [
            "His bravade masked his insecurity.",
            "She dismissed his bravade as mere posturing."
          ],
          "collocations": ["show bravade", "bravade of", "grand bravade"],
          "synonyms": ["boastfulness", "swagger", "vainglory"],
          "antonyms": ["humility", "modesty"],
          "register": "formal",
          "domain": ["general", "psychology"]
        }
      ]
    },
