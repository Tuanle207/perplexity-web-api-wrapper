    {
      "term": "brave",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Ready to face danger or pain without showing fear; showing courage.",
          "examples": [
            "A brave firefighter saved the child.",
            "She spoke up with brave honesty."
          ],
          "collocations": ["brave act", "brave decision", "brave enough"],
          "synonyms": ["courageous", "bold", "valiant"],
          "antonyms": ["cowardly", "fearful"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "To face or endure a difficult situation with courage.",
          "examples": [
            "He brave a harsh winter to reach the village.",
            "They braved the rain to protest the decision."
          ],
          "collocations": ["brave the weather", "brave danger", "brave the crowds"],
          "synonyms": ["face", "confront", "endure"],
          "antonyms": ["avoid", "shrink from"],
          "register": "neutral",
          "domain": ["general"]
        }
      ]
    },
