      "term": "reincurred",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "to occur again after something has already happened; to have happened again.",
          "examples": [
            "He had to pay more taxes because the same problem had reincurred.",
            "The issue reincurred despite earlier promises to resolve it."
          ],
          "collocations": ["recurred again", "recurred despite", "recurred last year"],
          "synonyms": ["reappeared", "reoccurred", "recurred"],
          "antonyms": ["resolved", "prevented"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
