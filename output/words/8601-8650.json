      "term": "alarmist",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who causes unnecessary fear by exaggerating dangers or problems",
          "examples": [
            "Some experts called him an alarmist for warning about a possible financial crash.",
            "The article accused environmental activists of being alarmists."
