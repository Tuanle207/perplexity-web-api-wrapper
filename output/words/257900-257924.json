      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a mythical female spirit or young woman; a beautiful young woman",
          "examples": ["A forest nymph appeared by the stream.", "The advertisement used the nymph as a symbol of grace."],
