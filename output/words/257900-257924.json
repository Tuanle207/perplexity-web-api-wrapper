          "synonyms": ["sprite", "fairy", "maiden"],
          "antonyms": [],
          "register": "literary",
          "domain": ["mythology", "literature", "arts"]
        },
        {
          "pos": "noun",
          "definition": "the larval or immature form of an insect (less common usage in biology)",
          "examples": ["The entomologist described a nymph stage in the insect's life cycle."],
          "collocations": ["insect nymph", "nymph stage"],
          "synonyms": ["juvenile form", "larva (when used in context)"],
          "antonyms": ["adult"],
          "register": "neutral",
          "domain": ["biology", "science"]
        }
