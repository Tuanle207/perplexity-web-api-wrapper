      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun (plural of bioturbation)",
          "definition": "the reworking or disturbance of soil or sediment by living organisms, especially by burrowing animals or root growth",
          "examples": [
            "Bioturbations by worms help mix nutrients in the sediment.",
            "Bioturbations can affect fossil records by redistributing sediments."
          ],
