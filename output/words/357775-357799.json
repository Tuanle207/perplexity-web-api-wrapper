{
  "items": [
    {
      "term": "signer",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who signs something, such as a document, or who signs in a public context",
          "examples": [
            "The signer of the contract must initial each page.",
            "The autograph signer stood beside the celebrity for photos."
          ],
          "collocations": ["signer of the contract", "authorized signer", "signature signer"],
          "synonyms": ["endorser", "signatory"],
          "antonyms": ["signatory (opposite sense)", "non-signer"],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
    {
      "term": "signers",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of signer; multiple people who sign something or who sign autographs",
          "examples": [
            "The signers of the petition gathered to present it.",
            "The room contained several famous signers after the event."
          ],
          "collocations": ["signers of the petition", "autograph signers"],
          "synonyms": ["endorsers", "signatories"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "law"]
        }
      ]
    },
    {
      "term": "signet",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a small seal used to imprint a design onto wax as a mark of authentication; a ring or seal",
          "examples": [
            "The king wore his signet ring on his finger.",
            "She pressed the signet into the wax to seal the letter."
          ],
          "collocations": ["signet ring", "signet seal", "royal signet"],
          "synonyms": ["seal", "emblem"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "history", "literature"]
        }
      ]
    },
