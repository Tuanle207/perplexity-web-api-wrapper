    {
      "term": "societyese",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a nonstandard or humorous style of speech or writing that imitates or caricatures the language used in a society or social group",
          "examples": ["The author’s use of societyese adds a playful tone to the dialogue."],
          "collocations": ["societyese phrasing", "societyese dialogue", "societyese humor"],
          "synonyms": ["jargon", "slang style", "lingo"],
          "antonyms": ["standard language", "formal prose"],
          "register": "informal",
          "domain": ["general", "literature"]
        }
      ]
    },
