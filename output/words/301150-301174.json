{
  "items": [
    {
      "term": "pragmatist",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who deals with things sensibly and realistically, based on practical considerations rather than theoretical ideas",
          "examples": [
            "As a pragmatist, she focuses on workable solutions rather than abstract theories.",
            "The pragmatist in him preferred a small, effective reform to grand but ineffective plans."
          ],
          "collocations": [
            "pragmatist approach",
            "pragmatist mindset",
            "pragmatist thinker",
            "pragmatist perspective",
            "pragmatist politician"
          ],
          "synonyms": ["practical person", "realist", "down-to-earth person"],
          "antonyms": ["idealist"],
          "register": "neutral",
          "domain": ["general", "everyday", "business"]
        }
      ]
    },
    {
      "term": "pragmatistic",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "relating to or following pragmatism; dealing with things in a practical, results-oriented way",
          "examples": [
            "Her pragmatistic approach wins more support than theoretical plans.",
            "They adopted a pragmatistic attitude toward the project."
          ],
          "collocations": [
            "pragmatistic approach",
            "pragmatistic mindset",
            "pragmatistic reasoning"
          ],
          "synonyms": ["practical", "realistic", "utilitarian"],
          "antonyms": ["theoretical", "idealistic"],
          "register": "neutral",
          "domain": ["general", "business", "academic"]
        }
      ]
    },
