    {
      "term": "calk",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to seal or fill gaps in a structure (such as a ship's hull or a window frame) with a waterproof material to prevent leaks.",
          "examples": [
            "They calked the seams to stop the water from entering.",
            "The carpenter calked the gaps around the window."
          ],
          "collocations": [
            "calk the seams",
            "oil-based calking",
            "tar and calk"
          ],
          "synonyms": ["caulk", "seal", "mortar"],
          "antonyms": [],
          "register": "formal",
          "domain": ["construction", "nautical", "general"]
        },
        {
          "pos": "noun",
          "definition": "a material or tool used for calking; a wedge or wooden plug used to fill gaps; sometimes refers to a shoe stud or a sharp projection used for grip.",
          "examples": [
            "The calk in the boat's hull held fast.",
            "He wore calks on his boots for extra traction."
          ],
          "collocations": [
            "ship calk",
            "calk material",
            "calk box"
          ],
          "synonyms": ["caulk", "wedge", "spike"],
          "antonyms": [],
          "register": "neutral",
