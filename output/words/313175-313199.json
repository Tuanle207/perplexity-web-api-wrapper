      "term": "psychobiographer",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a writer or researcher who studies or describes the life and psychology of a person, especially notable figures, through psychological analysis",
          "examples": [
            "The psychobiographer examined the author's childhood traumas to explain his later works.",
            "Her book is a sensitive psychobiography of the scientist."
