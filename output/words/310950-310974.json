    {
      "term": "protestation",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a formal declaration of objection or disapproval, often to express opposition to something believed to be wrong or unjust",
          "examples": [
            "Her protestation of innocence did little to sway the jury.",
            "There was a protestation against the new policy from several community groups."
          ],
          "collocations": ["protestation of", "solemn protestation", "with protestation"],
          "synonyms": ["objection", "disavowal", "denial"],
          "antonyms": ["consent", "agreement", "approval"],
          "register": "formal",
          "domain": ["general", "law", "politics"]
        }
      ]
    },
