      "term": "safranin",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A bright reddish-orange dye used in biology and histology to stain plant and animal tissues.",
          "examples": [
            "Safranin is often used to stain plant cell walls in microscopy.",
            "The histology slide showed nuclei stained by safranin."
          ],
          "collocations": [
            "safranin stain",
            "safranin-red",
            "histology staining",
            "alcian blue and safranin"
          ],
          "synonyms": ["orange-red dye", "histology stain"],
          "antonyms": [],
          "register": "formal",
          "domain": ["science", "medicine", "education"]
        }
      ]
    },
