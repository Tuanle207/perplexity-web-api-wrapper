      "term": "prededication",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "A formal or theoretical act of dedicating beforehand, often used to describe a preface or introductory statement in a text that dedicates it to someone prior to main content.",
          "examples": [
            "The prededication of the manuscript celebrated the donor who supported the project.",
            "Scholars discussed the prededication in the foreword, though it is rarely used today."
          ],
          "collocations": [
            "prededication of",
            "prededication statement",
            "foreword prededication"
          ],
          "synonyms": [],
          "antonyms": [],
          "register": "null",
          "domain": ["general", "literary"]
        }
      ]
    },
