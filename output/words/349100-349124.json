            "The path was lined with sedge along the marsh. ",
            "Sedges like to grow where the soil stays damp."
          ],
          "collocations": ["sedge bog", "tuft of sedge", "wet sedge", "sedge meadow"],
          "synonyms": ["grass", "reed"],
          "antonyms": [],
          "register": "informal",
          "domain": ["nature", "general"]
        }
      ]
    },
