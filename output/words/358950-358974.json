    {
      "term": "sinter",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A solid mass formed by heating powders (such as metal or ceramic particles) without melting them completely.",
          "examples": ["The metal powder was fused into a sinter for the final part."],
          "collocations": ["sintering process", "sinter powder", "sinter plant"],
          "synonyms": ["fused mass", "calcine (approx)"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "industry", "science"]
        },
        {
          "pos": "verb",
          "definition": "To form a coherent mass by heating powdered material to but not exceeding its melting point.",
          "examples": ["The particles were sintered to create a solid component."],
          "collocations": ["sinter metal", "sinter at high temperature", "sintering process"],
          "synonyms": ["fuse", "fuse together"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "science", "industry"]
        }
      ]
    },
