    {
      "term": "sensors",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "devices that detect physical properties and provide signals to other equipment",
          "examples": [
            "The sensors on the smartphone measure light levels to adjust the screen brightness.",
            "Motion sensors help turn on lights automatically."
          ],
          "collocations": ["motion sensor", "temperature sensor", "proximity sensor", "sensor data", "sensor array"],
          "synonyms": ["detectors", "transducers"],
          "antonyms": ["insensitive devices"],
          "register": "formal",
          "domain": ["technology", "general", "everyday"]
        }
      ]
    },
