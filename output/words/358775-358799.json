      "term": "singular",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "denoting something that is one; unique; solitary",
          "examples": [
            "a singular solution to the problem",
            "the singular beauty of the sunset",
            "her singular focus on her career"
          ],
          "collocations": ["singular focus", "singular importance", "singular instance"],
          "synonyms": ["unique", "one-of-a-kind", "exceptional"],
          "antonyms": ["plural", "common", "ordinary"],
          "register": "formal",
          "domain": ["general", "arts"]
        },
        {
          "pos": "noun",
          "definition": "a form of a noun indicating one person or thing; the basic form of a word used to denote one member of a class",
          "examples": [
            "The word 'dog' is in its singular form here.",
            "In English, nouns have singular and plural forms."
