    {
      "term": "sectarianizing",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "the act of promoting or engaging in sectarianism; making something partisan by emphasizing religious, ethnic, or ideological divisions",
          "examples": [
            "politicians were sectarianizing the debate to win support from their base",
            "the campaign faced criticism for sectarianizing public policy"
          ],
          "collocations": [
            "sectarianizing language",
            "sectarianizing rhetoric",
            "sectarianizing influence"
          ],
          "synonyms": ["partisanising (British)", "dividing", "polarizing"],
          "antonyms": ["uniting", "including", "bridging"],
          "register": "neutral",
          "domain": ["general", "politics", "society"]
        }
      ]
    },
