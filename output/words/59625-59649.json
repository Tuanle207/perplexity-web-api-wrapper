    {
      "term": "cataloguing",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "act of making a catalog; the process of listing and organizing items in a catalog",
          "examples": [
            "The library is currently involved in cataloguing all its new arrivals.",
            "Cataloguing helps researchers find materials quickly."
          ],
          "collocations": ["complete cataloguing", "modern cataloguing", "ethical cataloguing", "library cataloguing", "systematic cataloguing"],
          "synonyms": ["indexing", "listing", "classification"],
          "antonyms": ["disarray", "omission"],
          "register": "formal",
          "domain": ["general", "library", "information management"]
        }
      ]
    },
