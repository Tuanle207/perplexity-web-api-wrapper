          "collocations": ["quantal units", "quantal change", "quantal level"],
          "synonyms": ["discrete", "quantized", "countable"],
          "antonyms": ["continuous", "gradual"],
          "register": "formal",
          "domain": ["general", "science", "technology"]
        }
      ]
