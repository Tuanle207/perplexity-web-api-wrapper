      "term": "semirotating",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "partially or somewhat rotating; not fully rotating",
          "examples": [
            "The camera uses a semirotating mechanism to adjust angles slowly.",
            "A semirotating drum helps mix the solution without full rotation."
          ],
          "collocations": [
            "semirotating mechanism",
            "semirotating motion",
            "semirotating drum"
          ],
          "synonyms": ["partially rotating", "part-rotating"],
          "antonyms": ["fully rotating"],
          "register": "neutral",
          "domain": ["general", "technology"]
        }
      ]
    },
