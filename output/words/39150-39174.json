      "cefrLevel": "null",
      "senses": [
        {
          "pos": "plural noun",
          "definition": "informal term for a group of women or girls named Betty or characterized as related to the name Betty; can also refer to multiple dishes or desserts called brownies-style betty in culinary contexts",
          "examples": [
            "The two betties organized the charity bake sale.",
            "She introduced her friends as the betties from the art club."
          ],
          "collocations": [
            "the betties",
            "Betty's betties",
            "old betties"
          ],
          "synonyms": ["Bettys", "Betties (as a nickname group)"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "daily-life"]
        },
        {
          "pos": "noun (dessert, culinary)",
          "definition": "a dessert named after Betty, typically a layered fruit and crumb mixture baked in a dish; for example brown betty",
          "examples": [
            "We baked a cranberry betty for dessert.",
            "Brown betty is a classic American fruit dessert."
          ],
          "collocations": [
            "brown betty",
