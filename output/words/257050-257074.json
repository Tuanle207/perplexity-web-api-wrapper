      "senses": [
        {
          "pos": "noun",
          "definition": "a narrow opening that directs or controls the flow of a liquid or gas.",
          "examples": [
            "The nozzle on the bottle helps pour without spilling.",
            "Switching to a finer nozzle makes the spray more precise."
          ],
          "collocations": ["fuel nozzle", "spray nozzle", "nozzle tip", "adjustable nozzle"],
          "synonyms": ["spout", "tap", "outlet"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "technology"]
        },
        {
          "pos": "verb",
          "definition": "to direct or shape a liquid or gas through a nozzle (less common as a verb).",
          "examples": [
            "The pump noz zled the steam into a fine mist."  // Note: illustrative; actual usage rare
