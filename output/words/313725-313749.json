      "term": "ptyalin",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "an enzyme (alpha-amylase) in saliva that begins the digestion of starch",
          "examples": [
            "ptyalin starts breaking down starch as soon as food enters the mouth.",
            "Saliva contains ptyalin, which helps convert starch into simpler sugars."
          ],
          "collocations": [
            "saliva contains ptyalin",
            "ptyalin enzyme",
            "pancreatic ptyalin" 
          ],
          "synonyms": ["amylase", "salivary amylase"],
          "antonyms": [],
          "register": "formal",
          "domain": ["biology", "medicine", "general"]
        }
      ]
    },
