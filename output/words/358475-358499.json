    {
      "term": "simplemindedly",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that shows a lack of intelligence or good judgment",
          "examples": [
            "He shrugged off the warning and walked away simplemindedly.",
            "She nodded simplemindedly, agreeing without understanding the issue."
          ],
          "collocations": ["looked simplemindedly", "smiled simplemindedly", "act simplemindedly"],
          "synonyms": ["gullibly", "naively", "stupibly"],
          "antonyms": ["wisely", "shrewdly"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
