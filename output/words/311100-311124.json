  "items": [
    {
      "term": "protocolization",
      "kind": "noun",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act or process of establishing a protocol or formal procedure for carrying out something",
          "examples": [
            "The protocolization of the data-sharing process improved consistency across departments."
          ],
          "collocations": ["standard protocolization", "protocolization process", "documentation for protocolization"],
          "synonyms": ["formalization", "standardization"],
          "antonyms": ["informality", "disorganization"],
          "register": "formal",
          "domain": ["general", "technology", "business"]
        }
      ]
    },
    {
      "term": "protocolize",
