          "collocations": ["protocolize a process", "protocolize procedures", "protocolize data exchange"],
          "synonyms": ["formalize", "systematize"],
          "antonyms": ["disorganize", "deformalize"],
          "register": "formal",
          "domain": ["technology", "business", "general"]
        }
