    {
      "term": "screw",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A short, twisted metal pin with a threaded part used to join objects.",
          "examples": [
            "Fix the shelf to the wall with a screw.",
            "I can't find a screwdriver to fit this screw."
          ],
          "collocations": ["wood screw", "screw driver", "screw head", "screw thread", "screw cap"],
          "synonyms": ["bolt (in some contexts)", "fastener"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "construction", "mechanics"]
        }
      ]
    },
    {
      "term": "screwable",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "adjective",
          "definition": "Capable of being screwed or fastened with a screw.",
          "examples": [
            "The panel is screwable to the frame.",
            "Look for a screwable cover plate."
          ],
          "collocations": ["screwable joint", "screwable part"],
          "synonyms": ["screw-fastenable"],
          "antonyms": [],
          "register": null,
          "domain": ["general", "engineering"]
        }
      ]
    },
    {
      "term": "screwage",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "The act or amount of screwing; colloquial/archaic usage not common today.",
          "examples": [
            "The screwage of the fixture went smoothly.",
            "They charged extra screwage for the repair."
          ],
          "collocations": ["installation screwage"],
          "synonyms": ["fastening", "screwing"],
          "antonyms": [],
          "register": null,
          "domain": ["general", "mechanical"]
        }
      ]
    },
    {
      "term": "screwball",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A strange or eccentric person; a goofy or silly person.",
          "examples": [
            "The comedian is a real screwball.",
            "Don't take him too seriously; he's a screwball."
          ],
          "collocations": ["total screwball", "comic screwball"],
          "synonyms": ["nut", "weirdo", "oddball"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "entertainment"]
        },
        {
          "pos": "adjective",
          "definition": "Very strange or unpredictable; silly or wacky.",
          "examples": [
            "That was a screwball idea for a movie.",
            "She wore a screwball outfit to the party."
          ],
          "collocations": ["screwball move", "screwball scheme"],
          "synonyms": ["crazy", "ridiculous", "zany"],
          "antonyms": ["serious", "sensible"],
          "register": "informal",
          "domain": ["general", "film", "media"]
        }
      ]
    },
    {
      "term": "screwballs",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "Plural of screwball; multiple eccentric people or things.",
          "examples": [
            "The cast included several screwballs.",
            "We watched a few screwballs on TV last night."
          ],
          "collocations": ["a group of screwballs", "comedic screwballs"],
          "synonyms": ["oddballs"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "entertainment"]
        }
      ]
    }
