    {
      "term": "scrupulist",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who is extremely conscientious or meticulous about moral or ethical considerations",
          "examples": [
            "The scrupulist argued that even small lies undermine trust.",
            "As a scrupulist, she double-checked every detail before signing the contract."
          ],
          "collocations": [
            "moral scrupulist",
            "strict scrupulist",
            "religious scrupulist",
            "ethics-obsessed scrupulist"
          ],
          "synonyms": ["paragon of ethics", "moral purist", "prudish person"],
          "antonyms": ["carefree person", "easygoing person", "permissive person"],
          "register": "formal",
          "domain": ["general", "ethics"]
        }
      ]
    },
