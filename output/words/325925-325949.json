      "term": "refascination",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of regaining or restoring fascination or appeal; a renewed interest or attractiveness",
          "examples": [
            "The museum's new exhibit sparked a refascination with ancient art among visitors.",
            "Her refascination with classic cinema began after watching a restored film",
            "There was a refascination with handmade, slow-made goods in the market."
          ],
          "collocations": ["refascination with", "refascination toward", "great refascination"],
          "synonyms": ["renewed interest", "reawakening", "revival of appeal"],
          "antonyms": ["disinterest", "disenchantment", "boredom"],
          "register": "formal",
          "domain": ["general", "culture", "arts"]
        }
      ]
    },
