    {
      "term": "recapitulator",
      "kind": "noun",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person or thing that summarizes or recaps information, especially someone who repeats the main points.",
          "examples": [
            "The lecturer acted as a recapitulator, briefly restating the key ideas at the end.",
            "In the briefing, the manager served as a recapitulator, ensuring everyone understood the main outcomes."
          ],
          "collocations": [
            "be a recapitulator",
            "serves as a recapitulator",
            "brief recap by the recapitulator"
          ],
          "synonyms": [
            "summarizer",
            "recap reader",
            "recapper"
          ],
          "antonyms": [
            "expander",
            "detailer"
          ],
          "register": "formal",
          "domain": ["general", "education", "academic"]
        }
      ]
    },
