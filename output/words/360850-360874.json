      "term": "slapdashery",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality or practice of doing something in a hasty, careless, or slapdash manner",
          "examples": [
            "Her report showed more slapdashery than careful planning.",
            "We winced at the slapdashery of the project’s initial draft."
          ],
          "collocations": ["slapdashery and carelessness", "avoid slapdashery", "improve slapdashery"],
          "synonyms": ["carelessness", "hastiness", "careless hurriedness"],
          "antonyms": ["carefulness", "thoroughness", "precision"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
