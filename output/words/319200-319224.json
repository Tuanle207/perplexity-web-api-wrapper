      "term": "radarman",
      "kind": "noun",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who operates or monitors radar equipment, especially on a ship or in an air-defense environment",
          "examples": [
            "The radarman watched the screen for any sign of incoming aircraft.",
            "As a radarman, she learned to interpret radar blips quickly."
          ],
          "collocations": [
            "radarman on duty",
            "radarman trainee",
            "radarman technician",
            "military radarman",
            "radarman station"
          ],
          "synonyms": ["radar operator", "radar technician"],
          "antonyms": [],
          "register": "formal",
          "domain": ["military", "technology"]
        }
      ]
    },
