    {
      "term": "pseudoemotional",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "not truly emotional; appearing emotional but lacking real feeling",
          "examples": [
            "The film was praised for its pseudoemotional scenes that felt manipulative.",
            "She gave a pseudoemotional speech to gain sympathy."
          ],
          "collocations": [
            "pseudoemotional display",
            "pseudoemotional response",
            "pseudoemotional appeal"
          ],
          "synonyms": ["false emotional", "pretend emotional", "feigned emotion"],
          "antonyms": ["genuine", "sincere", "authentic"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        }
      ]
    },
