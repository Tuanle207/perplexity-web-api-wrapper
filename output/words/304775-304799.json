      "term": "premeditation",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of planning something in advance, especially a crime or wrongdoing",
          "examples": [
            "The jury had to consider whether the crime showed premeditation.",
            "Her premeditation was evident in the carefully staged scene."
          ],
          "collocations": [
            "intentional premeditation",
            "criminal premeditation",
            "show/prevent premeditation",
            "strong premeditation"
          ],
          "synonyms": ["forethought", "premeditated planning"],
          "antonyms": ["impulse", "spontaneity"],
          "register": "formal",
          "domain": ["law", "general", "criminal justice"]
        }
      ]
    },
