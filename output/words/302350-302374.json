      "term": "precognized",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "past tense of precognize, to know something before it happens or before evidence is available",
          "examples": [
            "She precognized the outcome and prepared accordingly.",
            "The detective precognized a likely clue before it appeared.",
            "In the early draft, he precognized the twist and wrote it into the plot."
          ],
          "collocations": ["precognized a possibility", "precognized outcome", "precognized risk"],
          "synonyms": ["foreknow", "predict"],
          "antonyms": ["uncertainty", "ignore"],
          "register": "formal",
          "domain": ["general", "psychology"]
        }
      ]
    },
