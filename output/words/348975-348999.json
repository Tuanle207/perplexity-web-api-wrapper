      "term": "sectwise",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Relating to or focused on a particular sect or faction within a larger group.",
          "examples": ["Sectwise, the conference divided opinions along faction lines.", "Sectwise views differ on the interpretation of the doctrine."],
          "collocations": ["sectwise support", "sectwise differences", "sectwise bias"],
          "synonyms": ["partisan", "sectarian"],
          "antonyms": ["inclusive", "universal"],
          "register": "neutral",
          "domain": ["general", "society", "religion"]
        }
      ]
