          "synonyms": ["nonreligious", "worldly"],
          "antonyms": ["sacred", "religious"],
          "register": "formal",
          "domain": ["general", "education", "politics"]
        },
        {
          "pos": "noun",
          "definition": "A person who is not a member of a religious order or who lives in the world rather than the church.",
          "examples": ["The palace was visited by seculars and clergy alike."],
          "collocations": ["secular person", "secular society"],
          "synonyms": ["layperson", "noncleric"],
          "antonyms": ["cleric", "monk"],
          "register": "neutral",
          "domain": ["general", "religion"]
        }
      ]
    },
