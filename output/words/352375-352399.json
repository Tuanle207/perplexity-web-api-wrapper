    {
      "term": "sequitur",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a conclusion or consequence that logically follows from what has just been said, especially in formal discourse",
          "examples": ["The conclusion of the argument was the logical sequitur to the premises."],
          "collocations": ["logical sequitur", "follow as sequitur", "be the sequitur"],
          "synonyms": ["consequence", "outcome", "inference"],
          "antonyms": ["premise", "assumption"],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
    {
      "term": "sequiturs",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of sequitur; logical conclusions or consequences that follow from statements or arguments",
          "examples": ["Her remarks included several awkward sequiturs that weakened the point.", "The talk wandered with multiple sequiturs, making it hard to follow."],
          "collocations": ["logical sequiturs", "ironic sequiturs", "apparent sequiturs"],
          "synonyms": ["consequences", "outcomes", "inferences"],
          "antonyms": ["premises", "assumptions"],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
