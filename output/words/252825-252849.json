      "term": "nonnegativistic",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "not following the standard assumption of nonnegativity; relating to a mathematical or scientific model that allows negative values",
          "examples": [
            "The nonnegativistic model permits negative energies under certain conditions.",
            "In some theories, a nonnegativistic approach is used for simplicity."
          ],
          "collocations": [
            "nonnegativistic model",
            "nonnegativistic framework",
            "nonnegativistic assumption"
          ],
          "synonyms": ["negativist model (rare)", "negative-value model (less common)"],
          "antonyms": [],
          "register": "formal",
          "domain": ["technology", "science", "academic"]
        }
      ]
