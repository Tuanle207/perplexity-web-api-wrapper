  "items": [
    {
      "term": "pushers",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "people or things that push others to act or progress, often asserting pressure or influence",
          "examples": [
            "Political pushers often encourage reforms through persuasive campaigns.",
            "The marketing team are pushers, always urging clients to sign up."
          ],
          "collocations": ["heavy-handed pushers", "persistent pushers", "motivational pushers"],
          "synonyms": ["driving force", "instigators", "pressurers"],
          "antonyms": ["relaxers", "retreaters"],
          "register": "formal",
          "domain": ["general", "business", "everyday"]
        }
      ]
    },
    {
      "term": "pushes",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "acts of applying force to move something away or forward",
          "examples": [
            "Give the door a push; it’s stuck.",
            "The car’s pushes on the hill gave it more speed."
          ],
          "collocations": ["strong pushes", "nervous pushes", "gentle pushes"],
          "synonyms": ["shoves", "presses", " thrusts"],
          "antonyms": ["pulls", "draws"],
          "register": "informal",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to apply force to move something away or forward; to press someone to do something",
          "examples": [
            "She pushes the cart down the aisle.",
