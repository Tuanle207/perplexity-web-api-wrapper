    {
      "term": "reclaimer",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person or thing that reclaims something, especially scrap materials or land",
          "examples": [
            "The street sweeper found an old bicycle among the trash and served as a reclaimer by taking useful parts.",
            "Industrial reclaimers process scrap metal to be melted down and reused."
          ],
          "collocations": ["oil reclaimer", "garbage reclaimer", "metal reclaimer", "land reclaimer"],
          "synonyms": ["recycler", "recuperator"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "environment", "industry"]
        }
      ]
    },
    {
