      "term": "snivelled",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "past tense of snivel: to cry or complain in a way that shows self-pity or fretful complaining.",
          "examples": [
            "She snivelled about the rain throughout the entire walk.",
            "He snivelled that he was too tired to continue."
          ],
          "collocations": ["snivelled and complained", "snivelled softly", "snivelled about"],
          "synonyms": ["whine", "gripe", "whimper"],
          "antonyms": ["growl", "laugh", "cheerful"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
