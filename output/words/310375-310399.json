      "term": "prosecrecy",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the practice or state of keeping information secret, especially in a professional or official context",
          "examples": [
            "the prosecrecy of government documents hindered public scrutiny",
            "corporate prosecrecy raised concerns about transparency"
          ],
          "collocations": [
            "national prosecrecy",
            "corporate prosecrecy",
            "journalistic prosecrecy",
            "maintain prosecrecy",
            "restrict prosecrecy"
          ],
          "synonyms": ["secrecy", "confidentiality", "secretiveness"],
          "antonyms": ["transparency", "openness", "accountability"],
          "register": "formal",
          "domain": ["general", "politics", "law"]
        }
      ]
    },
