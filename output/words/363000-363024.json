    {
      "term": "snaky",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having many twists and turns; winding like a snake",
          "examples": [
            "The snaky path through the forest made us carefully pick our steps.",
            "A snaky river curls through the valley."
          ],
          "collocations": ["snaky path", "snaky road", "snaky river", "snaky terrain"],
          "synonyms": ["winding", "twisting", "serpentine"],
          "antonyms": ["straight", "direct", "straightforward"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "adjective",
          "definition": "untrustworthy or deceitful in a sly way",
          "examples": [
            "He gave a snaky smile that didn’t reach his eyes.",
            "Don't trust his snaky explanations."
          ],
          "collocations": ["snaky smile", "snaky behavior", "snaky tactics"],
          "synonyms": ["sly", "devious", "crooked"],
          "antonyms": ["honest", "straightforward"],
          "register": "informal",
          "domain": ["general", "everyday"]
        }
      ]
    },
    {
      "term": "snap",
