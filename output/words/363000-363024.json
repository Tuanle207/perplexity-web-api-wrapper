      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to break suddenly with a sharp cracking sound",
          "examples": [
            "The branch snapped under his weight.",
            "She snapped the towel in half."
          ],
          "collocations": ["snap a twig", "snap fastener", "snap decisions"],
          "synonyms": ["crack", "break", "fracture"],
          "antonyms": ["grow", "extend"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "noun",
          "definition": "a sharp, quick cracking sound or action",
          "examples": [
            "With a snap, the rope broke.",
            "He gave a sharp snap of the fingers."
          ],
          "collocations": ["snap of the fingers", "sound snap", "snap fastener"],
          "synonyms": ["crack", "pop"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "everyday"]
        },
        {
          "pos": "verb",
          "definition": "to say something abruptly or angrily; to lose one's temper quickly",
          "examples": [
            "Don't snap at me just because you're tired.",
            "The manager snapped at the receptionist."
