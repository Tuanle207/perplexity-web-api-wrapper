  "items": [
    {
      "term": "bipolarize",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to convert or cause to have two opposing poles or aspects, often used metaphorically to describe turning opinions, emotions, or positions toward two extremes",
          "examples": [
            "The debate bipolarized public opinion, splitting supporters into two camps.",
            "Efforts to bipolarize data can reveal contrasting trends in different regions."
          ],
          "collocations": ["bipolarize opinions", "bipolarize a dataset", "bipolarize into two camps"],
          "synonyms": ["polarize", "diversify (rare)"],
          "antonyms": ["unify", "harmonize"],
          "register": "neutral",
          "domain": ["general", "education", "psychology"]
        }
      ]
    },
    {
      "term": "bipolarized",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "having two polar opposites or extremes; characterized by dual, opposing positions or emotions",
          "examples": [
            "The population remained bipolarized after the campaign.",
            "Her views became bipolarized, swinging between enthusiasm and skepticism."
          ],
          "collocations": ["bipolarized electorate", "bipolarized opinions", "bipolarized state"],
          "synonyms": ["polarized", "dual-natured"],
          "antonyms": ["unified", "consensus"],
          "register": "neutral",
          "domain": ["general", "politics", "psychology"]
        }
      ]
    },
