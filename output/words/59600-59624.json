    {
      "term": "catalog",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "A complete list of items, often with descriptions, in a library, store, or collection.",
          "examples": [
            "The library catalog shows which books are available.",
            "She browsed the catalog for a new desk lamp."
          ],
          "collocations": [
            "library catalog",
            "product catalog",
            "online catalog",
            "catalog entry",
            "catalog table"
          ],
          "synonyms": ["list", "inventory", "index"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "business", "education"]
        },
        {
          "pos": "noun",
          "definition": "A complete and systematic listing of the items in a collection or the contents of a file.",
          "examples": [
            "Her music catalog contains works from the 18th century.",
            "The archive's catalog helps researchers locate documents."
          ],
          "collocations": [
            "music catalog",
            "archive catalog",
            "catalog entry",
            "catalog number"
          ],
          "synonyms": ["register", "record"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["arts", "library", "information"]
        },
        {
          "pos": "verb",
          "definition": "To arrange items in an organized list or to itemize and categorize.",
          "examples": [
            "The librarian cataloged the new acquisitions.",
            "They cataloged the specimens by species."
          ],
          "collocations": [
            "catalog something",
            "catalog a collection",
            "careful cataloging"
          ],
          "synonyms": ["index", "register", "document"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "library", "information"]
        }
      ]
    },
