      "term": "postponed",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "held back or delayed to a later time",
          "examples": ["The meeting was postponed until next week.", "Her trip was postponed due to bad weather."],
          "collocations": ["postponed indefinitely", "postponed decision", "postponed schedule"],
          "synonyms": ["delayed", "deferred", "put off"],
          "antonyms": ["urgent", "immediate", "scheduled"],
          "register": "formal",
          "domain": ["general", "everyday"]
        }
        // Note: as a past participle used as adjective, typically one sense
      ]
    },
