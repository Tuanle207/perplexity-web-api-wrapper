      "term": "repertoires",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the set of skills, abilities, or knowledge that a person or group uses in particular situations",
          "examples": [
            "Her musical repertoire includes several challenging pieces.",
            "The teacher expanded the class's repertoire of teaching strategies."
          ],
          "collocations": ["musical repertoire", "repertoire of skills", "repertoire of techniques", "draw from one's repertoire"],
          "synonyms": ["portfolio", "range", "array", "selection"],
          "antonyms": ["limited set", "scarcity"],
          "register": "formal",
          "domain": ["general", "education", "arts"]
        }
      ]
    },
