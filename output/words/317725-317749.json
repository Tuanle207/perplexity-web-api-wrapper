    {
      "term": "quellable",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adjective",
          "definition": "capable of being suppressed or silenced",
          "examples": ["The rebellion was not quellable by the authorities.", "They searched for a quellable outbreak before it spread."],
          "collocations": ["quellable fear", "quellable unrest", "quellable outbreak"],
          "synonyms": ["suppressible", "silence-able"],
          "antonyms": ["unquellable", "uncontrollable"],
          "register": "formal",
          "domain": ["general", "law", "politics"]
        }
      ]
    },
    {
