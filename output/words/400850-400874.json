    {
      "term": "tiptoe",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to walk quietly and softly, especially on the tips of the toes to avoid being noticed",
          "examples": [
            "She tiptoed through the sleeping house to avoid waking anyone.",
            "If you tiptoe past the sleeping baby, you won't wake him."
          ],
          "collocations": [
            "tiptoe around",
            "tiptoe through",
            "tiptoe quietly"
          ],
          "synonyms": ["sneak", "creep", "walk on tiptoe"],
          "antonyms": ["march", "stomp"],
          "register": "neutral",
          "domain": ["everyday", "general"]
        }
      ]
    },
    {
      "term": "tiptoed",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
