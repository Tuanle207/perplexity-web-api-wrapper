          "collocations": ["potential risk", "potential winner", "potential market", "potential benefit"],
          "synonyms": ["possible", "prospective", "latent"],
          "antonyms": ["certain", "definite"],
          "register": "neutral",
          "domain": ["general", "business", "technology"]
