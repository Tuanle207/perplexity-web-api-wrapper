      "term": "potential",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the ability to develop or become, or a possible future state that could be achieved",
          "examples": [
            "She has the potential to become a great scientist.",
            "The project has the potential to reduce costs by half."
          ],
          "collocations": ["untapped potential", "great/potential", "maximum potential", "potential for", "unlock potential"],
          "synonyms": ["possibility", "capability", "promise"],
          "antonyms": ["limitations", "impossibility"],
          "register": "neutral",
          "domain": ["general", "education", "business"]
        },
        {
          "pos": "adjective",
          "definition": "capable of becoming real; possible but not yet actual",
          "examples": [
            "This is a potential risk that we must address.",
            "The potential solution is still under study."
