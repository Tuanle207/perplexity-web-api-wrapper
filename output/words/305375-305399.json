          "collocations": [
            "preponderate over",
            "preponderate in favor",
            "preponderating evidence"
          ],
          "synonyms": ["predominate", "outweigh", "dominate"],
          "antonyms": ["insignificant", "belittle", "underweight"],
          "register": "formal",
          "domain": ["law", "logic", "general"]
        }
      ]
    },
