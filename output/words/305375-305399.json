{
  "items": [
    {
      "term": "preponderant",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Having a greater influence, importance, or amount than others; dominant.",
          "examples": [
            "The preponderant majority supported the proposal.",
            "In the debate, one side held a preponderant position."
          ],
          "collocations": [
            "preponderant influence",
            "preponderant advantage",
            "preponderant force",
            "preponderant importance",
            "preponderant power"
          ],
          "synonyms": ["dominating", "predominant", "supreme", "principal"],
          "antonyms": ["insignificant", "minor", "subordinate"],
          "register": "formal",
          "domain": ["general", "politics", "ethics", "business"]
        }
      ]
    },
    {
      "term": "preponderantly",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "adverb",
          "definition": "In a way that is more important or numerous than others; predominantly.",
          "examples": [
            "The region is preponderantly rural.",
            "The decision was preponderantly influenced by economic factors."
          ],
          "collocations": [
            "preponderantly male/female",
            "preponderantly rural",
            "preponderantly influenced"
          ],
          "synonyms": ["predominantly", "mostly", "chiefly"],
          "antonyms": ["minimally", "little", "scarcely"],
          "register": "formal",
          "domain": ["general", "statistics", "sociology"]
        }
      ]
    },
    {
