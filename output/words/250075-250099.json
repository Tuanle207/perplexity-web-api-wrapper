      "term": "nondescriptiveness",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being very ordinary or not having distinctive features that stand out",
          "examples": [
            "The building's nondescriptiveness made it easy to overlook.",
            "She picked a nondescript shirt to blend in with the crowd."
          ],
          "collocations": [
            "air of nondescriptness",
            "nondescriptness of the facade",
            "lose their nondescriptiveness"
          ],
          "synonyms": ["ordinariness", "undistinctiveness", "blandness"],
          "antonyms": ["distinctiveness", "character", " individuality"],
          "register": "formal",
          "domain": ["general", "everyday"]
        }
      ]
    },
