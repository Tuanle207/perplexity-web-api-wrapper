{
  "items": [
    {
      "term": "prescriptivist",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who favors prescribing rules for language use and who judges others' language as incorrect according to those rules",
          "examples": [
            "Many linguists argue against prescriptivists who police grammar on social media.",
            "The prescriptivist insisted that 'whom' must be used in that sentence."
          ],
          "collocations": [
            "language prescriptivist",
            "linguistic prescriptivist",
            "die-hard prescriptivist",
            "prescriptivist group",
            "grammar prescriptivist"
          ],
          "synonyms": ["grammar purist", "grammar police", "prescription-minded linguist"],
          "antonyms": ["descriptive linguist", "usage-based linguist"],
          "register": "formal",
          "domain": ["language", "general", "education"]
        }
      ]
    },
    {
      "term": "prescriptivists",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of prescriptivist; people who advocate fixed rules for language and judge usage against those rules",
          "examples": [
            "Prescriptivists often debate whether 'data' should be treated as singular or plural.",
            "The conference included several prescriptivists arguing for traditional grammar."
          ],
          "collocations": [
            "prescriptivists debate",
            "linguistic prescriptivists",
            "grammar purists and prescriptivists"
          ],
          "synonyms": ["grammar purists", "prescription-minded linguists"],
          "antonyms": ["descriptive linguists"],
          "register": "formal",
          "domain": ["language", "education", "academic"]
        }
      ]
    },
