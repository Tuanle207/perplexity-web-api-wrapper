{
  "items": [
    {
      "term": "quarantinable",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Capable of being placed in quarantine or of being restricted to prevent the spread of disease.",
          "examples": ["The infected shipment was deemed quarantinable until it could be cleared.", "Certain animals are quarantinable to protect the local herd."],
          "collocations": ["quarantine laws", "quarantinable disease", "quarantinable offense"],
          "synonyms": ["quarantineable" ],
          "antonyms": ["unquarantinable"],
          "register": "formal",
          "domain": ["health", "law", "public health"]
        }
      ]
    },
    {
      "term": "quarantine",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A period of isolation to prevent the spread of disease.",
          "examples": ["People were put under quarantine to stop the outbreak.", "The ship arrived during the 40-day quarantine."],
          "collocations": ["impose quarantine", "quarantine period", "end of quarantine"],
          "synonyms": ["isolation", "detention"],
          "antonyms": ["freedom", "liberation"],
          "register": "neutral",
          "domain": ["health", "public health", "general"]
        },
        {
          "pos": "verb",
          "definition": "To impose or undergo a period of isolation to prevent disease spread.",
          "examples": ["Authorities quarantined the town.", "They quarantined the animals for 21 days."],
          "collocations": ["quarantine someone", "quarantine period", "quarantine station"],
          "synonyms": ["isolate", "restrict"],
          "antonyms": ["release", "release from quarantine"],
          "register": "neutral",
          "domain": ["health", "public health"]
        }
      ]
    },
    {
      "term": "quarantined",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "Having been placed in quarantine.",
          "examples": ["The quarantined villagers could not leave their homes.", "Quarantined animals were not released until tested negative."],
          "collocations": ["quarantined area", "quarantined person", "quarantined for days"],
          "synonyms": ["isolated", "restricted"],
          "antonyms": ["unquarantined", "clear"],
          "register": "neutral",
          "domain": ["health", "public health"]
        }
      ]
    },
