      "term": "snuffly",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having a congested or blocked nose; stuffed up",
          "examples": [
            "I feel snuffly this morning and cannot breathe easily.",
            "Her snuffly nose made her voice sound nasal."
          ],
          "collocations": ["snuffly nose", "snuffly cold", "feel snuffly"],
          "synonyms": ["nasal", "blocked", "stuffy"],
          "antonyms": ["clear", "unblocked", "nasal-free"],
          "register": "informal",
          "domain": ["everyday", "health"]
        }
      ]
    },
