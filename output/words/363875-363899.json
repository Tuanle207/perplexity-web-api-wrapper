      "term": "snuffs",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the outer part of a candle wick that has been burned away; the end of a candle wick",
          "examples": [
            "The snuff of the candle needs trimming.",
            "She blew out the flame and pruned the snuffs."
          ],
          "collocations": ["candle snuffs", "trim snuffs"],
          "synonyms": ["wick end", "char"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "household"]
        },
        {
          "pos": "noun",
          "definition": "a small portion of tobacco that is chewed, sniffed, or inhaled through the nose; also used as a verb meaning to sniff or squelch with snuff",
          "examples": [
            "He took a pinch of snuff from the box.",
            "She snuffed the powder from under the nose of the old clock."
          ],
          "collocations": ["snuff (tobacco)", "snuff box"],
          "synonyms": ["tobacco", "snuff tobacco"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "history"]
        },
        {
          "pos": "verb",
          "definition": "to extinguish or stop something, especially a flame or light; to snuff out",
          "examples": [
            "The servant snuffed the candle before midnight.",
            "They snuffed out the last of the fires."
          ],
          "collocations": ["snuff out", "snuff the flame"],
          "synonyms": ["extinguish", "put out", "quash"],
          "antonyms": ["ignite", "kindle"],
          "register": "formal",
          "domain": ["general"]
        }
