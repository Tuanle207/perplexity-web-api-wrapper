    {
      "term": "pyromania",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a mental disorder characterized by an obsessive desire to start fires",
          "examples": [
            "The doctor diagnosed him with pyromania after he confessed to repeatedly setting small fires.",
            "Some cases of pyromania involve thrill rather than financial gain."
          ],
          "collocations": [
            "diagnosis of pyromania",
            "suffer from pyromania",
            "pyromania impulse",
            "fire-setting pyromania"
          ],
          "synonyms": ["fire-setting disorder", "fire-setting syndrome"],
          "antonyms": ["arsonist (person)", ""],
          "register": "formal",
          "domain": ["medicine", "general", "psychology"]
        }
      ]
    },
