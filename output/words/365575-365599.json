    {
      "term": "sonograph",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "an instrument or device that records or displays the sound waves produced by the human voice or other sounds, especially in a medical or scientific context",
          "examples": ["The doctor used a sonograph to visualize the fetus.", "A high-resolution sonograph can show tissue details."],
          "collocations": ["medical sonograph", "ultrasound sonograph", "vital signs sonograph"],
          "synonyms": ["ultrasound image", "sonogram"],
          "antonyms": [],
          "register": "formal",
          "domain": ["medical", "technology", "general"]
        }
      ]
    },
