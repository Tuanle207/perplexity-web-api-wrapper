  "items": [
    {
      "term": "catastrophes",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of catastrophe; events causing great and often sudden damage, suffering, or disaster",
          "examples": [
            "The flood and the fire were two catastrophes that struck the town in the same week.",
            "We prepared for potential catastrophes by improving emergency plans."
          ],
          "collocations": ["natural catastrophes", "environmental catastrophes", "major catastrophes", "massive catastrophes", "economic catastrophes"],
          "synonyms": ["disasters", "calamities", "disasters of unprecedented scale"],
          "antonyms": ["minor incidents", "small problems"],
          "register": "formal",
          "domain": ["general", "risk", "environment"]
        }
      ]
    },
    {
      "term": "catastrophic",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "causing or relating to a catastrophe; very harmful or disastrous",
          "examples": [
            "The wildfire caused catastrophic damage to the forest.",
            "It would be catastrophic if the project failed now."
          ],
          "collocations": ["catastrophic failure", "catastrophic damage", "catastrophic consequences", "catastrophic event"],
          "synonyms": ["disastrous", "calamitous", "ruinous"],
          "antonyms": ["beneficial", "helpful", "advantageous"],
          "register": "formal",
          "domain": ["general", "risk", "environment"]
        }
      ]
    },
