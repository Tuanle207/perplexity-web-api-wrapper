      "term": "catastrophism",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the doctrine that catastrophe rather than gradual change explains most geological features",
          "examples": [
            "Catastrophism was historically debated with uniformitarianism in geology.",
            "The book discusses catastrophism as a historical paradigm."
          ],
          "collocations": ["geological catastrophism", "historical catastrophism"],
          "synonyms": ["catastrophic theory"],
          "antonyms": ["uniformitarianism"],
          "register": "formal",
          "domain": ["science", "academic"]
        }
      ]
    },
