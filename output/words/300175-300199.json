    {
      "term": "postulata",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "plural noun",
          "definition": "the things that are proposed or assumed as true or necessary, especially in a theory or argument",
          "examples": [
            "The postulata of the scientific theory were later tested by experiments.",
            "He reviewed the postulata of the philosophical argument before presenting his critique."
          ],
          "collocations": [
            "restate the postulata",
            "test the postulata",
            "assess the postulata",
            "the foundational postulata"
          ],
          "synonyms": ["premises", "assumptions", "propositions"],
          "antonyms": [],
          "register": "formal",
          "domain": ["academic", "philosophy", "general"]
        }
      ]
    },
    {
      "term": "postulate",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a statement or proposition that is accepted as true without proof for the purpose of argument or investigation",
          "examples": [
            "Let’s accept this postulate for the sake of the model.",
            "The postulates of Euclidean geometry are foundational ideas."
          ],
          "collocations": [
            "assume a postulate",
            "base on the postulate",
            "geometric postulate",
            "universal postulate"
          ],
          "synonyms": ["assumption", "premise", "hypothesis"],
          "antonyms": ["fact", "proof"],
          "register": "formal",
          "domain": ["mathematics", "philosophy", "science"]
        },
        {
          "pos": "verb",
          "definition": "to suggest or assume something as true without proof",
          "examples": [
            "The theory postulates that all mammals have the same basic brain structure.",
            "Researchers postulate a link between diet and memory."
          ],
          "collocations": [
            "postulate a theory",
            "postulate a principle",
            "widely postulated"
          ],
          "synonyms": ["propose", "suggest", "hypothesize"],
          "antonyms": ["demonstrate", "prove"],
          "register": "formal",
          "domain": ["science", "philosophy", "academic"]
        }
      ]
    },
