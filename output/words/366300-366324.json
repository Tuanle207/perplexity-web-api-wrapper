      "term": "soundbite",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a short spoken extract from a longer interview or speech that is used to illustrate a point or to promote something",
          "examples": [
            "The news clip included a soundbite from the president.",
            "She edited the interview to include a catchy soundbite for social media."
