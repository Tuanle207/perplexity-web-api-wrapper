    {
      "term": "bootlessness",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state of lacking a boot or not having something essential to start; figuratively, a lack of initiative or readiness",
          "examples": [
            "The bootlessness of his efforts was obvious as he kept stalling at every checkpoint.",
            "Her bootlessness in facing deadlines led to repeated delays."
          ],
          "collocations": ["complete bootlessness", "economic bootlessness", "bootlessness of effort"],
          "synonyms": ["inadequacy", "unpreparedness"],
          "antonyms": ["readiness", "preparedness"],
          "register": "formal",
          "domain": ["general", "education"]
        }
      ]
    },
