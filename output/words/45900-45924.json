    {
      "term": "bootstrap",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a loop or mechanism for starting something, often a process or computer; also a framework name",
          "examples": [
            "We used a bootstrap process to start the application.",
            "The Bootstrap framework helps build responsive websites."
          ],
          "collocations": ["bootstrap process", "bootstrap framework"],
          "synonyms": ["self-start", "initialization"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "general"]
        },
        {
          "pos": "verb",
          "definition": "to start up or improve something using its own resources; to pull oneself up without external help",
          "examples": [
            "The company bootstrapped its way to profitability.",
            "You can bootstrap the project with existing data."
