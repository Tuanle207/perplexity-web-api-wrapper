      "term": "solstices",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the times of year when the sun reaches its highest or lowest point in the sky at noon, marking the longest and shortest days of the year",
          "examples": [
            "In most cultures, solstices are celebrated as seasonal turning points.",
            "The summer solstice has the longest day of the year."
          ],
          "collocations": ["summer solstice", "winter solstice", "solstice festival", "approach of solstice"],
          "synonyms": ["solstice day", "greatest sun position day"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "science", "calendar"]
        }
      ]
    },
