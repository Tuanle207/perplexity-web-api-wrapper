    {
      "term": "nonrepresentation",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the absence or failure to present or depict something; the state of not representing something",
          "examples": ["The film suffers from nonrepresentation of the minority group."],
          "collocations": ["lack of representation", "nonrepresentation of", "historical nonrepresentation"],
          "synonyms": ["underrepresentation", "absence of portrayal"],
          "antonyms": ["representation", "portrayal"],
          "register": "formal",
          "domain": ["general", "cultural studies"]
        }
      ]
    },
    {
