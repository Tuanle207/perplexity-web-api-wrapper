      "term": "rootedly",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a rooted or firmly established manner; in a way that shows strong, deep attachment or origin",
          "examples": [
            "The tradition stood rootedly in the village culture.",
            "She spoke rootedly in her family’s beliefs."
          ],
          "collocations": [
            "stand rootedly",
            "grow rootedly",
            "believe rootedly"
          ],
          "synonyms": ["steadily", "firmly", "deeply"],
          "antonyms": ["shallowly", "superficially"],
          "register": "formal",
          "domain": ["general", "culture"]
        }
      ]
    },
