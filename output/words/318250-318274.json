      "term": "quinine",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a bitter compound derived from the cinchona tree, used as a medicine to treat malaria and as a flavoring agent in tonic water",
          "examples": [
            "Quinine is an ingredient in some anti-malarial drugs.",
            "Tonic water is flavored with quinine."
          ],
          "collocations": ["quinine sulfate", "quinine-based", "malaria treatment", "tonic water"],
          "synonyms": ["cinchona alkaloid", "quinidine (related)", "antimalarial compound"],
          "antonyms": [],
          "register": "formal",
          "domain": ["medicine", "healthcare", "general"]
        }
      ]
