      "term": "toadyism",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "the behavior or quality of a toady; a servile or obsequious way of acting toward someone important in order to gain favor",
          "examples": [
            "His toadyism toward the boss made him unpopular with colleagues.",
            "She resented the constant display of toadyism at the meetings."
          ],
          "collocations": [
            "a display of toadyism",
            "pack of toadyism",
            "political toadyism",
            "blatant toadyism"
          ],
          "synonyms": ["servility", "sycophancy", "worming", "obsequiousness"],
          "antonyms": ["independence", "frankness", "candor"],
          "register": "formal",
          "domain": ["general", "psychology", "social"]
        }
      ]
    },
