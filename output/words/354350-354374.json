    {
      "term": "sharecrop",
      "kind": "verb",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to work a farm and receive a portion of the crops as payment instead of a salary",
          "examples": [
            "The tenant agreed to sharecrop the land with the farmer.",
            "They decided to sharecrop the plots to avoid upfront costs."
          ],
          "collocations": [
            "sharecrop a field",
            "sharecrop agreement",
            "sharecropping system"
          ],
          "synonyms": ["farm on a share", "crop-share farming"],
          "antonyms": ["cash rent", "own farm outright"],
          "register": "neutral",
          "domain": ["agriculture", "general"]
        }
      ]
    },
