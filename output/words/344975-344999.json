    {
      "term": "scavenge",
      "kind": "verb",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to search for and collect things that others have left behind, often for reuse or profit",
          "examples": [
            "The old building was scavenging for scraps of metal in the junkyard.",
            "They scavenged the beach for plastic bottles to recycle."
          ],
          "collocations": ["scavenge for", "scavenge scraps", "scavenge metal", "scavenge food"],
          "synonyms": ["hunt", "forage", "rummage", "collect"],
          "antonyms": ["discard", "ignore"],
          "register": "informal",
          "domain": ["everyday", "general"]
        },
        {
          "pos": "verb",
          "definition": "to remove fuel from a damaged vehicle or aircraft after an accident or to seek and remove usable parts from a wreck",
          "examples": [
            "The salvaged parts were scavenged from the wreck.",
            "They scavenged the airplane fuselage for spare components."
          ],
          "collocations": ["scavenge parts", "scavenge a wreck", "scavenge the chassis"],
          "synonyms": ["salvage", "strip"],
          "antonyms": ["manufacture", "create"],
          "register": "neutral",
          "domain": ["general", "technical"]
        }
      ]
    },
