      "term": "cajolery",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of using flattery or charming talk to persuade someone",
          "examples": [
            "His cajolery did not win her agreement this time.",
            "She resisted his cajolery and stood firm on her decision."
          ],
          "collocations": [
            "persistent cajolery",
            "use cajolery",
            "flattery and cajolery"
          ],
          "synonyms": [
            "flattery",
            "persuasion",
            "coaxing"
          ],
          "antonyms": [
            "honesty",
            "frankness",
            "bluntness"
          ],
          "register": "formal",
          "domain": ["general", "social", "psychology"]
        }
      ]
    },
