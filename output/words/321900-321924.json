  "items": [
    {
      "term": "readjusting",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "verb",
          "definition": "changing something again to correct or improve its position, size, or arrangement",
          "examples": [
            "She started readjusting the picture on the wall after noticing it was crooked.",
            "The policy is about readjusting prices to reflect market changes."
          ],
          "collocations": ["readjusting balance", "readjusting the margins", "readjusting settings"],
          "synonyms": ["repositioning", "readapting"],
          "antonyms": ["stabilizing", "holding"],
          "register": "neutral",
          "domain": ["general", "everyday", "business"]
        }
      ]
    },
    {
      "term": "readjustment",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of changing something again to correct or improve it",
          "examples": [
            "There was a readjustment of salaries after the audit.",
            "The readjustment in policy led to clearer guidelines."
          ],
          "collocations": ["economic readjustment", "readjustment period", "readjustment of prices"],
          "synonyms": ["rearrangement", "recalibration"],
          "antonyms": ["stability", "normalization"],
          "register": "neutral",
          "domain": ["general", "business", "economy"]
        }
      ]
    },
    {
      "term": "readjustments",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "instances of changing something again to correct or improve it",
