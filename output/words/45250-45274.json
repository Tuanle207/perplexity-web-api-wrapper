    {
      "term": "bond",
      "kind": "word",
      "cefrLevel": "A1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a strong connection or link between people, ideas, or objects",
          "examples": [
            "There is a strong bond between mother and child.",
            "They formed a bond after working together."
          ],
          "collocations": [
            "family bond",
            "emotional bond",
            "bond with"
          ],
          "synonyms": ["connection", "link", "tie"],
          "antonyms": ["separation", "rupture"],
          "register": "neutral",
          "domain": ["general", "social"]
        },
        {
          "pos": "noun",
          "definition": "a legal contract by which a debt is secured; a certificate of indebtedness",
          "examples": [
            "The government sold bonds to finance the project.",
            "She bought a 10-year government bond."
          ],
          "collocations": [
            "government bond",
            "corporate bond",
            "issue bonds"
          ],
          "synonyms": ["security", "debt instrument"],
          "antonyms": [],
          "register": "formal",
          "domain": ["finance", "economy"]
        },
        {
          "pos": "verb",
          "definition": "to join or secure with a bond or bonds; to fasten or connect",
          "examples": [
            "The two pieces are bonded with epoxy.",
            "The shelves are bonded to the wall."
          ],
          "collocations": [
            "bond together",
            "bond with",
            "chemical bond"
          ],
          "synonyms": ["attach", "fasten", "link"],
          "antonyms": ["detach", "separate"],
          "register": "neutral",
          "domain": ["science", "general"]
        }
      ]
    },
