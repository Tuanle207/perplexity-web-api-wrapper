  "items": [
    {
      "term": "bonapartism",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a political ideology or movement supporting Napoleon Bonaparte or his ideals, especially the idea of strong centralized leadership and authority",
          "examples": [
            "Bonapartism influenced many early 19th‑century political groups in Europe.",
            "Some critics viewed the regime as a form of Bonapartism."
          ],
          "collocations": [
            "Bonapartism flourished",
            "support for Bonapartism",
            "Bonapartism and empire"
          ],
          "synonyms": ["Napoleonicism", "bonapartist ideology"],
          "antonyms": ["liberalism", "republicanism"],
          "register": "formal",
          "domain": ["history", "politics", "general"]
        }
      ]
    },
    {
      "term": "bonapartist",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a supporter of Napoleon Bonaparte or his political successors; someone who favors strong centralized leadership",
          "examples": [
            "The party attracted several bonapartists who believed in strong, decisive leadership.",
            "As a bonapartist, he admired the Napoleonic model of governance."
          ],
          "collocations": [
            "bonapartist supporter",
            "bonapartist regime",
            "bonapartist faction"
          ],
          "synonyms": ["Napoleonic supporter", "authoritarian nationalist"],
          "antonyms": ["liberal", "democrat"],
          "register": "formal",
          "domain": ["history", "politics"]
        }
      ]
    },
