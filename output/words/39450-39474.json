      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a member of a low-caste or marginalized group in South Asia traditionally associated with manual scavenging or cleaning sewers.",
          "examples": [
            "The documentary explored the life of a bhangi and the social stigma they face.",
            "Historically, the role of the bhangi involved dangerous manual labor."
          ],
          "collocations": [
            "bhangi community",
