          "antonyms": ["doubt", "disbelieve"],
          "register": "informal",
          "domain": ["general"]
        },
        {
          "pos": "verb",
          "definition": "to calculate or compute something, especially a total",
          "examples": [
            "He counted and reckoned the expenses.",
            "They reckoned the years since the invention."
          ],
          "collocations": [
            "reckon up",
            "reckon the total",
            "reckon the cost"
          ],
          "synonyms": ["calculate", "compute", "tally"],
          "antonyms": ["estimate (approximate)"],
          "register": "neutral",
          "domain": ["general", "finance"]
        }
      ]
    },
