  "items": [
    {
      "term": "recklessly",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a way that shows a lack of care for danger or consequences",
          "examples": [
            "He drove recklessly and endangered others on the road.",
            "She spent her money recklessly, without considering the future."
          ],
          "collocations": [
            "drive recklessly",
            "spend recklessly",
            "act recklessly",
            "behave recklessly"
          ],
          "synonyms": ["heedlessly", "carelessly", "irresponsibly"],
          "antonyms": ["carefully", "cautiously", "prudently"],
          "register": "informal",
          "domain": ["everyday", "general"]
        }
      ]
    },
    {
