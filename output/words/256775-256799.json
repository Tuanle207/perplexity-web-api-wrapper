            "He discussed noumenal aspects of reality."
          ],
          "collocations": [
            "noumenal reality",
            "noumenal form",
            "noumenal distinction"
          ],
          "synonyms": ["transcendental", "thing-in-itself-related"],
          "antonyms": ["phenomenal", "phenomenalistic"],
          "register": "formal",
          "domain": ["philosophy", "theology"]
        }
      ]
    },
