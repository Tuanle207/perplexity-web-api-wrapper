    {
      "term": "noumena",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun (plural of noumenon)",
          "definition": "the kind of thing that exists independently of our experience; in Kantian philosophy, the thing-in-itself as opposed to phenomena which we perceive",
          "examples": [
            "Philosophers debate whether noumena can be known directly.",
            "For Kant, noumena are beyond our sensory experience."
          ],
          "collocations": [
            "transcendental noumena",
            "conceive noumena",
            "recognize noumena"
          ],
          "synonyms": ["thing-in-itself", "noumenon (plural)"},
          "antonyms": ["phenomena", "appearance"],
          "register": "formal",
          "domain": ["philosophy", "general"]
        }
      ]
    },
    {
