  "items": [
    {
      "term": "precondition",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a condition that must be met before something else happens",
          "examples": ["The contract includes a precondition that both parties must sign.", "Access to the system is limited by a precondition of verification."],
          "collocations": ["necessary precondition", "condition as a precondition", "legal precondition", "precondition for"],
          "synonyms": ["precondition", "condition precedent", "requirement"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "law", "business"]
        },
        {
          "pos": "verb",
          "definition": "to make something required beforehand",
          "examples": ["The project preconditions the approval on environmental safeguards.", "They preconditioned the grant with a review schedule."],
          "collocations": ["precondition something", "preconditioned by", "preconditioning"],
          "synonyms": ["condition", "require", "make a prerequisite of"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
