      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a game or match in which one team prevents the other from scoring any points or goals",
          "examples": [
            "The final score was a 3–0 shutout.",
            "They earned a shutout in the championship game."
          ],
          "collocations": ["defensive shutout", "record a shutout", "get/achieve a shutout"],
          "synonyms": ["clean sheet (sports)"],
          "antonyms": ["allowing goals", "being scored on"],
          "register": "neutral",
          "domain": ["sports", "general"]
        }
      ]
    },
