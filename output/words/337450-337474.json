      "term": "romcom",
      "kind": "abbreviation",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "a romantic comedy, a movie or book that focuses on love and humor",
          "examples": [
            "We watched a light romcom on Friday night.",
            "That romcom has a predictable ending, but it’s fun."
          ],
          "collocations": [
            "romcom film",
            "romcom movie",
            "romcom night",
            "romcom plot",
            "romcom stereotype"
          ],
          "synonyms": ["romantic comedy", "love comedy"],
          "antonyms": [],
          "register": "informal",
          "domain": ["entertainment", "general"]
        }
      ]
    },
