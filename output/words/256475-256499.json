    {
      "term": "nostrums",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "a poor, ineffective, or unproven remedy or scheme; a medicine or treatment with no real efficacy",
          "examples": [
            "Many fad diets are just nostrums that don’t work in the long run.",
            "The inventor claimed the device was a universal nostrum, but experts remained skeptical."
          ],
          "collocations": [
            "patent nostrum",
            "ridiculous nostrum",
            "quack nostrum",
            "fountain of nostrums"
          ],
          "synonyms": [
            "panacea (often used ironically)",
            "remedy (pejorative sense)",
            "cure-all (pejorative sense)"
          ],
          "antonyms": [
            "effective cure",
            "proven treatment",
            "scientific remedy"
          ],
          "register": "formal",
          "domain": ["general", "medicine", "history"]
        }
      ]
    },
