{
  "items": [
    {
      "term": "processor",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A device that performs processing, especially the central part of a computer that executes instructions.",
          "examples": [
            "The processor handles all the calculations in the laptop.",
            "Upgrade the processor to improve performance."
          ],
          "collocations": [
            "central processor",
            "processor speed",
            "multi-core processor",
            "CPU and processor",
            "Intel/AMD processor"
          ],
          "synonyms": ["CPU", "microprocessor", "brains of the computer"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["technology", "general", "computing"]
        },
        {
          "pos": "noun",
          "definition": "A person or organization that processes something, such as data or agricultural products.",
          "examples": [
            "The chocolate factory is a large processor of cocoa beans.",
            "The data processor sorts the survey results."
          ],
          "collocations": [
            "data processor",
            "processor of records",
            "industrial processor",
            "food processor"
          ],
          "synonyms": ["processor (as a service)", "handler", "facilitator"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["business", "technology", "general"]
        }
      ]
    },
    {
