      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to add marks such as periods, commas, or question marks to writing",
          "examples": [
            "Please punctuate your essay correctly with periods and commas.",
            "The editor asked me to punctuate the dialogue properly."
          ],
          "collocations": ["punctuate text", "punctuate a sentence", "punctuate properly"],
          "synonyms": ["mark", "punctificate"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "education", "writing"]
        },
        {
          "pos": "verb",
          "definition": "to interrupt or emphasize at certain points in speech or writing (figurative use)",
          "examples": [
            "The speaker punctuated his talk with quick anecdotes.",
            "Her notes punctuated the chapter with bold headings."
