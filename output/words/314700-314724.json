    {
      "term": "punctualness",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the quality of being on time; arriving or occurring at the expected or planned time",
          "examples": [
            "Her punctualness made her a reliable team member.",
            "They were praised for their punctualness in starting the meeting on time."
          ],
          "collocations": ["high punctualness", "show punctualness", "excellent punctualness", "punctualness in timing"],
          "synonyms": ["reliability", "timeliness", "promptness"],
          "antonyms": ["tardiness", "lateness", "unreliability"],
          "register": "formal",
          "domain": ["general", "everyday"]
        }
      ]
    },
    {
