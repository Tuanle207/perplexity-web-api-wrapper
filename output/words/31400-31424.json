    {
      "term": "bait",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "food or something attractive used to attract and catch fish or animals",
          "examples": ["He put worms on the hook as bait.", "The bait attracted many fish to the trap.", "She used cheese as bait for the mouse."],
          "collocations": ["fishing bait", "live bait", "cut bait", "bait bucket", "fresh bait"],
          "synonyms": ["lure", "temptation", "entice"],
          "antonyms": [],
          "register": null,
          "domain": ["everyday", "fishing"]
        },
        {
          "pos": "noun",
          "definition": "something that tempts or tricks a person to do something",
          "examples": ["The cheap price was bait to get customers inside.", "Free samples are often bait for buying more.", "The offer turned out to be bait for a scam."],
          "collocations": ["bait and switch", "take the bait", "dangle bait", "bait for trouble"],
          "synonyms": ["trap", "enticement", "decoy"],
          "antonyms": [],
          "register": "informal",
          "domain": ["general", "business"]
        },
        {
          "pos": "verb",
          "definition": "to put food or a lure on a hook to catch fish",
          "examples": ["He baited the hook with a worm.", "She baited her line before casting it.", "We baited the traps with nuts."],
          "collocations": ["bait a hook", "bait a trap", "bait with worms", "freshly baited"],
          "synonyms": ["lure", "entice"],
          "antonyms": [],
          "register": null,
          "domain": ["fishing", "hunting"]
        },
        {
          "pos": "verb",
          "definition": "to deliberately make someone angry by saying or doing something annoying",
          "examples": ["He baited his brother by hiding his toys.", "Don't bait the dog or it will bark.", "She baited him with rude comments."],
          "collocations": ["bait someone", "bait into arguing", "bait with insults"],
          "synonyms": ["tease", "taunt", "provoke"],
          "antonyms": ["calm"],
          "register": "informal",
          "domain": ["everyday"]
        }
      ]
    },
