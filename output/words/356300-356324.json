          "collocations": ["final shortlists", "shortlists released", "shortlist committee"],
          "synonyms": ["top picks", "short lists"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "business"]
        },
        {
          "pos": "verb",
          "definition": "to include someone or something on a shortlist",
