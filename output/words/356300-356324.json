  "items": [
    {
      "term": "shortlisting",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the act of creating a shortlist by selecting a small number of candidates or items from a larger group",
          "examples": [
            "The company is shortlisting applicants for the interview.",
            "Shortlisting narrowed the pool to five strong candidates."
          ],
          "collocations": ["shortlisting process", "candidate shortlisting", "for shortlisting"],
          "synonyms": ["screening", "narrowing down"],
          "antonyms": ["outlining", "listing completely"],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
    {
      "term": "shortlists",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "lists of selected candidates or items that will be considered further",
          "examples": [
            "The shortlists were announced today.",
            "Her name appeared on several shortlists."
