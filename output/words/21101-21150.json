      "term": "apractic",
      "kind": "word",
      "cefrLevel": "C2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "relating to apraxia, a medical condition where a person cannot carry out purposeful movements even though muscles are not weak",
          "examples": [
            "Apractic symptoms appeared after the stroke affected his parietal lobe.",[11][12][13]
            "The clinic specializes in treating apractic patients with intensive therapy."[14][15][11]
          ],
