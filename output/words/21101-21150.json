      "term": "appurtenances",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "things that belong to or come with something more important, such as extra equipment, furniture, or possessions",
          "examples": [
            "The lawyer listed all the house and its appurtenances in the contract.",[1]
            "The appurtenances of wealth include luxury cars, art, and private staff."[1]
          ],
          "collocations": [
            "house and appurtenances",
            "land and appurtenances",
            "rights and appurtenances",
            "appurtenances of wealth",
            "appurtenances of office",
            "fixtures and appurtenances",
            "all appurtenances thereto"
          ],
          "synonyms": [
            "accessories",
            "extras",
            "belongings",
            "trappings"
          ],
          "antonyms": [
            "essentials",
            "core",
            "main property"
          ],
          "register": "formal",
          "domain": [
            "law",
            "business",
            "real_estate"
          ]
        },
        {
          "pos": "noun",
          "definition": "objects or possessions that are typical of a particular way of life",
          "examples": [
            "Books and laptops are among the appurtenances of student life.",[2]
            "The appurtenances of modern work include smartphones and constant email."[2]
          ],
          "collocations": [
            "appurtenances of student life",
