{
  "items": [
    {
      "term": "salivate",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to produce saliva in the mouth, especially in response to tasting something unpleasant or thinking about food",
          "examples": [
            "The smell of the bread made him salivate.",
            "Dogs salivate when they see their food.",
            "Salivating at the thought of the delicious meal, she waited eagerly."
          ],
          "collocations": [
            "salivate at/over",
            "salivate badly",
            "salivate uncontrollably",
            "start to salivate"
          ],
          "synonyms": ["drool", "dribble", "mouth water"],
          "antonyms": ["dry", "parched"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
