    {
      "term": "betray",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to break someone's trust by not keeping a promise or revealing secrets",
          "examples": [
            "If you tell a friend a secret and then tell others, you betray their trust.",
            "The spy betrayed his country by sharing classified information."
          ],
          "collocations": ["betray a friend", "betray someone's trust", "betray one's country"],
          "synonyms": ["disappoint", "deceive", "rat"],
          "antonyms": ["be loyal to", "keep a secret"],
          "register": "informal",
          "domain": ["general", "emotional"]
        },
        {
          "pos": "verb",
          "definition": "to reveal or make known something, often information that was hidden",
          "examples": [
            "The memo betrayed the company's intentions.",
            "New evidence betrayed the truth of the story."
