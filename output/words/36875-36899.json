    {
      "term": "belate",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to cause to be late or to arrive late; to do something later than planned or expected",
          "examples": [
            "I don't want to belate you, so I'll start the meeting now.",
            "If we belate the start, we'll miss the first speaker."
          ],
          "collocations": ["to belate", "late", "belatedly", "be belated"],
          "synonyms": ["delay", "postpone", "tarry"],
          "antonyms": ["advance", "expedite"],
          "register": "neutral",
          "domain": ["general", "everyday", "time"]
        }
      ]
    },
