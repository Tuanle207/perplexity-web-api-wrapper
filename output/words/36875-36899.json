      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "verb",
          "definition": "to fix or secure a rope or line so that it will not slip; to secure or fasten",
          "examples": [
            "Belay the rope to the anchor.",
            "He belayed the line to prevent it from moving."
          ],
          "collocations": ["belay the rope", "belay device", "belay line"],
          "synonyms": ["secure", "fasten", "anchor"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["general", "outdoors", "sport"]
        },
        {
          "pos": "verb",
          "definition": "to cancel or reverse a previous order or instruction; to stop following an order",
          "examples": [
            "The captain belayed the command due to poor visibility.",
            "Belay that instruction; abandon the plan."
          ],
          "collocations": ["belay the command", "belay that order"],
          "synonyms": ["cancel", "withdraw", "reverse"],
          "antonyms": [],
          "register": "formal",
          "domain": ["military", "general"]
        }
