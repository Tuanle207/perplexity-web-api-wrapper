      "term": "routinisations",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of routinisation: the process of making something routine or standard through repetition or formalization",
          "examples": [
            "The routinisations of the manufacturing process reduced variability.",
            "Many companies pursue routinisations to improve efficiency."
