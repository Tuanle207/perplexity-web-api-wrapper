          "collocations": [
            "process routinisation",
            "design routinisation",
            "clinical routinisation"
          ],
          "synonyms": ["standardization", "formalization", "regularization"],
          "antonyms": ["flexibility", "innovation"],
          "register": "formal",
          "domain": ["general", "business", "industry"]
        }
      ]
    },
