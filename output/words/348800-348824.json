    {
      "term": "secondarily",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "adverb",
          "definition": "in a secondary way; not primary or main",
          "examples": [
            "The company focuses on core products, and profits are generated secondarily.",
            "Secondarily, we consider long-term effects."
          ],
          "collocations": [
            "focus on",
            "be secondary",
            "consider secondarily"
          ],
          "synonyms": ["peripherally", "second to none (contrastive usage)"],
          "antonyms": ["primarily", "mainly"],
          "register": "formal",
          "domain": ["general", "business"]
        }
      ]
    },
