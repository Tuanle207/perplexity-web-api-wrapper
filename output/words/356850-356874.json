    {
      "term": "shuddered",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "past tense of shudder: to tremble or shake suddenly as a result of fear, cold, or strong emotion",
          "examples": [
            "She shuddered at the sight of the grim room.",
            "The cold wind made him shuddered for a moment."
          ],
          "collocations": ["shuddered with fear", "shuddered violently", "shuddered in surprise"],
          "synonyms": ["trembled", "shivered"],
          "antonyms": ["relaxed", "settled"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
