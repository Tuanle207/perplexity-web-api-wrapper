    {
      "term": "proven",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "having been shown to be true or real",
          "examples": [
            "The evidence proved his claim was true.",
            "They have proven results from the study."
          ],
          "collocations": ["proven fact", "proven method", "proven track record"],
          "synonyms": ["established", "demonstrated", "verified"],
          "antonyms": ["unproven", "unverified"],
          "register": "formal",
          "domain": ["general", "academic"]
        },
        {
          "pos": "verb",
          "definition": "to establish the truth or validity of something by evidence or argument",
          "examples": [
            "The tests proved the hypothesis.",
            "This method proved effective in practice."
          ],
          "collocations": ["prove a point", "prove to be", "prove conclusively"],
          "synonyms": ["demonstrate", "substantiate", "verify"],
          "antonyms": ["disprove", "refute"],
          "register": "formal",
          "domain": ["general", "academic"]
        }
      ]
    },
