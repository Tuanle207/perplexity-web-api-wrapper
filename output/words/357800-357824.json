      "term": "significantly",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adverb",
          "definition": "to a large or important degree",
          "examples": [
            "Sales have increased significantly this quarter.",
            "Her health improved significantly after the treatment."
          ],
          "collocations": [
            "increase significantly",
            "significantly different",
            "significantly higher",
            "significantly smaller",
            "significantly affect",
            "significantly more/less"
          ],
          "synonyms": ["considerably", "dramatically", "substantially", "notably"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "business", "economics"]
        }
      ]
    },
