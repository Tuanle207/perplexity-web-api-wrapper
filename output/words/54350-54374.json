    {
      "term": "calculative",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "adjective",
          "definition": "tending to calculate or compute; focused on numbers and results",
          "examples": ["She has a calculative mind and plans every move carefully.", "A calculative approach can help in budgeting."],
          "collocations": ["calculative mind", "calculative approach", "calculative thinking", "calculative device"],
          "synonyms": ["calculating", "prudent", "strategic"],
          "antonyms": ["impulsive", "careless"],
          "register": "neutral",
          "domain": ["general", "everyday", "business"]
        }
      ]
    },
    {
