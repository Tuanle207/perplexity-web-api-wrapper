      "term": "bibliolatrists",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "people who worship books or regard books as sacred objects.",
          "examples": [
            "The bibliolatrists treated ancient manuscripts as holy relics.",
            "Some bibliolatrists collect rare volumes and guard them as if they were sacred."
          ],
          "collocations": [
            "biblical bibliolatrists",
            "academic bibliolatrists",
            "die-hard bibliolatrists",
            "mythical bibliolatrists"
          ],
          "synonyms": [
            "book worshippers",
            "bibliophiles (but more about loving books than worship)"
          ],
          "antonyms": [
            "book critics",
            "anti-bibliophiles"
          ],
          "register": "neutral",
          "domain": ["general", "culture", "literature"]
        }
      ]
    },
