      "term": "skinworm",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "noun",
          "definition": "a vermiform larva that feeds on or within the skin of a host, sometimes used to refer to parasitic worm larvae that affect skin",
          "examples": [
            "The farmer warned of skinworms that infested the stored grain and damaged the kernels.",
            "In some reptiles, skinworms can cause irritation when they burrow under the skin."
          ],
          "collocations": [
            "skinworm infestation",
            "skinworm larvae",
            "treatment for skinworms"
          ],
          "synonyms": ["parasite", "worm larva"],
          "antonyms": [],
          "register": "formal",
          "domain": ["biology", "medicine", "general"]
        }
      ]
