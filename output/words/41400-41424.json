    {
      "term": "bipedality",
      "kind": "word",
      "cefrLevel": "C1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the state or condition of having two feet used for walking or standing, as opposed to quadrupedalism",
          "examples": [
            "The evolution of bipedality distinguished humans from many other primates.",
            "Researchers study the biomechanics of bipedality to understand gait efficiency."
          ],
          "collocations": [
            "human bipedality",
            "animal bipedality",
            "evolution of bipedality",
            "faculties supporting bipedality"
          ],
          "synonyms": ["two-footed locomotion", "bipedalism"],
          "antonyms": ["quadrupedality", "quadrapedalism"],
          "register": "formal",
          "domain": ["science", "biology", "anatomy", "academic"]
        }
      ]
    },
