  "items": [
    {
      "term": "preimposes",
      "kind": "verb",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "verb",
          "definition": "to place a burden, requirement, or obligation before something or someone; to impose beforehand",
          "examples": [
            "The policy preimposes strict limits on emissions before the project begins.",
            "The contract preimposes additional responsibilities on the contractor."
          ],
          "collocations": ["preimpose a burden", "preimpose conditions", "preimpose restrictions"],
          "synonyms": ["prerequire", "precondition"],
          "antonyms": ["remove", "lift", "waive"],
          "register": "formal",
          "domain": ["law", "business", "general"]
        }
      ]
    },
    {
      "term": "preimposing",
