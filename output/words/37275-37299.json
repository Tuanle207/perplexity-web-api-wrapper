    {
      "term": "bely",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "To lie or be located in a way that shows or reveals something; to reveal or betray.",
          "examples": [
            "Her trembling hands bely her calm demeanor.",
            "The evidence belies his claims of innocence."
          ],
          "collocations": ["bely the truth", "bely the surface", "bely the lie"],
          "synonyms": ["reveal", "betray", "disclose"],
          "antonyms": ["conceal", "hide"],
          "register": "formal",
          "domain": ["general", "law", "psychology"]
        }
      ]
    },
    {
      "term": "belying",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "verb",
          "definition": "Present participle of bely; showing something to be false or not as claimed.",
          "examples": [
            "The data are belying the team's optimistic projections."
          ],
          "collocations": ["belying the claims", "belying the appearance"],
          "synonyms": ["disproving", "refuting", "contradicting"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "science", "business"]
        }
      ]
    },
    {
      "term": "belyingly",
      "kind": "word",
      "cefrLevel": null,
      "senses": [
        {
          "pos": "adverb",
          "definition": "In a way that reveals to be false or contradicts; in a way that betrays.",
          "examples": [
            "The statistic changed belyingly as more data came in."
