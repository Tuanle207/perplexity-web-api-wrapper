      "term": "belvedere",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "A structure or balcony with a view, especially on a hill or high place; a lookout point.",
          "examples": [
            "They stood on the belvedere to enjoy the panorama of the city.",
            "The villa features a marble belvedere that overlooks the gardens."
          ],
          "collocations": ["belvedere terrace", "peaceful belvedere", "panoramic belvedere", "balcony belvedere", "on the belvedere"],
          "synonyms": ["viewpoint", "lookout", "balcony", "promenade"],
          "antonyms": [],
          "register": "formal",
          "domain": ["general", "architecture", "travel"]
        }
