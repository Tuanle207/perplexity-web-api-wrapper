    {
      "term": "schlimazel",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "a person who is chronically unlucky or misfortunate, especially someone who seems to attract bad luck or mishaps without trying",
          "examples": [
            "In the story, the main character was a real schlimazel, always missing the bus and dropping his umbrella in the rain."
          ],
          "collocations": [
            "true schlimazel",
            "terrible schlimazel",
            "unlucky schlimazel",
            "kamische schlimazel" 
          ],
          "synonyms": ["jinx", "misfortune magnet", "unlucky person"],
          "antonyms": ["lucky person", "fortunate one"],
          "register": "informal",
          "domain": ["everyday", "humor"]
        }
      ]
    },
    {
      "term": "schlimazels",
      "kind": "word",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "plural of schlimazel; multiple people who are chronically unlucky",
          "examples": [
            "The parade drew three schlimazels, each tripping over their own feet at some point."
          ],
          "collocations": [
            "group of schlimazels",
            "two schlimazels"
          ],
          "synonyms": ["jinxes (plural)", "unlucky people (plural)"],
          "antonyms": ["lucky people (plural)", "fortunate ones"],
          "register": "informal",
          "domain": ["everyday", "humor"]
        }
      ]
    },
