  "items": [
    {
      "term": "nonperformance",
      "kind": "word",
      "cefrLevel": "B2",
      "senses": [
        {
          "pos": "noun",
          "definition": "The act or instance of not performing or failing to perform a duty or task",
          "examples": [
            "The project was delayed due to nonperformance of key team members.",
            "Nonperformance of contractual obligations can lead to penalties."
          ],
          "collocations": ["nonperformance of duties", "risk of nonperformance", "record of nonperformance"],
          "synonyms": ["failure to perform", "underperformance"],
          "antonyms": ["performance", "fulfillment"],
          "register": "formal",
          "domain": ["business", "law", "general"]
        }
      ]
    },
    {
