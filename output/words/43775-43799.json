      "cefrLevel": "null",
      "senses": [
        {
          "pos": "noun",
          "definition": "extremely loud, inflated, or verbose speech or writing, often with the aim of sounding impressive but lacking substance",
          "examples": ["His political speech was filled with bloviations that bored the audience."],
          "collocations": ["political bloviations", "ridiculous bloviations", "bloviations about"],
          "synonyms": ["bombast", "gasconade", "grandiloquence"],
          "antonyms": ["conciseness", "brevity"],
          "register": "informal",
          "domain": ["general", "politics"]
        }
      ]
