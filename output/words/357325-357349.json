{
  "items": [
    {
      "term": "sideline",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "noun",
          "definition": "the edge or border of a field, court, or playing area; a line marking the side of something",
          "examples": ["The players stood on the sideline during the coach's talk.", "She stood to the sideline to watch the game."],
          "collocations": ["sideline of the field", "on the sideline", "pull to the sideline"],
          "synonyms": ["edge", "border", "perimeter"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["everyday", "sports"]
        },
        {
          "pos": "noun",
          "definition": "a secondary or unofficial position or role; something kept in reserve or out of main use",
          "examples": ["He kept his project on the sideline while he finished his degree.", "The startup was kept on the sideline until funding came through."],
          "collocations": ["put on the sideline", "sideline role", "sideline project"],
          "synonyms": ["reserve", "backup", "auxiliary"],
          "antonyms": [],
          "register": "neutral",
          "domain": ["business", "general"]
        },
        {
          "pos": "verb",
          "definition": "to push someone or something to the side; to exclude from main activity or consideration",
          "examples": ["The committee sidelined the proposal for further discussion.", "She felt sidelined by the new management."],
          "collocations": ["sidelined by", "sideline the proposal", "sidelining of"],
          "synonyms": ["exclude", "marginalize", "ignore"],
          "antonyms": ["include", "prioritize"],
          "register": "neutral",
          "domain": ["general", "business", "politics"]
        }
      ]
    },
    {
