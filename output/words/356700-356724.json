{
  "items": [
    {
      "term": "shrink",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "verb",
          "definition": "to become smaller in size or to make something smaller",
          "examples": [
            "The sweater will shrink if you wash it in hot water.",
            "Pack the clothes carefully so they won't shrink during the move.",
            "The balloon shrank as the air escaped."
          ],
          "collocations": ["shrink (in size)", "shrink quickly", "shrink back", "shrink wrap"],
          "synonyms": ["contract", "compress", "diminish"],
          "antonyms": ["expand", "grow"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
    {
      "term": "shrinkable",
      "kind": "word",
      "cefrLevel": "B1",
      "senses": [
        {
          "pos": "adjective",
          "definition": "able to become smaller or to be saved from shrinking",
          "examples": [
            "Cotton is not very shrinkable when washed at high temperatures.",
            "This fabric is not shrinkable if you follow the care label."
          ],
          "collocations": ["shrinkable fabric", "shrinkable clothes"],
          "synonyms": ["compressible", "contractible"],
          "antonyms": ["nonshrinking", "sturdy"],
          "register": "neutral",
          "domain": ["general", "everyday"]
        }
      ]
    },
    {
      "term": "shrinkage",
      "kind": "word",
      "cefrLevel": "A2",
      "senses": [
        {
          "pos": "noun",
          "definition": "the process or result of something getting smaller",
          "examples": [
            "There was a noticeable shrinkage in the company’s size after the layoffs.",
            "Fabric shrinkage can ruin a garment if washed at the wrong temperature."
          ],
          "collocations": ["shrinkage amount", "inventory shrinkage", "price shrinkage"],
          "synonyms": ["reduction", "decrease", "condensation"],
          "antonyms": ["expansion", "growth"],
          "register": "neutral",
          "domain": ["business", "general", "everyday"]
        }
      ]
    },
