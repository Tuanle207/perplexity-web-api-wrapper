      "term": "shaddup",
      "kind": "idiom",
      "cefrLevel": "null",
      "senses": [
        {
          "pos": "interjection",
          "definition": "a rude or slang way of telling someone to be quiet",
          "examples": [
            "Shaddup and let me finish my story.",
            "If you’d just shaddup, you might hear what they’re saying."
          ],
          "collocations": ["shaddup already", "shaddup you"]
          ,
          "synonyms": ["shut up", "be quiet", "hush up"],
          "antonyms": ["talk", "speak up"],
          "register": "informal",
          "domain": ["everyday", "colloquial"]
        }
      ]
    },
